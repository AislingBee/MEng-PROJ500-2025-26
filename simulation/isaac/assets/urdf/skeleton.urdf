      </geometry>
    </collision>
  </link>

  <!-- =========================
       JOINTS (Z-UP ORIGINS + AXES)
       ========================= -->


  <!-- Torso -->
  <joint name="torso_joint" type="revolute">
    <parent link="pelvis_link"/>
    <child link="torso_link"/>
    <origin xyz="0.00 0.00 0.00" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <!-- Left leg chain -->
  <joint name="l_hip_yaw_joint" type="revolute">
    <parent link="pelvis_link"/>
    <child link="l_hip_yaw_link"/>
    <origin xyz="0.00 0.12 -0.01" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <joint name="l_hip_pitch_joint" type="revolute">
    <parent link="l_hip_yaw_link"/>
    <child link="l_hip_pitch_link"/>
    <origin xyz="0.00 0.08 -0.14" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <joint name="l_hip_roll_joint" type="revolute">
    <parent link="l_hip_pitch_link"/>
    <child link="l_thigh_link"/>
    <origin xyz="0.00 -0.08 0.00" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <joint name="l_knee_joint" type="revolute">
    <parent link="l_thigh_link"/>
    <child link="l_shank_link"/>
    <origin xyz="0.00 0.01 -0.30" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <joint name="l_ankle_joint" type="revolute">
    <parent link="l_shank_link"/>
    <child link="l_ankle_link"/>
    <origin xyz="0.00 0.00 -0.30" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <joint name="l_foot_joint" type="revolute">
    <parent link="l_ankle_link"/>
    <child link="l_foot_link"/>
    <origin xyz="0.07 -0.01 0.00" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <!-- Right leg chain -->
  <joint name="r_hip_yaw_joint" type="revolute">
    <parent link="pelvis_link"/>
    <child link="r_hip_yaw_link"/>
    <origin xyz="0.00 -0.12 -0.01" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <joint name="r_hip_pitch_joint" type="revolute">
    <parent link="r_hip_yaw_link"/>
    <child link="r_hip_pitch_link"/>
    <origin xyz="0.00 -0.08 -0.14" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <joint name="r_hip_roll_joint" type="revolute">
    <parent link="r_hip_pitch_link"/>
    <child link="r_thigh_link"/>
    <origin xyz="0.00 0.08 0.00" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <joint name="r_knee_joint" type="revolute">
    <parent link="r_thigh_link"/>
    <child link="r_shank_link"/>
    <origin xyz="0.00 -0.01 -0.30" rpy="0 0 0"/>
