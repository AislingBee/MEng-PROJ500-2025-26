    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <joint name="r_ankle_joint" type="revolute">
    <parent link="r_shank_link"/>
    <child link="r_ankle_link"/>
    <origin xyz="0.00 0.00 -0.30" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
  </joint>

  <joint name="r_foot_joint" type="revolute">
    <parent link="r_ankle_link"/>
    <child link="r_foot_link"/>
    <origin xyz="0.07 0.01 0.00" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="120" velocity="5.0"/>
