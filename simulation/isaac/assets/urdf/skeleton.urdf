      </geometry>
    </collision>
  </link>

  <!-- Right leg links -->
  <link name="r_hip_yaw_link">
    <inertial>
      <origin xyz="0.00 -0.06 -0.07" rpy="0 0 0"/>
      <mass value="6.334"/>
      <inertia ixx="0.03" ixy="0.00" ixz="0.01"
               iyy="0.00" iyz="0.00" izz="0.03"/>
    </inertial>
