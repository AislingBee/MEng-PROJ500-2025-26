    </collision>
  </link>

  <link name="r_thigh_link">
    <inertial>
      <origin xyz="0.00 0.01 -0.26" rpy="0 0 0"/>
      <mass value="3.092"/>
      <inertia ixx="0.03" ixy="0.00" ixz="0.00"
               iyy="0.03" iyz="0.00" izz="0.00"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/skeleton/r_thigh_link.stl"/>
