  <link name="r_foot_link">
    <inertial>
      <origin xyz="0.02 0.00 -0.01" rpy="0 0 0"/>
      <mass value="2.790"/>
      <inertia ixx="0.01" ixy="0.00" ixz="0.00"
               iyy="0.01" iyz="0.00" izz="0.01"/>
