      <mass value="2.498"/>
      <inertia ixx="0.01" ixy="0.00" ixz="0.00"
               iyy="0.00" iyz="0.00" izz="0.00"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/skeleton/l_ankle_link.stl"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/skeleton/collision_meshes/l_ankle_link_collision.stl"/>
