      </geometry>
    </collision>
  </link>

  <link name="r_hip_pitch_link">
    <inertial>
      <origin xyz="-0.03 0.07 0.00" rpy="0 0 0"/>
      <mass value="2.494"/>
      <inertia ixx="0.00" ixy="0.00" ixz="0.00"
               iyy="0.01" iyz="0.00" izz="0.00"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/skeleton/r_hip_pitch_link.stl"/>
