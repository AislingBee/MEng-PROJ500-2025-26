    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/skeleton/collision_meshes/r_thigh_link_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <link name="r_shank_link">
    <inertial>
      <origin xyz="0.00 -0.02 -0.15" rpy="0 0 0"/>
      <mass value="0.852"/>
      <inertia ixx="0.01" ixy="0.00" ixz="0.00"
               iyy="0.01" iyz="0.00" izz="0.00"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
