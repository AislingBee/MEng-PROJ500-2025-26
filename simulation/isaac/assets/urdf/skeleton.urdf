<?xml version="1.0"?>
<robot name="skeleton">


    <!-- =========================
       LINKS (INERTIAL + VISUAL + COLLISION)
       Mesh paths are correct for:
       simulation/isaac/assets/urdf/skeleton.urdf
       simulation/isaac/assets/meshes/skeleton/*.stl
       simulation/isaac/assets/meshes/skeleton/collision_meshes/*_collision.stl
       ========================= -->

  <link name="pelvis_link">
    <inertial>
      <origin xyz="0.00 0.00 0.00" rpy="0 0 0"/>
      <mass value="0.470"/>
      <inertia ixx="0.01" ixy="0.00" ixz="0.00"
               iyy="0.01" iyz="0.00" izz="0.00"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/skeleton/pelvis_link.stl"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/skeleton/collision_meshes/pelvis_link_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <link name="torso_link">
    <inertial>
      <origin xyz="0.00 0.00 0.15" rpy="0 0 0"/>
      <mass value="3.477"/>
      <inertia ixx="0.05" ixy="0.00" ixz="0.00"
               iyy="0.05" iyz="0.00" izz="0.03"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/skeleton/torso_link.stl"/>
