      </geometry>
    </collision>
  </link>

  <link name="r_ankle_link">
    <inertial>
      <origin xyz="0.00 0.03 0.00" rpy="0 0 0"/>
      <mass value="2.498"/>
      <inertia ixx="0.01" ixy="0.00" ixz="0.00"
               iyy="0.00" iyz="0.00" izz="0.00"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
