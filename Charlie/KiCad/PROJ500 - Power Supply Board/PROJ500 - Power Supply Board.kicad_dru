(version 1)
(rule "TPS2492 local escape"
    (constraint clearance (min 0.25mm) (opt 0.25mm))
    (condition "A.insideArea('TPS2492_escape') && B.insideArea('TPS2492_escape')"))
(rule "MIC28517 SW"
    (constraint clearance (min 0.25mm) (opt 0.25mm))
    (condition "A.insideArea('MIC28517_SW') && B.insideArea('MIC28517_SW')"))
