static bool st_ssd_uart_apply(uint32_t baud, uint32_t stop_bits) {
	HAL_UART_DeInit(&ST_RS485_UART);

	ST_RS485_UART.Instance = USART3;
	ST_RS485_UART.Init.BaudRate = baud;
	ST_RS485_UART.Init.WordLength = UART_WORDLENGTH_8B;
	ST_RS485_UART.Init.StopBits = stop_bits;
	ST_RS485_UART.Init.Parity = UART_PARITY_NONE;
	ST_RS485_UART.Init.Mode = UART_MODE_TX_RX;
	ST_RS485_UART.Init.HwFlowCtl = UART_HWCONTROL_NONE;
	ST_RS485_UART.Init.OverSampling = UART_OVERSAMPLING_16;
	ST_RS485_UART.Init.OneBitSampling = UART_ONE_BIT_SAMPLE_DISABLE;
	ST_RS485_UART.Init.ClockPrescaler = UART_PRESCALER_DIV1;
	ST_RS485_UART.AdvancedInit.AdvFeatureInit = UART_ADVFEATURE_NO_INIT;

	if (HAL_UART_Init(&ST_RS485_UART) != HAL_OK) {
		return false;
	}

	(void) HAL_UARTEx_SetTxFifoThreshold(&ST_RS485_UART,
			UART_TXFIFO_THRESHOLD_1_8);
	(void) HAL_UARTEx_SetRxFifoThreshold(&ST_RS485_UART,
			UART_RXFIFO_THRESHOLD_1_8);
	(void) HAL_UARTEx_DisableFifoMode(&ST_RS485_UART);

	/* MspInit configures DE pin as AF7; override to GPIO output for manual
	 * DE control so st_rs485_de_set() actually drives the pin. */
	GPIO_InitTypeDef gpio_de = { 0 };
	gpio_de.Pin   = RS485_DE_Pin;
	gpio_de.Mode  = GPIO_MODE_OUTPUT_PP;
	gpio_de.Pull  = GPIO_NOPULL;
	gpio_de.Speed = GPIO_SPEED_FREQ_LOW;
	HAL_GPIO_Init(RS485_DE_GPIO_Port, &gpio_de);
	st_rs485_de_set(false);   /* start in receive mode */

	return true;
}

static bool st_ssd_uart_apply_defaults(void) {
	return st_ssd_uart_apply(ST_SSD_UART_BAUD, UART_STOPBITS_1);
}

/* Clear UART error flags + drain any stale RXNE byte accumulated during TX.
 * Called after DE deassert so the receive path starts clean. */
static void st_ssd_post_tx_cleanup(void) {
	HAL_Delay(1U);
	__HAL_UART_CLEAR_OREFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_NEFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_FEFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_PEFLAG(&ST_RS485_UART);
	if (__HAL_UART_GET_FLAG(&ST_RS485_UART, UART_FLAG_RXNE) != RESET) {
		(void)(ST_RS485_UART.Instance->RDR & 0xFFU);
	}
}

static void st_ssd_flush_rx(void) {
	uint32_t t0 = HAL_GetTick();

	__HAL_UART_CLEAR_OREFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_NEFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_FEFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_PEFLAG(&ST_RS485_UART);

	while ((HAL_GetTick() - t0) < 20U) {
		if (__HAL_UART_GET_FLAG(&ST_RS485_UART, UART_FLAG_RXNE) != RESET) {
			volatile uint8_t dump = (uint8_t) (ST_RS485_UART.Instance->RDR
					& 0xFFU);
			(void) dump;
			t0 = HAL_GetTick();
		}
	}

	__HAL_UART_CLEAR_OREFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_NEFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_FEFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_PEFLAG(&ST_RS485_UART);
}

static bool st_ssd_send_cmd(const char *cmd) {
	st_ssd_flush_rx();

	st_rs485_de_set(true);
	HAL_Delay(2U);

	HAL_StatusTypeDef st = HAL_UART_Transmit(&ST_RS485_UART, (uint8_t*) cmd,
			(uint16_t) strlen(cmd),
			ST_SSD_UART_TIMEOUT_MS);
	if (st != HAL_OK) {
		st_rs485_de_set(false);
		return false;
	}

	while (__HAL_UART_GET_FLAG(&ST_RS485_UART, UART_FLAG_TC) == RESET) {
	}
	st_rs485_de_set(false);
	st_ssd_post_tx_cleanup();

	return true;
}

static size_t st_ssd_read_capture(uint8_t *buf, size_t len, uint32_t timeout_ms) {
	if (buf == NULL || len == 0U)
		return 0U;

	size_t idx = 0U;
	uint8_t ch = 0U;
	uint32_t t0 = HAL_GetTick();
	bool got_any = false;

	while ((HAL_GetTick() - t0) < timeout_ms && idx < len) {
		HAL_StatusTypeDef rc = HAL_UART_Receive(&ST_RS485_UART, &ch, 1U, 20U);
		if (rc == HAL_OK) {
			buf[idx++] = ch;
			got_any = true;
			t0 = HAL_GetTick();
		} else {
			if (rc == HAL_ERROR) {
				/* Clear error flags so subsequent receives check for real data
				 * instead of immediately returning HAL_ERROR again. */
				__HAL_UART_CLEAR_OREFLAG(&ST_RS485_UART);
				__HAL_UART_CLEAR_NEFLAG(&ST_RS485_UART);
				__HAL_UART_CLEAR_FEFLAG(&ST_RS485_UART);
				__HAL_UART_CLEAR_PEFLAG(&ST_RS485_UART);
			}
			if (got_any && (HAL_GetTick() - t0) > 50U) {
				break;
			}
		}
	}

	return idx;
}

static bool st_ssd_extract_last_line(const uint8_t *raw, size_t raw_len,
		char *line, size_t line_len) {
	if (line == NULL || line_len == 0U)
		return false;
	line[0] = '\0';

	size_t best_start = 0U, best_len = 0U;
	size_t cur_start = 0U, cur_len = 0U;

	for (size_t i = 0U; i < raw_len; ++i) {
		uint8_t ch = raw[i];
		if (ch == '\r' || ch == '\n') {
			if (cur_len > 0U) {
				best_start = cur_start;
				best_len = cur_len;
				cur_len = 0U;
			}
			cur_start = i + 1U;
		} else {
			if (cur_len == 0U)
				cur_start = i;
			cur_len++;
		}
	}
	if (cur_len > 0U) {
		best_start = cur_start;
		best_len = cur_len;
	}

	if (best_len == 0U)
		return false;
	if (best_len >= line_len)
		best_len = line_len - 1U;

	memcpy(line, &raw[best_start], best_len);
	line[best_len] = '\0';
	return true;
}

static bool st_ssd_read_line(char *buf, size_t len, uint32_t timeout_ms) {
	if (len == 0U)
		return false;

	size_t idx = 0U;
	uint8_t ch = 0U;
	uint32_t t0 = HAL_GetTick();
	bool got_any = false;

	while ((HAL_GetTick() - t0) < timeout_ms) {
		if (HAL_UART_Receive(&ST_RS485_UART, &ch, 1U, 20U) == HAL_OK) {
			got_any = true;

			if (ch == '\r' || ch == '\n') {
				if (idx == 0U) {
					continue;
				}
				break;
			}

			if (idx < (len - 1U)) {
				buf[idx++] = (char) ch;
			}

			t0 = HAL_GetTick();
		}
	}

	buf[idx] = '\0';
	return got_any && (idx > 0U);
}

static bool st_ssd_query_text(const char *cmd, char *buf, size_t len) {
	uint8_t raw[ST_SSD_RX_BUF_LEN];

	if (buf == NULL || len == 0U)
		return false;
	buf[0] = '\0';

	if (!st_ssd_send_cmd(cmd))
		return false;

	size_t n = st_ssd_read_capture(raw, sizeof(raw), ST_SSD_RAW_TIMEOUT_MS);
	if (n == 0U)
		return false;

	return st_ssd_extract_last_line(raw, n, buf, len);
}

static bool st_ssd_query_i32(const char *cmd, char expected_prefix,
		int32_t *value) {
	char buf[ST_SSD_RX_BUF_LEN];
	char num[24];
	size_t ni = 0U;
	bool started = false;

	if (!st_ssd_query_text(cmd, buf, sizeof(buf)))
		return false;
	if (buf[0] != expected_prefix)
		return false;

	for (size_t i = 1U; buf[i] != '\0' && ni < (sizeof(num) - 1U); ++i) {
		char c = buf[i];
		if (!started) {
			if (c == '-' || c == '+' || isdigit((unsigned char )c)) {
				num[ni++] = c;
				started = true;
			}
		} else {
			if (isdigit((unsigned char )c)) {
				num[ni++] = c;
			} else {
				break;
			}
		}
	}
	num[ni] = '\0';
	if (ni == 0U)
		return false;
	*value = (int32_t) strtol(num, NULL, 10);
	return true;
}

static void st_ssd_print_readings(void) {
	int32_t current_ma = 0;
	int32_t vbus_mv = 0;
	int32_t temp_dC = 0;
	int32_t power_dW = 0;
	int32_t errors = 0;

	bool ok_i = st_ssd_query_i32(":1GA\r", 'A', &current_ma);
	HAL_Delay(20U);
	bool ok_v = st_ssd_query_i32(":1GV\r", 'V', &vbus_mv);
	HAL_Delay(20U);
	bool ok_t = st_ssd_query_i32(":1GT\r", 'T', &temp_dC);
	HAL_Delay(20U);
	bool ok_p = st_ssd_query_i32(":1GP\r", 'P', &power_dW);
	HAL_Delay(20U);
	bool ok_e = st_ssd_query_i32(":1G!\r", '!', &errors);

	if (!(ok_i && ok_v && ok_t && ok_p && ok_e)) {
		st_dbg_printf("[SSD] read failed (I=%u V=%u T=%u P=%u E=%u)\r\n",
				ok_i ? 1U : 0U, ok_v ? 1U : 0U, ok_t ? 1U : 0U, ok_p ? 1U : 0U,
				ok_e ? 1U : 0U);
		return;
	}

	/* Update cache on successful read */
	g_ssd_cache.current_a  = current_ma / 1000.0f;
	g_ssd_cache.voltage_v  = vbus_mv    / 1000.0f;
	g_ssd_cache.temp_c     = temp_dC   / 10.0f;
	g_ssd_cache.last_ok_ms = HAL_GetTick();
	g_ssd_cache.valid      = true;

	st_dbg_printf(
			"[SSD] I=%.3f A  V=%.3f V  T=%.1f C  P=%.1f W  ERR=0x%04lX\r\n",
			current_ma / 1000.0f, vbus_mv / 1000.0f, temp_dC / 10.0f,
			power_dW / 10.0f, (unsigned long) ((uint32_t) errors & 0xFFFFU));
}

/* Refresh g_ssd_cache silently (I, V, T only — no print). Used by stream mode. */
static bool st_ssd_cache_refresh(void) {
	if (!st_ssd_uart_apply_defaults())
		return false;
	int32_t current_ma = 0, vbus_mv = 0, temp_dC = 0;
	bool ok = st_ssd_query_i32(":1GA\r", 'A', &current_ma);
	HAL_Delay(20U);
	ok = ok && st_ssd_query_i32(":1GV\r", 'V', &vbus_mv);
	HAL_Delay(20U);
	ok = ok && st_ssd_query_i32(":1GT\r", 'T', &temp_dC);
	if (ok) {
		g_ssd_cache.current_a  = current_ma / 1000.0f;
		g_ssd_cache.voltage_v  = vbus_mv    / 1000.0f;
		g_ssd_cache.temp_c     = temp_dC   / 10.0f;
		g_ssd_cache.last_ok_ms = HAL_GetTick();
		g_ssd_cache.valid      = true;
	}
	return ok;
}

static void st_ssd_print_raw_cmd(const char *cmd_in) {
	char cmd[32];
	uint8_t raw[ST_SSD_RX_BUF_LEN];
	size_t n;

	if (cmd_in == NULL || cmd_in[0] == '\0') {
		st_dbg_printf("[SSD] raw requires command text, e.g. ssd raw :1VE\r\n");
		return;
	}

	if (strchr(cmd_in, '\r') || strchr(cmd_in, '\n')) {
		snprintf(cmd, sizeof(cmd), "%s", cmd_in);
	} else {
		snprintf(cmd, sizeof(cmd), "%s\r", cmd_in);
	}

	if (!st_ssd_send_cmd(cmd)) {
		st_dbg_printf("[SSD] TX failed\r\n");
		return;
	}

	/* Snapshot USART ISR immediately after TX — shows any error flags
	 * or whether RXNE already has data before read_capture starts. */
	uint32_t isr_snap = ST_RS485_UART.Instance->ISR;
	st_dbg_printf("[SSD] ISR=0x%08lX (TC=%lu RXNE=%lu ORE=%lu FE=%lu NE=%lu)\r\n",
			(unsigned long) isr_snap,
			(unsigned long) ((isr_snap >> 6) & 1U),
			(unsigned long) ((isr_snap >> 5) & 1U),
			(unsigned long) ((isr_snap >> 3) & 1U),
			(unsigned long) ((isr_snap >> 1) & 1U),
			(unsigned long) ((isr_snap >> 2) & 1U));

	n = st_ssd_read_capture(raw, sizeof(raw), ST_SSD_RAW_TIMEOUT_MS);
	st_dbg_printf("[SSD] TX=\"%s\" RX_LEN=%lu\r\n", cmd, (unsigned long) n);
	st_dbg_printf("[SSD] RX_HEX:");
	for (size_t i = 0U; i < n; ++i)
		st_dbg_printf(" %02X", raw[i]);
	st_dbg_printf("\r\n");
	st_dbg_printf("[SSD] RX_ASCII=\"");
	for (size_t i = 0U; i < n; ++i) {
		uint8_t ch = raw[i];
		if (ch == '\r')
			st_dbg_printf("<CR>");
		else if (ch == '\n')
			st_dbg_printf("<LF>");
		else if (isprint((unsigned char )ch))
			st_dbg_printf("%c", ch);
		else
			st_dbg_printf(".");
	}
	st_dbg_printf("\"\r\n");
}

static void st_ssd_discover_ascii(void) {
	static const uint32_t baud_list[ST_SSD_DISCOVER_BAUD_COUNT] = { 9600U,
			14400U, 19200U, 38400U, 57600U, 115200U };
	char cmd[16];
	char resp[ST_SSD_RX_BUF_LEN];
	bool found = false;

	st_dbg_printf("[SSD] ASCII discover start\r\n");

	for (size_t bi = 0U; bi < ST_SSD_DISCOVER_BAUD_COUNT; ++bi) {
		uint32_t baud = baud_list[bi];
		if (!st_ssd_uart_apply(baud, UART_STOPBITS_1)) {
			st_dbg_printf("[SSD] baud %lu init failed\r\n",
					(unsigned long) baud);
			continue;
		}

		for (uint32_t addr = 1U; addr <= ST_SSD_SCAN_ADDR_MAX; ++addr) {
			snprintf(cmd, sizeof(cmd), ":%luVE\r", (unsigned long) addr);
			if (st_ssd_query_text(cmd, resp, sizeof(resp))) {
				found = true;
				st_dbg_printf("[SSD] ASCII hit: baud=%lu addr=%lu VE=%s\r\n",
						(unsigned long) baud, (unsigned long) addr, resp);

				snprintf(cmd, sizeof(cmd), ":%luGM\r", (unsigned long) addr);
				if (st_ssd_query_text(cmd, resp, sizeof(resp)))
					st_dbg_printf("[SSD]   GM=%s\r\n", resp);

				snprintf(cmd, sizeof(cmd), ":%luGB\r", (unsigned long) addr);
				if (st_ssd_query_text(cmd, resp, sizeof(resp)))
					st_dbg_printf("[SSD]   GB=%s\r\n", resp);
			}
		}
	}

	if (!found)
		st_dbg_printf("[SSD] ASCII discover found nothing\r\n");

	(void) st_ssd_uart_apply_defaults();
}

static uint16_t st_modbus_crc16(const uint8_t *data, size_t len) {
	uint16_t crc = 0xFFFFU;
	for (size_t i = 0U; i < len; ++i) {
		crc ^= data[i];
		for (uint8_t b = 0U; b < 8U; ++b) {
			if (crc & 1U)
				crc = (uint16_t) ((crc >> 1) ^ 0xA001U);
			else
				crc >>= 1;
		}
	}
	return crc;
}

static bool st_ssd_modbus_probe_once(uint8_t addr, uint32_t baud,
		uint16_t *fw_reg, uint16_t *mode_reg, uint16_t *baud_reg) {
	uint8_t req[8];
	uint8_t rx[32];
	size_t n;
	uint16_t crc;

	if (!st_ssd_uart_apply(baud, UART_STOPBITS_2))
		return false;

	req[0] = addr;
	req[1] = 0x04U;
	req[2] = 0x00U;
	req[3] = 17U;
	req[4] = 0x00U;
	req[5] = 0x01U;
	crc = st_modbus_crc16(req, 6U);
	req[6] = (uint8_t) (crc & 0xFFU);
	req[7] = (uint8_t) (crc >> 8);

	st_ssd_flush_rx();
	st_rs485_de_set(true);
	HAL_Delay(2U);
	if (HAL_UART_Transmit(&ST_RS485_UART, req, sizeof(req),
			ST_SSD_UART_TIMEOUT_MS) != HAL_OK) {
		st_rs485_de_set(false);
		return false;
	}
	st_rs485_de_set(false);
	st_ssd_post_tx_cleanup();

	n = st_ssd_read_capture(rx, sizeof(rx), ST_SSD_RAW_TIMEOUT_MS);
	if (n < 7U)
		return false;
	if (rx[0] != addr || rx[1] != 0x04U || rx[2] != 0x02U)
		return false;
	crc = st_modbus_crc16(rx, n - 2U);
	if (rx[n - 2U] != (uint8_t) (crc & 0xFFU)
			|| rx[n - 1U] != (uint8_t) (crc >> 8))
		return false;
	if (fw_reg)
		*fw_reg = (uint16_t) (((uint16_t) rx[3] << 8) | rx[4]);

	req[0] = addr;
	req[1] = 0x03U;
	req[2] = 0x00U;
	req[3] = 2U;
	req[4] = 0x00U;
	req[5] = 0x01U;
	crc = st_modbus_crc16(req, 6U);
	req[6] = (uint8_t) (crc & 0xFFU);
	req[7] = (uint8_t) (crc >> 8);
	st_ssd_flush_rx();
	st_rs485_de_set(true);
	HAL_Delay(2U);
	if (HAL_UART_Transmit(&ST_RS485_UART, req, sizeof(req),
			ST_SSD_UART_TIMEOUT_MS) != HAL_OK) {
		st_rs485_de_set(false);
		return false;
	}
	st_rs485_de_set(false);
	st_ssd_post_tx_cleanup();
	n = st_ssd_read_capture(rx, sizeof(rx), ST_SSD_RAW_TIMEOUT_MS);
	if (n >= 7U && rx[0] == addr && rx[1] == 0x03U && rx[2] == 0x02U) {
		crc = st_modbus_crc16(rx, n - 2U);
		if (rx[n - 2U] == (uint8_t) (crc & 0xFFU)
				&& rx[n - 1U] == (uint8_t) (crc >> 8) && mode_reg)
			*mode_reg = (uint16_t) (((uint16_t) rx[3] << 8) | rx[4]);
	}

	req[0] = addr;
	req[1] = 0x03U;
	req[2] = 0x00U;
	req[3] = 4U;
	req[4] = 0x00U;
	req[5] = 0x01U;
	crc = st_modbus_crc16(req, 6U);
	req[6] = (uint8_t) (crc & 0xFFU);
	req[7] = (uint8_t) (crc >> 8);
	st_ssd_flush_rx();
	st_rs485_de_set(true);
	HAL_Delay(2U);
	if (HAL_UART_Transmit(&ST_RS485_UART, req, sizeof(req),
			ST_SSD_UART_TIMEOUT_MS) != HAL_OK) {
		st_rs485_de_set(false);
		return true;
	}
	st_rs485_de_set(false);
	st_ssd_post_tx_cleanup();
	n = st_ssd_read_capture(rx, sizeof(rx), ST_SSD_RAW_TIMEOUT_MS);
	if (n >= 7U && rx[0] == addr && rx[1] == 0x03U && rx[2] == 0x02U) {
		crc = st_modbus_crc16(rx, n - 2U);
		if (rx[n - 2U] == (uint8_t) (crc & 0xFFU)
				&& rx[n - 1U] == (uint8_t) (crc >> 8) && baud_reg)
			*baud_reg = (uint16_t) (((uint16_t) rx[3] << 8) | rx[4]);
	}

	return true;
}

static void st_ssd_modbus_probe(void) {
	static const uint32_t baud_list[ST_SSD_DISCOVER_BAUD_COUNT] = { 9600U,
			14400U, 19200U, 38400U, 57600U, 115200U };
	bool found = false;

	st_dbg_printf("[SSD] MODBUS probe start\r\n");

	for (size_t bi = 0U; bi < ST_SSD_DISCOVER_BAUD_COUNT; ++bi) {
		uint32_t baud = baud_list[bi];
		for (uint32_t addr = 1U; addr <= ST_SSD_SCAN_ADDR_MAX; ++addr) {
			uint16_t fw = 0U, mode = 0xFFFFU, br = 0xFFFFU;
			if (st_ssd_modbus_probe_once((uint8_t) addr, baud, &fw, &mode,
					&br)) {
				found = true;
				st_dbg_printf(
						"[SSD] MODBUS hit: baud=%lu addr=%lu FW=0x%04X MODE=0x%04X BAUD=%u\r\n",
						(unsigned long) baud, (unsigned long) addr, fw, mode,
						br);
			}
		}
	}

	if (!found)
		st_dbg_printf("[SSD] MODBUS probe found nothing\r\n");

	(void) st_ssd_uart_apply_defaults();
}

/* Passive bus monitor — listen without transmitting for up to timeout_ms.
 * Prints any bytes received in hex+ASCII. Useful to detect autosend data
 * or verify the receive path is alive. */
static void st_ssd_listen(uint32_t timeout_ms) {
	uint8_t buf[128];
	size_t n;

	if (!st_ssd_uart_apply_defaults()) {
		st_dbg_printf("[SSD] UART init failed\r\n");
		return;
	}

	st_dbg_printf("[SSD] listen %lums...\r\n", (unsigned long) timeout_ms);
	n = st_ssd_read_capture(buf, sizeof(buf), timeout_ms);
	if (n == 0U) {
		st_dbg_printf("[SSD] listen: no bytes (bus idle)\r\n");
		return;
	}
	st_dbg_printf("[SSD] listen RX_LEN=%lu\r\n", (unsigned long) n);
	st_dbg_printf("[SSD] HEX:");
	for (size_t i = 0U; i < n; ++i)
		st_dbg_printf(" %02X", buf[i]);
	st_dbg_printf("\r\n[SSD] ASCII=\"");
	for (size_t i = 0U; i < n; ++i) {
		uint8_t ch = buf[i];
		if (ch == '\r')      st_dbg_printf("<CR>");
		else if (ch == '\n') st_dbg_printf("<LF>");
		else if (isprint((unsigned char)ch)) st_dbg_printf("%c", ch);
		else st_dbg_printf(".");
	}
	st_dbg_printf("\"\r\n");
}

/* Send a single raw Modbus frame (FC 0x04, addr, input reg 17, qty 1)
 * and show ISR snapshot + raw RX. Mirrors what modbus-probe sends so
 * the user can see exactly what bytes come back (or don't). */
static void st_ssd_modraw(uint8_t addr) {
	uint8_t req[8];
	uint8_t rx[32];
	uint16_t crc;
	size_t n;

	if (!st_ssd_uart_apply(19200U, UART_STOPBITS_2)) {
		st_dbg_printf("[SSD] UART init failed\r\n");
		return;
	}

	req[0] = addr;
	req[1] = 0x04U;
	req[2] = 0x00U;
	req[3] = 17U;
	req[4] = 0x00U;
	req[5] = 0x01U;
	crc = st_modbus_crc16(req, 6U);
	req[6] = (uint8_t)(crc & 0xFFU);
	req[7] = (uint8_t)(crc >> 8);

	st_dbg_printf("[SSD] modraw TX[8]:");
	for (size_t i = 0U; i < 8U; ++i)
		st_dbg_printf(" %02X", req[i]);
	st_dbg_printf("\r\n");

	st_ssd_flush_rx();
	st_rs485_de_set(true);
	HAL_Delay(2U);
	if (HAL_UART_Transmit(&ST_RS485_UART, req, sizeof(req), ST_SSD_UART_TIMEOUT_MS) != HAL_OK) {
		st_rs485_de_set(false);
		st_dbg_printf("[SSD] modraw TX failed\r\n");
		(void) st_ssd_uart_apply_defaults();
		return;
	}
	st_rs485_de_set(false);

	uint32_t isr_snap = ST_RS485_UART.Instance->ISR;
	st_dbg_printf("[SSD] ISR=0x%08lX (TC=%lu RXNE=%lu ORE=%lu FE=%lu NE=%lu)\r\n",
			(unsigned long)isr_snap,
			(unsigned long)((isr_snap >> 6) & 1U),
			(unsigned long)((isr_snap >> 5) & 1U),
			(unsigned long)((isr_snap >> 3) & 1U),
			(unsigned long)((isr_snap >> 1) & 1U),
			(unsigned long)((isr_snap >> 2) & 1U));

	st_ssd_post_tx_cleanup();

	n = st_ssd_read_capture(rx, sizeof(rx), ST_SSD_RAW_TIMEOUT_MS);
	st_dbg_printf("[SSD] modraw RX_LEN=%lu\r\n", (unsigned long)n);
	st_dbg_printf("[SSD] HEX:");
	for (size_t i = 0U; i < n; ++i)
		st_dbg_printf(" %02X", rx[i]);
	st_dbg_printf("\r\n");
	if (n >= 7U) {
		crc = st_modbus_crc16(rx, n - 2U);
		bool crc_ok = (rx[n-2U] == (uint8_t)(crc & 0xFFU) && rx[n-1U] == (uint8_t)(crc >> 8));
		st_dbg_printf("[SSD] CRC %s, addr=%02X fc=%02X bc=%02X data=0x%04X\r\n",
				crc_ok ? "OK" : "FAIL",
				rx[0], rx[1], rx[2],
				(n >= 5U) ? (uint32_t)(((uint16_t)rx[3] << 8) | rx[4]) : 0xFFFFU);
	}

	(void) st_ssd_uart_apply_defaults();
}


static bool st_adc_write_reg(uint8_t reg, uint8_t value) {
	uint8_t tx[3] = { ST_TLA_OP_SINGLE_WRITE, reg, value };
	return HAL_I2C_Master_Transmit(&ST_I2C, ST_ADC_ADDR_8BIT, tx, sizeof(tx),
			ST_I2C_TIMEOUT_MS) == HAL_OK;
}

static bool st_adc_read_reg(uint8_t reg, uint8_t *value) {
	uint8_t tx[2] = { ST_TLA_OP_SINGLE_READ, reg };
	if (HAL_I2C_Master_Transmit(&ST_I2C, ST_ADC_ADDR_8BIT, tx, sizeof(tx),
			ST_I2C_TIMEOUT_MS) != HAL_OK)
		return false;
	return HAL_I2C_Master_Receive(&ST_I2C, ST_ADC_ADDR_8BIT, value, 1U,
			ST_I2C_TIMEOUT_MS) == HAL_OK;
}

static bool st_adc_ping(uint8_t *sys_status) {
	return st_adc_read_reg(ST_TLA_REG_SYSTEM_STATUS, sys_status);
}

static bool st_adc_init_analog_defaults(void) {
	if (!st_adc_write_reg(ST_TLA_REG_PIN_CFG, 0x00U))
		return false;
	if (!st_adc_write_reg(ST_TLA_REG_DATA_CFG, 0x00U))
		return false;
	if (!st_adc_write_reg(ST_TLA_REG_OSR_CFG, 0x00U))
		return false;
	if (!st_adc_write_reg(ST_TLA_REG_OPMODE_CFG, 0x00U))
		return false;
	return true;
}

static bool st_adc_read_channel12(uint8_t ch, uint16_t *raw12) {
	uint8_t rx[2] = { 0, 0 };
	if (ch > 7U)
		return false;
	if (!st_adc_write_reg(ST_TLA_REG_CHANNEL_SEL, ch & 0x0FU))
		return false;
	if (HAL_I2C_Master_Receive(&ST_I2C, ST_ADC_ADDR_8BIT, rx, sizeof(rx),
			ST_I2C_TIMEOUT_MS) != HAL_OK)
		return false;
	*raw12 = (uint16_t) (((uint16_t) rx[0] << 4) | ((uint16_t) rx[1] >> 4));
	return true;
}

static bool st_adc_read_all(st_adc_sample_t samples[8]) {
	if (!st_adc_init_analog_defaults())
		return false;
	for (uint8_t i = 0U; i < 8U; ++i) {
		if (!st_adc_read_channel12(i, &samples[i].raw12))
			return false;
		samples[i].vadc = st_raw_to_vadc(samples[i].raw12, 12U);
		samples[i].eng = g_adc_info[i].convert(samples[i].raw12, 12U);
		if ((i == 6U || i == 7U) && !isnan(samples[i].eng)) {
			samples[i].eng = st_therm_apply_cal(samples[i].eng);
		}
	}
	return true;
}

static void st_adc_print_raw(const st_adc_sample_t samples[8]) {
	st_dbg_printf("[ADC] raw12 / Vadc\r\n");
	for (uint8_t i = 0U; i < 8U; ++i) {
		st_dbg_printf("  CH%u %-10s raw=%4u  Vadc=%.4f\r\n", i,
				g_adc_info[i].name, samples[i].raw12, samples[i].vadc);
	}
}

static void st_adc_print_eng(const st_adc_sample_t samples[8]) {
	st_dbg_printf("[ADC] engineering values\r\n");
	for (uint8_t i = 0U; i < 8U; ++i) {
		st_dbg_printf("  CH%u %-10s = %.3f %s\r\n", i, g_adc_info[i].name,
				samples[i].eng, g_adc_info[i].unit);
	}
}

static st_status_t st_adc_sanity(const st_adc_sample_t samples[8], char *detail,
		size_t detail_len) {
	bool fail = false;
	bool warn = false;
	if (detail != NULL && detail_len > 0U)
		detail[0] = '\0';
	for (uint8_t i = 0U; i < 8U; ++i) {
		float v = samples[i].eng;
		if (isnan(v) || v < g_adc_info[i].fail_min
				|| v > g_adc_info[i].fail_max) {
			fail = true;
			if (detail != NULL && detail_len > 0U)
				snprintf(detail, detail_len, "%s out of fail range (%.3f %s)",
						g_adc_info[i].name, v, g_adc_info[i].unit);
			break;
		}
		if (v < g_adc_info[i].warn_min || v > g_adc_info[i].warn_max) {
			warn = true;
			if (detail != NULL && detail_len > 0U && detail[0] == '\0')
				snprintf(detail, detail_len, "%s out of warn range (%.3f %s)",
						g_adc_info[i].name, v, g_adc_info[i].unit);
		}
	}
	if (fail)
		return STS_FAIL;
	if (warn)
		return STS_WARN;
	if (detail != NULL && detail_len > 0U)
		snprintf(detail, detail_len, "all ADC channels sane");
	return STS_PASS;
}

/* ======================================================================
 *  Local (on-chip) ADC channels
 *  THERM_0  PA6  ADC2_IN3   10K/10K NTC divider
 *  THERM_1  PA7  ADC2_IN4   10K/10K NTC divider
 *  THERM_2  PC4  ADC2_IN5   10K/10K NTC divider
 *  V_SOURCE PB0  ADC1_IN15  200K/5.6K divider
 *  V_BUS    PB1  ADC1_IN12  200K/5.6K divider
 *  I_COIL   PB2  ADC2_IN12  10mΩ shunt, gain 50  (Vadc * 2.0 A)
 * ====================================================================== */

/* Voltage divider scale: (200K + 5.6K) / 5.6K */
#define ST_LADC_VDIV_SCALE   36.7142857f
/* I_COIL: shunt 10mΩ, amp gain 50 → Vout = I*0.01*50 = I/2 → I = Vadc*2 */
#define ST_LADC_ICOIL_SCALE   2.0f
#define ST_LADC_NCH           6U

typedef struct {
	const char        *name;
	const char        *unit;
	ADC_HandleTypeDef *hadc;
	uint32_t           channel;
	float            (*convert)(uint16_t raw, uint8_t bits);
	float              warn_min;
	float              warn_max;
	float              fail_min;
	float              fail_max;
} st_ladc_info_t;

static float st_ladc_conv_vdiv(uint16_t raw, uint8_t bits) {
	return st_raw_to_vadc(raw, bits) * ST_LADC_VDIV_SCALE;
}
static float st_ladc_conv_icoil(uint16_t raw, uint8_t bits) {
	return st_raw_to_vadc(raw, bits) * ST_LADC_ICOIL_SCALE;
}
/* Thermistors: same beta-model as external ADC, same cal offset */
static float st_ladc_conv_therm_local(uint16_t raw, uint8_t bits) {
	return st_therm_apply_cal(st_adc_conv_therm(raw, bits));
}

/* warn: 0.1–65 V (conservative — actual rail unknown)  fail: 0–80 V */
/* warn for I_COIL: –1–20 A,  fail: –5–30 A            (no-load expected near 0) */
static const st_ladc_info_t g_ladc_info[ST_LADC_NCH] = {
	{ "THERM_0",  "C", &hadc2, ADC_CHANNEL_3,  st_ladc_conv_therm_local,  0.0f,  60.0f, -20.0f,  90.0f },
	{ "THERM_1",  "C", &hadc2, ADC_CHANNEL_4,  st_ladc_conv_therm_local,  0.0f,  60.0f, -20.0f,  90.0f },
	{ "THERM_2",  "C", &hadc2, ADC_CHANNEL_5,  st_ladc_conv_therm_local,  0.0f,  60.0f, -20.0f,  90.0f },
	{ "V_SOURCE", "V", &hadc1, ADC_CHANNEL_15, st_ladc_conv_vdiv,          0.1f,  65.0f,   0.0f,  80.0f },
	{ "V_BUS",    "V", &hadc1, ADC_CHANNEL_12, st_ladc_conv_vdiv,          0.1f,  65.0f,   0.0f,  80.0f },
	{ "I_COIL",   "A", &hadc2, ADC_CHANNEL_12, st_ladc_conv_icoil,        -1.0f,  20.0f,  -5.0f,  30.0f },
};

/*
 * Read a single local ADC channel.
 * Calls HAL_ADC_Stop first to ensure ADSTART=0 — required on STM32G4 so that
 * HAL_ADC_ConfigChannel can safely modify DIFSEL (switching from the CubeMX
 * differential-channel-11 config to single-ended for each channel we want).
 * After the CubeMX differential config is fixed this is still harmless.
 */
static bool st_ladc_read_one(ADC_HandleTypeDef *hadc, uint32_t channel,
		uint16_t *raw12) {
	ADC_ChannelConfTypeDef cfg = { 0 };
	cfg.Channel      = channel;
	cfg.Rank         = ADC_REGULAR_RANK_1;
	cfg.SamplingTime = ADC_SAMPLETIME_92CYCLES_5;
	cfg.SingleDiff   = ADC_SINGLE_ENDED;
	cfg.OffsetNumber = ADC_OFFSET_NONE;
	cfg.Offset       = 0;
	(void) HAL_ADC_Stop(hadc);  /* clear ADSTART so ConfigChannel can write DIFSEL */
	if (HAL_ADC_ConfigChannel(hadc, &cfg) != HAL_OK) return false;
	if (HAL_ADC_Start(hadc) != HAL_OK) return false;
	if (HAL_ADC_PollForConversion(hadc, 10U) != HAL_OK) {
		(void) HAL_ADC_Stop(hadc);
		return false;
	}
	*raw12 = (uint16_t)(HAL_ADC_GetValue(hadc) & 0x0FFFU);
	(void) HAL_ADC_Stop(hadc);
	return true;
}

static bool st_ladc_read_all(st_adc_sample_t samples[ST_LADC_NCH]) {
	for (uint8_t i = 0U; i < ST_LADC_NCH; ++i) {
		if (!st_ladc_read_one(g_ladc_info[i].hadc, g_ladc_info[i].channel,
				&samples[i].raw12))
			return false;
		samples[i].vadc = st_raw_to_vadc(samples[i].raw12, 12U);
		samples[i].eng  = g_ladc_info[i].convert(samples[i].raw12, 12U);
	}
	return true;
}

static void st_ladc_print_raw(const st_adc_sample_t samples[ST_LADC_NCH]) {
	st_dbg_printf("[LADC] raw12 / Vadc\r\n");
	for (uint8_t i = 0U; i < ST_LADC_NCH; ++i) {
		st_dbg_printf("  CH%-2u %-9s raw=%4u  Vadc=%.4f\r\n",
				(unsigned) i, g_ladc_info[i].name,
				samples[i].raw12, samples[i].vadc);
	}
}

static void st_ladc_print_eng(const st_adc_sample_t samples[ST_LADC_NCH]) {
	st_dbg_printf("[LADC] engineering values\r\n");
	for (uint8_t i = 0U; i < ST_LADC_NCH; ++i) {
		if (isnan(samples[i].eng))
			st_dbg_printf("  CH%-2u %-9s = NaN %s\r\n",
					(unsigned) i, g_ladc_info[i].name, g_ladc_info[i].unit);
		else
			st_dbg_printf("  CH%-2u %-9s = %.3f %s\r\n",
					(unsigned) i, g_ladc_info[i].name,
					samples[i].eng, g_ladc_info[i].unit);
	}
}

