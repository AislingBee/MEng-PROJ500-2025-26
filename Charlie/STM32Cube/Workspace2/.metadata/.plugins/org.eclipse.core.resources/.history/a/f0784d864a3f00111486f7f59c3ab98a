		test_mcan_poll, STS_NOT_RUN, "" }, };
#define ST_NUM_TESTS ((int)(sizeof(g_tests) / sizeof(g_tests[0])))
static uint32_t g_campaign_pass[ST_NUM_TESTS];
static uint32_t g_campaign_fail[ST_NUM_TESTS];
static uint32_t g_campaign_warn[ST_NUM_TESTS];
static uint32_t g_campaign_skip[ST_NUM_TESTS];

static void st_reset_all_tests(void) {
	for (int i = 0; i < ST_NUM_TESTS; ++i) {
		g_tests[i].status = STS_NOT_RUN;
		g_tests[i].detail[0] = '\0';
		if (g_tests[i].reset)
			g_tests[i].reset();
	}
}

static int st_test_index_from_name(const char *name) {
	for (int i = 0; i < ST_NUM_TESTS; ++i)
		if (strcmp(name, g_tests[i].name) == 0)
			return i;
	return -1;
}

static void st_start_test_index(int idx) {
	if (idx < 0 || idx >= ST_NUM_TESTS)
		return;
	g_rt.current_test = idx;
	g_tests[idx].status = STS_RUNNING;
	g_tests[idx].detail[0] = '\0';
	if (g_tests[idx].start)
		g_tests[idx].start();
	st_dbg_printf("[RUN] %s\r\n", g_tests[idx].name);
}

static int st_next_enabled_test_after(int idx) {
	for (int i = idx + 1; i < ST_NUM_TESTS; ++i)
		if ((g_rt.current_mask & g_tests[i].mask) != 0U)
			return i;
	return -1;
}

static void st_abort(bool announce) {
	st_safe_outputs();
	st_restore_runtime_outputs();
	g_rt.mode = RUN_IDLE;
	g_rt.current_test = -1;
	g_rt.current_mask = 0U;
	g_rt.campaign_active = false;
	g_rt.loop_enabled = false;
	g_rt.loop_target_count = 0U;
	if (announce)
		st_dbg_printf("[RUN] stopped\r\n");
}

static void st_start_all(void) {
	st_reset_all_tests();
	g_rt.mode = RUN_ALL;
	g_rt.current_mask = g_rt.enabled_mask;
	g_rt.current_test = -1;
	g_rt.run_fail_count = 0U;
	g_rt.run_warn_count = 0U;
	for (int i = 0; i < ST_NUM_TESTS; ++i) {
		if ((g_tests[i].mask & g_rt.enabled_mask) != 0U) {
			g_rt.current_test = i;
			g_tests[i].status = STS_RUNNING;
			if (g_tests[i].start)
				g_tests[i].start();
			if (!g_rt.loop_fast)
				st_dbg_printf("[RUN] %s\r\n", g_tests[i].name);
			return;
		} else {
			g_tests[i].status = STS_SKIPPED;
		}
	}
	g_rt.mode = RUN_IDLE;
}

static void st_start_one(uint32_t mask) {
	st_reset_all_tests();
	g_rt.mode = RUN_ONE;
	g_rt.current_mask = mask;
	g_rt.current_test = -1;
	g_rt.run_fail_count = 0U;
	g_rt.run_warn_count = 0U;
	for (int i = 0; i < ST_NUM_TESTS; ++i) {
		if ((g_tests[i].mask & mask) != 0U) {
			g_rt.current_test = i;
			g_tests[i].status = STS_RUNNING;
			g_tests[i].detail[0] = '\0';
			if (g_tests[i].start)
				g_tests[i].start();
			st_dbg_printf("[RUN] %s\r\n", g_tests[i].name);
			return;
		}
	}
	g_rt.mode = RUN_IDLE;
}

/* Board-provided externs for shared MCAN layer (Group B) */
uint8_t st_mcan_get_summary_code(void) {
    bool any_fail = false, any_warn = false;
    for (int i = 0; i < ST_NUM_TESTS; ++i) {
        if (g_tests[i].status == STS_FAIL) any_fail = true;
        else if (g_tests[i].status == STS_WARN) any_warn = true;
    }
    return any_fail ? 2U : (any_warn ? 1U : 0U);
}

uint16_t st_mcan_get_status_word(void) {
	uint16_t w = 0U;
	if (HAL_GPIO_ReadPin(FAULT_LATCH_GPIO_Port, FAULT_LATCH_Pin) == GPIO_PIN_SET) w |= MCAN_PDU_SW_FAULT_LATCH;
	if (HAL_GPIO_ReadPin(SW_FAULT_GPIO_Port,    SW_FAULT_Pin)    == GPIO_PIN_SET) w |= MCAN_PDU_SW_FAULT_BTN;
	if (HAL_GPIO_ReadPin(PGOOD_SW_GPIO_Port,    PGOOD_SW_Pin)    == GPIO_PIN_SET) w |= MCAN_PDU_SW_PGOOD_SW;
	if (HAL_GPIO_ReadPin(PGOOD_24V_GPIO_Port,   PGOOD_24V_Pin)   == GPIO_PIN_SET) w |= MCAN_PDU_SW_PGOOD_24V;
	if (g_fpga_cache.valid) {
		w |= (uint16_t)((g_fpga_cache.state_code & 0x3U) << MCAN_PDU_SW_FPGA_STATE_SHIFT);
		if (g_fpga_cache.fault_latch)  w |= MCAN_PDU_SW_FPGA_FLTL;
		if (g_fpga_cache.arm_permit)   w |= MCAN_PDU_SW_ARM_PERMIT;
		if (g_fpga_cache.estop_ok)     w |= MCAN_PDU_SW_ESTOP_OK;
	}
	return w;
}

uint32_t st_mcan_local_mask_from_selector(uint16_t selector) {
    switch (selector) {
        case ST_MCAN_SEL_ALL:    return ST_TEST_ALL;
        case ST_MCAN_SEL_GPIO:   return ST_TEST_GPIO;
        case ST_MCAN_SEL_BUZZER: return ST_TEST_BUZZER;
        case ST_MCAN_SEL_MCAN:   return ST_TEST_MCAN;
        case ST_MCAN_SEL_CAN:    return ST_TEST_CAN;
        case ST_MCAN_SEL_SSD:    return ST_TEST_SSD;
        case ST_MCAN_SEL_FPGA:   return ST_TEST_FPGA;
        case ST_MCAN_SEL_ADC:    return ST_TEST_ADC;
        default: return 0U;
    }
}

