}

/* ======================================================================
 *  Stream / telemetry mode
 * ====================================================================== */
static void st_stream_poll(uint32_t now_ms) {
	if (!g_stream_on)
		return;

	/* Low-rate SSD background refresh (every STREAM_SSD_INTERVAL_MS) */
	if ((int32_t)(now_ms - g_stream_ssd_next_ms) >= 0) {
		st_ssd_cache_refresh();  /* silent — populates g_ssd_cache */
		g_stream_ssd_next_ms = now_ms + STREAM_SSD_INTERVAL_MS;
	}

	/* Telemetry line */
	if ((int32_t)(now_ms - g_stream_next_ms) < 0)
		return;
	g_stream_next_ms = now_ms + g_stream_interval_ms;

	/* Refresh FPGA cache (background also does this, but grab latest) */
	st_fpga_poll();

	/* ADC — use internal STM32 ADC for local rails */
	st_adc_sample_t s[8];
	bool adc_ok = st_adc_read_all(s);
	float vsrc = adc_ok ? s[0].eng : NAN;
	float vbus = adc_ok ? s[3].eng : NAN;
	float icoil = adc_ok ? s[1].eng : NAN;
	float t0 = adc_ok ? st_therm_apply_cal(st_adc_conv_therm(s[6].raw12, 12U)) : NAN;
	float t1 = adc_ok ? st_therm_apply_cal(st_adc_conv_therm(s[7].raw12, 12U)) : NAN;

	/* FPGA state string */
	const char *fpga_state = g_fpga_cache.valid
		? (g_fpga_cache.fault_latch ? "FAULT" : k_fpga_state_names[g_fpga_cache.state_code & 3U])
		: "NA";
	uint8_t fpga_flt  = g_fpga_cache.valid ? g_fpga_cache.fault_code : 0U;
	uint8_t fpga_arm  = g_fpga_cache.valid ? (g_fpga_cache.mcu_cmd_arm_seen ? 1U : 0U) : 0U;
	uint8_t fpga_est  = g_fpga_cache.valid ? (g_fpga_cache.estop_ok ? 1U : 0U) : 0U;

	/* GPIO inputs */
	uint8_t pg_sw  = HAL_GPIO_ReadPin(PGOOD_SW_GPIO_Port, PGOOD_SW_Pin) == GPIO_PIN_SET ? 1U : 0U;
	uint8_t pg_24v = HAL_GPIO_ReadPin(PGOOD_24V_GPIO_Port, PGOOD_24V_Pin) == GPIO_PIN_SET ? 1U : 0U;
	uint8_t flt    = HAL_GPIO_ReadPin(FAULT_LATCH_GPIO_Port, FAULT_LATCH_Pin) == GPIO_PIN_SET ? 1U : 0U;

	/* MCAN HB status */
	const char *mcan_hb = g_mcan.peer_online ? "OK" : "LOST";
	uint32_t rtt = g_mcan.rtt_last_ms;

	/* AUX switch states */
	uint8_t a1 = st_aux_sw_get(1U) ? 1U : 0U;
	uint8_t a2 = st_aux_sw_get(2U) ? 1U : 0U;
	uint8_t a3 = st_aux_sw_get(3U) ? 1U : 0U;

	st_dbg_printf("[STR] t=%lu FPGA=%s/%u arm=%u estop=%u"
		" | Vsrc=%.2f Vbus=%.2f Icoil=%.2f T0=%.1f T1=%.1f"
		" | IN PG_SW=%u PG24=%u FL=%u",
		(unsigned long)now_ms,
		fpga_state, fpga_flt, fpga_arm, fpga_est,
		vsrc, vbus, icoil, t0, t1,
		pg_sw, pg_24v, flt);

	if (g_ssd_cache.valid) {
		st_dbg_printf(" | SSD I=%.1fA V=%.1fV T=%.1fC",
			g_ssd_cache.current_a, g_ssd_cache.voltage_v, g_ssd_cache.temp_c);
	} else {
		st_dbg_printf(" | SSD=NA");
	}

	st_dbg_printf(" | MCAN hb=%s rtt=%lums | AUX %u %u %u\r\n",
		mcan_hb, (unsigned long)rtt, a1, a2, a3);
}


static void st_monitor_poll(uint32_t now_ms) {
	if (!g_rt.monitor_adc && !g_rt.monitor_inputs && !g_rt.monitor_ssd
			&& !g_rt.monitor_adc_local && !g_rt.monitor_fpga)
		return;
	if ((now_ms - g_rt.last_monitor_ms) < g_rt.monitor_interval_ms)
		return;
	g_rt.last_monitor_ms = now_ms;
	if (g_rt.monitor_adc)
		st_adc_monitor_print();
	if (g_rt.monitor_inputs)
		st_inputs_monitor_print();
	if (g_rt.monitor_ssd)
		st_ssd_print_readings();
	if (g_rt.monitor_adc_local)
		st_ladc_monitor_print();
	if (g_rt.monitor_fpga)
		st_fpga_monitor_print();
}

