static void test_can_reset(void) {
}
static void test_can_start(void) {
}
static st_status_t test_can_poll(uint32_t now_ms, char *detail,
		size_t detail_len) {
	(void) now_ms;
	(void) detail;
	(void) detail_len;
	HAL_StatusTypeDef st;
	bool mcan_was_online = g_mcan.online;
	if (mcan_was_online) st_mcan_bus_disable(&g_mcan);
	uint32_t old_mode = ST_FDCAN.Init.Mode;
	uint8_t tx[8] = { 0x50, 0x44, 0x55, 0x5F, 0x43, 0x41, 0x4E, 0x31 };
	uint8_t rx[8] = { 0 };
	FDCAN_FilterTypeDef filter = { 0 };
	FDCAN_TxHeaderTypeDef txh = { 0 };
	FDCAN_RxHeaderTypeDef rxh = { 0 };

	st_can_standby_set(true);
	HAL_FDCAN_Stop(&ST_FDCAN);
	ST_FDCAN.Init.Mode = FDCAN_MODE_INTERNAL_LOOPBACK;
	if (HAL_FDCAN_Init(&ST_FDCAN) != HAL_OK)
		goto fail;

	filter.IdType = FDCAN_STANDARD_ID;
	filter.FilterIndex = 0;
	filter.FilterType = FDCAN_FILTER_MASK;
	filter.FilterConfig = FDCAN_FILTER_TO_RXFIFO0;
	filter.FilterID1 = 0;
	filter.FilterID2 = 0;
	if (HAL_FDCAN_ConfigFilter(&ST_FDCAN, &filter) != HAL_OK)
		goto fail;
	if (HAL_FDCAN_ConfigGlobalFilter(&ST_FDCAN, FDCAN_REJECT, FDCAN_REJECT,
			FDCAN_FILTER_REMOTE, FDCAN_FILTER_REMOTE) != HAL_OK)
		goto fail;
	if (HAL_FDCAN_Start(&ST_FDCAN) != HAL_OK)
		goto fail;

	txh.Identifier = 0x123;
	txh.IdType = FDCAN_STANDARD_ID;
	txh.TxFrameType = FDCAN_DATA_FRAME;
	txh.DataLength = FDCAN_DLC_BYTES_8;
	txh.ErrorStateIndicator = FDCAN_ESI_ACTIVE;
	txh.BitRateSwitch = FDCAN_BRS_OFF;
	txh.FDFormat = FDCAN_CLASSIC_CAN;
	txh.TxEventFifoControl = FDCAN_NO_TX_EVENTS;
	txh.MessageMarker = 0;
	if (HAL_FDCAN_AddMessageToTxFifoQ(&ST_FDCAN, &txh, tx) != HAL_OK)
		goto fail;

	{
		uint32_t t0 = HAL_GetTick();
		while (HAL_FDCAN_GetRxFifoFillLevel(&ST_FDCAN, FDCAN_RX_FIFO0) == 0U) {
			if ((HAL_GetTick() - t0) > 100U)
				goto fail;
		}
	}

	st = HAL_FDCAN_GetRxMessage(&ST_FDCAN, FDCAN_RX_FIFO0, &rxh, rx);
	HAL_FDCAN_Stop(&ST_FDCAN);
	ST_FDCAN.Init.Mode = old_mode;
	(void) HAL_FDCAN_Init(&ST_FDCAN);
	if (mcan_was_online) (void)st_mcan_bus_config(&g_mcan, true);
	if (st != HAL_OK)
		return STS_FAIL;
	if (rxh.Identifier != 0x123U || memcmp(tx, rx, 8U) != 0)
		return STS_FAIL;
	return STS_PASS;

	fail: HAL_FDCAN_Stop(&ST_FDCAN);
	ST_FDCAN.Init.Mode = old_mode;
	(void) HAL_FDCAN_Init(&ST_FDCAN);
	if (mcan_was_online) (void)st_mcan_bus_config(&g_mcan, true);
	return STS_FAIL;
}

static void test_ssd_reset(void) {
}
static void test_ssd_start(void) {
}
static st_status_t test_ssd_poll(uint32_t now_ms, char *detail,
		size_t detail_len) {
	(void) now_ms;
	int32_t current_ma = 0;
	int32_t vbus_mv = 0;
	int32_t temp_dC = 0;
	int32_t power_dW = 0;
	int32_t errors = 0;
	char fw[ST_SSD_RX_BUF_LEN] = { 0 };

	if (!st_ssd_uart_apply_defaults()) {
		if (detail && detail_len)
			snprintf(detail, detail_len, "UART3 reinit to 19200 8N1 failed");
		return STS_FAIL;
	}
	if (!st_ssd_query_text(":1VE\r", fw, sizeof(fw))) {
		if (detail && detail_len)
			snprintf(detail, detail_len, "SSD no response to :1VE");
		return STS_FAIL;
	}
	if (!st_ssd_query_i32(":1GA\r", 'A', &current_ma)
			|| !st_ssd_query_i32(":1GV\r", 'V', &vbus_mv)
			|| !st_ssd_query_i32(":1GT\r", 'T', &temp_dC)
			|| !st_ssd_query_i32(":1GP\r", 'P', &power_dW)
			|| !st_ssd_query_i32(":1G!\r", '!', &errors)) {
		if (detail && detail_len)
			snprintf(detail, detail_len, "SSD read failed after FW=%s", fw);
		return STS_FAIL;
	}

	if (detail && detail_len) {
		snprintf(detail, detail_len,
				"FW=%s I=%.3fA V=%.3fV T=%.1fC P=%.1fW E=0x%04lX", fw,
				current_ma / 1000.0f, vbus_mv / 1000.0f, temp_dC / 10.0f,
				power_dW / 10.0f,
				(unsigned long) ((uint32_t) errors & 0xFFFFU));
	}

	if (errors != 0)
		return STS_WARN;
	return STS_PASS;
}

static void test_fpga_reset(void) {
	memset(&g_fpga_test, 0, sizeof(g_fpga_test));
}
static void test_fpga_start(void) {
	test_fpga_reset();
	g_fpga_test.next_ms = HAL_GetTick();
}
static st_status_t test_fpga_poll(uint32_t now_ms, char *detail,
		size_t detail_len) {
	if (now_ms < g_fpga_test.next_ms)
		return STS_RUNNING;

	switch (g_fpga_test.phase) {
	case 0: {
		/* Phase 0: version check */
		uint8_t ver = 0U;
		if (!st_fpga_read_regs(ST_FPGA_REG_VERSION, &ver, 1U)) {
			if (detail) snprintf(detail, detail_len, "I2C read failed (ver)");
			return STS_FAIL;
		}
		if (ver != ST_FPGA_VERSION_EXPECT) {
			if (detail) snprintf(detail, detail_len, "ver=0x%02X expected 0x%02X", ver, ST_FPGA_VERSION_EXPECT);
			return STS_FAIL;
		}
		g_fpga_test.next_ms = now_ms + 5U;
		break;
	}
	case 1: {
		/* Phase 1: MCU_CMD_ARM_SEEN must be set (CMD_ARM is high at runtime) */
		if (!st_fpga_poll()) {
			if (detail) snprintf(detail, detail_len, "I2C read failed (regs)");
			return STS_FAIL;
		}
		if (!g_fpga_cache.mcu_cmd_arm_seen) {
			if (detail) snprintf(detail, detail_len,
				"FPGA v0x%02X: MCU_CMD_ARM not seen (INPUTS=0x%02X)",
				g_fpga_cache.version, g_fpga_cache.inputs);
			return STS_FAIL;
		}
		g_fpga_test.next_ms = now_ms + 4U;
		break;
	}
	case 2: {
		/* Phase 2: heartbeat — FPGA_SPARE_OUT_0 (500 Hz) must toggle over 3 ms */
		GPIO_PinState s1 = HAL_GPIO_ReadPin(FPGA_SPARE_OUT_0_GPIO_Port, FPGA_SPARE_OUT_0_Pin);
		HAL_Delay(3U);
		GPIO_PinState s2 = HAL_GPIO_ReadPin(FPGA_SPARE_OUT_0_GPIO_Port, FPGA_SPARE_OUT_0_Pin);
		if (s1 == s2) {
			/* One coincidence is possible; warn but allow pass */
			g_fpga_test.phase++;  /* try phase 3 = repeat sample */
			g_fpga_test.next_ms = now_ms + 3U;
			return STS_RUNNING;
		}
		g_fpga_test.next_ms = now_ms + 2U;
		break;
	}
	case 3: {
		/* Phase 3: second heartbeat attempt if phase 2 didn't toggle */
		GPIO_PinState s1 = HAL_GPIO_ReadPin(FPGA_SPARE_OUT_0_GPIO_Port, FPGA_SPARE_OUT_0_Pin);
		HAL_Delay(3U);
		GPIO_PinState s2 = HAL_GPIO_ReadPin(FPGA_SPARE_OUT_0_GPIO_Port, FPGA_SPARE_OUT_0_Pin);
		if (s1 == s2) {
			/* Both tries static — WARN (sampling coincidence less likely twice) */
			if (detail) snprintf(detail, detail_len,
				"FPGA v0x%02X state=%s arm=%u estop=%u hb=WARN",
				g_fpga_cache.version,
				g_fpga_cache.fault_latch ? "FAULT" : k_fpga_state_names[g_fpga_cache.state_code & 3U],
				g_fpga_cache.mcu_cmd_arm_seen ? 1U : 0U,
				g_fpga_cache.estop_ok ? 1U : 0U);
			return STS_WARN;
		}
		g_fpga_test.next_ms = now_ms + 2U;
		break;
	}
	case 4:
	default: {
		/* Phase 4: sanity — WARN if fault latched or OVUV mismatch */
		const char *state_str = g_fpga_cache.fault_latch
			? "FAULT" : k_fpga_state_names[g_fpga_cache.state_code & 3U];
		bool warn = false;
		if (g_fpga_cache.fault_latch) {
			warn = true;
			if (detail) snprintf(detail, detail_len,
				"FPGA v0x%02X state=FAULT flt_code=%u (%s)",
				g_fpga_cache.version,
				g_fpga_cache.fault_code,
				(g_fpga_cache.fault_code < 8U)
					? g_fpga_fault_names[g_fpga_cache.fault_code] : "?");
		} else if (!g_fpga_cache.ovuv_ok
				&& HAL_GPIO_ReadPin(PGOOD_SW_GPIO_Port, PGOOD_SW_Pin) == GPIO_PIN_SET
				&& HAL_GPIO_ReadPin(PGOOD_24V_GPIO_Port, PGOOD_24V_Pin) == GPIO_PIN_SET) {
			warn = true;
			if (detail) snprintf(detail, detail_len,
				"FPGA v0x%02X state=%s OVUV_OK=0 but PGOOD_SW+24V=1",
				g_fpga_cache.version, state_str);
		}
		if (!warn && detail) {
			snprintf(detail, detail_len,
				"FPGA v0x%02X state=%s arm=%u estop=%u hb=OK",
				g_fpga_cache.version, state_str,
				g_fpga_cache.mcu_cmd_arm_seen ? 1U : 0U,
				g_fpga_cache.estop_ok ? 1U : 0U);
		}
		return warn ? STS_WARN : STS_PASS;
	}
	}
	g_fpga_test.phase++;
	return STS_RUNNING;
}

/* ======================================================================
 *  FPGA I2C register interface
 *  Slave address 0x55 (7-bit) on I2C4 (ST_I2C).  Read-only register map.
 *  Other device on bus: TLA2528 at 0x17 — left undisturbed.
 * ====================================================================== */

/* Write register pointer then read len bytes (auto-increment). */
static bool st_fpga_read_regs(uint8_t start, uint8_t *buf, uint8_t len) {
	return HAL_I2C_Mem_Read(&ST_I2C, ST_FPGA_ADDR_8BIT,
			start, I2C_MEMADD_SIZE_8BIT,
			buf, len, ST_FPGA_I2C_TMO) == HAL_OK;
}

/* Update g_fpga_cache from I2C — silent, no print. Returns true on success. */
static bool st_fpga_poll(void) {
	uint8_t r[ST_FPGA_REGS_BLOCK_LEN];
	uint8_t ver = 0U;
	uint32_t now = HAL_GetTick();

	if (!st_fpga_read_regs(ST_FPGA_REG_STATUS0, r, ST_FPGA_REGS_BLOCK_LEN))
		return false;
	if (!st_fpga_read_regs(ST_FPGA_REG_VERSION, &ver, 1U))
		return false;

	g_fpga_cache.valid          = true;
	g_fpga_cache.last_read_ms   = now;
	g_fpga_cache.status0        = r[ST_FPGA_REG_STATUS0];
	g_fpga_cache.fault_code     = r[ST_FPGA_REG_FAULT] & 0x0FU;
	g_fpga_cache.state_code     = r[ST_FPGA_REG_STATE] & 0x03U;
	g_fpga_cache.actions        = r[ST_FPGA_REG_ACTIONS];
	g_fpga_cache.inputs         = r[ST_FPGA_REG_INPUTS];
	g_fpga_cache.pchg_timer_ms  = ((uint16_t)r[ST_FPGA_REG_PCHG_HI] << 8)
	                             | (uint16_t)r[ST_FPGA_REG_PCHG_LO];
	g_fpga_cache.version        = ver;

	/* Decoded convenience flags (from STATUS0) */
	g_fpga_cache.fault_latch      = (r[ST_FPGA_REG_STATUS0] & 0x80U) != 0U;
	g_fpga_cache.precharge_latch  = (r[ST_FPGA_REG_STATUS0] & 0x40U) != 0U;
	g_fpga_cache.motor_en         = (r[ST_FPGA_REG_STATUS0] & 0x20U) != 0U;
	g_fpga_cache.compute_en       = (r[ST_FPGA_REG_STATUS0] & 0x10U) != 0U;
	g_fpga_cache.ovuv_ok          = (r[ST_FPGA_REG_STATUS0] & 0x02U) != 0U;
	g_fpga_cache.arm_permit       = (r[ST_FPGA_REG_STATUS0] & 0x01U) != 0U;
	/* Decoded convenience flags (from INPUTS) */
	g_fpga_cache.estop_ok         = (r[ST_FPGA_REG_INPUTS] & 0x20U) != 0U;
	g_fpga_cache.mcu_cmd_arm_seen = (r[ST_FPGA_REG_INPUTS] & 0x10U) != 0U;
	g_fpga_cache.remote_arm_latch = (r[ST_FPGA_REG_INPUTS] & 0x40U) != 0U;
	return true;
}


/* Print space-separated names of set bits.  names[0]=bit7 … names[7]=bit0. */
static bool st_fpga_print_bits(uint8_t val, const char *const names[8]) {
	bool any = false;
	for (uint8_t b = 0U; b < 8U; ++b) {
		if ((val & (0x80U >> b)) && names[b] != NULL) {
			st_dbg_printf("%s%s", any ? " " : "", names[b]);
			any = true;
		}
	}
	return any;
}

static const char *st_fpga_state_str(uint8_t state_reg, uint8_t status0) {
	switch (state_reg & 0x03U) {
	case 0U: return (status0 & 0x80U) ? "FAULT" : "IDLE";
	case 1U: return "PRECHARGE";
	case 2U: return "ARMED";
	case 3U: return "COMPUTE";
	default:  return "?";
	}
}

static void st_fpga_cmd_regs(void) {
	uint8_t r[ST_FPGA_REGS_BLOCK_LEN];
	if (!st_fpga_read_regs(ST_FPGA_REG_STATUS0, r, ST_FPGA_REGS_BLOCK_LEN)) {
		st_dbg_printf("[FPGA] I2C read failed\r\n");
		return;
	}
	uint8_t fault_code = r[ST_FPGA_REG_FAULT] & 0x0FU;
	uint16_t pchg_ms = ((uint16_t)r[ST_FPGA_REG_PCHG_HI] << 8)
	                 | (uint16_t)r[ST_FPGA_REG_PCHG_LO];
	st_dbg_printf("[FPGA] regs\r\n");
	st_dbg_printf("  STATUS0   : 0x%02X  ", r[ST_FPGA_REG_STATUS0]);
	if (!st_fpga_print_bits(r[ST_FPGA_REG_STATUS0], g_fpga_s0_names))
		st_dbg_printf("(none)");
	st_dbg_printf("\r\n");
	st_dbg_printf("  FAULT     : 0x%02X  %s\r\n", r[ST_FPGA_REG_FAULT],
			(fault_code < 8U) ? g_fpga_fault_names[fault_code] : "?");
	st_dbg_printf("  STATE     : 0x%02X  %s\r\n", r[ST_FPGA_REG_STATE],
			st_fpga_state_str(r[ST_FPGA_REG_STATE], r[ST_FPGA_REG_STATUS0]));
	st_dbg_printf("  ACTIONS   : 0x%02X  ", r[ST_FPGA_REG_ACTIONS]);
	if (!st_fpga_print_bits(r[ST_FPGA_REG_ACTIONS], g_fpga_act_names))
		st_dbg_printf("(none)");
	st_dbg_printf("\r\n");
	st_dbg_printf("  INPUTS    : 0x%02X  ", r[ST_FPGA_REG_INPUTS]);
	if (!st_fpga_print_bits(r[ST_FPGA_REG_INPUTS], g_fpga_in_names))
		st_dbg_printf("(none)");
	st_dbg_printf("\r\n");
	st_dbg_printf("  PCHG_TMR  : %u ms\r\n", (unsigned)pchg_ms);
}

static void st_fpga_cmd_state(void) {
	uint8_t r[3];
	if (!st_fpga_read_regs(ST_FPGA_REG_STATUS0, r, 3U)) {
		st_dbg_printf("[FPGA] I2C read failed\r\n");
		return;
	}
	st_dbg_printf("[FPGA] state=%s  FAULT_LATCH=%u\r\n",
			st_fpga_state_str(r[ST_FPGA_REG_STATE], r[ST_FPGA_REG_STATUS0]),
			(r[ST_FPGA_REG_STATUS0] & 0x80U) ? 1U : 0U);
}

static void st_fpga_cmd_fault(void) {
	uint8_t r[2];
	if (!st_fpga_read_regs(ST_FPGA_REG_STATUS0, r, 2U)) {
		st_dbg_printf("[FPGA] I2C read failed\r\n");
		return;
	}
	uint8_t code = r[ST_FPGA_REG_FAULT] & 0x0FU;
	st_dbg_printf("[FPGA] FAULT_LATCH=%u  fault_code=%u (%s)\r\n",
			(r[ST_FPGA_REG_STATUS0] & 0x80U) ? 1U : 0U,
			(unsigned)code,
			(code < 8U) ? g_fpga_fault_names[code] : "?");
}

static void st_fpga_cmd_inputs(void) {
	uint8_t val = 0U;
	if (!st_fpga_read_regs(ST_FPGA_REG_INPUTS, &val, 1U)) {
		st_dbg_printf("[FPGA] I2C read failed\r\n");
		return;
	}
	st_dbg_printf("[FPGA] INPUTS 0x%02X  ", val);
	if (!st_fpga_print_bits(val, g_fpga_in_names))
		st_dbg_printf("(none)");
	st_dbg_printf("\r\n");
}

static void st_fpga_cmd_timers(void) {
	uint8_t r[2];
	if (!st_fpga_read_regs(ST_FPGA_REG_PCHG_HI, r, 2U)) {
		st_dbg_printf("[FPGA] I2C read failed\r\n");
		return;
	}
	uint16_t pchg_ms = ((uint16_t)r[0] << 8) | (uint16_t)r[1];
	st_dbg_printf("[FPGA] pchg_timer=%u ms\r\n", (unsigned)pchg_ms);
}

static void st_fpga_cmd_ver(void) {
	uint8_t val = 0U;
	if (!st_fpga_read_regs(ST_FPGA_REG_VERSION, &val, 1U)) {
		st_dbg_printf("[FPGA] I2C read failed\r\n");
		return;
	}
	st_dbg_printf("[FPGA] ver=0x%02X  %s\r\n", val,
			(val == ST_FPGA_VERSION_EXPECT) ? "OK" : "FAIL (expected 0xB2)");
}

static void st_fpga_cmd_status(void) {
	bool cmd_arm   = HAL_GPIO_ReadPin(CMD_ARM_GPIO_Port,             CMD_ARM_Pin)             == GPIO_PIN_SET;
	bool cmd_fault = HAL_GPIO_ReadPin(CMD_FAULT_GPIO_Port,           CMD_FAULT_Pin)           == GPIO_PIN_SET;
	bool fl        = HAL_GPIO_ReadPin(FAULT_LATCH_GPIO_Port,         FAULT_LATCH_Pin)         == GPIO_PIN_SET;
	bool sp0       = HAL_GPIO_ReadPin(FPGA_SPARE_OUT_0_GPIO_Port,    FPGA_SPARE_OUT_0_Pin)    == GPIO_PIN_SET;
	bool sp1       = HAL_GPIO_ReadPin(FPGA_SPARE_OUT_1_GPIO_Port,    FPGA_SPARE_OUT_1_Pin)    == GPIO_PIN_SET;
	st_dbg_printf("[FPGA] CMD_ARM=%u CMD_FAULT=%u  FAULT_LATCH=%u SPARE0=%u SPARE1=%u\r\n",
			cmd_arm, cmd_fault, fl, sp0, sp1);
}

static void st_fpga_scenario_arm(void) {
	st_dbg_printf("[FPGA] scenario arm — current state:\r\n");
	st_fpga_cmd_state();
	st_cmd_arm_set(true);
	st_dbg_printf("[FPGA] CMD_ARM asserted, waiting 100 ms\r\n");
	HAL_Delay(100U);
	st_fpga_cmd_regs();
}

static void st_fpga_scenario_fault(void) {
	st_dbg_printf("[FPGA] scenario fault — asserting CMD_FAULT for 50 ms\r\n");
	st_cmd_fault_set(true);
	HAL_Delay(50U);
	st_cmd_fault_set(false);
	st_dbg_printf("[FPGA] CMD_FAULT released\r\n");
	HAL_Delay(10U);
	st_fpga_cmd_fault();
}

static void test_adc_reset(void) {
}
static void test_adc_start(void) {
}
static st_status_t test_adc_poll(uint32_t now_ms, char *detail,
		size_t detail_len) {
	(void) now_ms;
	uint8_t sys = 0U;
	st_adc_sample_t samples[8];
	if (!st_adc_ping(&sys)) {
		if (detail && detail_len)
			snprintf(detail, detail_len, "TLA2528 no ACK at 0x17");
		return STS_FAIL;
	}
	if (!st_adc_read_all(samples)) {
		if (detail && detail_len)
			snprintf(detail, detail_len, "ADC channel read failed");
		return STS_FAIL;
	}
	st_dbg_printf("[ADC] SYSTEM_STATUS=0x%02X\r\n", sys);
	st_adc_print_eng(samples);
	if (detail && detail_len) {
		snprintf(detail, detail_len, "VRAW=%.2fV IVRAW=%.2fA 12V=%.2fV 24V=%.2fV I12=%.2fA I24=%.2fA T1=%.1fC T2=%.1fC",
				samples[0].eng, samples[1].eng, samples[2].eng, samples[3].eng,
				samples[4].eng, samples[5].eng, samples[6].eng, samples[7].eng);
	}
	return st_adc_sanity(samples, detail, detail_len);
}

static void test_mcan_reset(void) { memset(&g_mcan_test, 0, sizeof(g_mcan_test)); }
static void test_mcan_start(void) {
    memset(&g_mcan_test, 0, sizeof(g_mcan_test));
    st_mcan_stop_ping(&g_mcan);
}
static st_status_t test_mcan_poll(uint32_t now_ms, char *detail, size_t detail_len)
{
    switch (g_mcan_test.phase) {
        case 0: /* bus warmup — ensure local bus is online */
            if (!g_mcan.online) (void)st_mcan_bus_config(&g_mcan, true);
            if (!g_mcan.online) {
                snprintf(detail, detail_len, "bus config failed");
                return STS_FAIL;
            }
            g_mcan_test.phase = 1;
            return STS_RUNNING;
        case 1:
            g_mcan_test.base_ping_resp = g_mcan.ping_resp;
            g_mcan_test.base_ping_timeout = g_mcan.ping_timeout;
            st_mcan_start_ping(&g_mcan,1U, 100U, false, false);
            g_mcan_test.deadline_ms = now_ms + 1000U;
            g_mcan_test.phase = 2;
            return STS_RUNNING;
        case 2:
            if (g_mcan.ping_resp > g_mcan_test.base_ping_resp) {
                g_mcan_test.base_status_resp = g_mcan.status_resp_rx;
                g_mcan_test.status_seq = ++g_mcan.next_seq;
                if (!st_mcan_send_simple(&g_mcan,ST_MCAN_TYPE_STATUS_REQ, g_mcan_test.status_seq, 0U, 0U, 0U)) {
                    snprintf(detail, detail_len, "status req send failed");
                    return STS_FAIL;
                }
                g_mcan.tx_req++;
                g_mcan_test.deadline_ms = now_ms + 1000U;
                g_mcan_test.phase = 3;
                return STS_RUNNING;
            }
            if (g_mcan.ping_timeout > g_mcan_test.base_ping_timeout || (int32_t)(now_ms - g_mcan_test.deadline_ms) >= 0) {
                snprintf(detail, detail_len, "ping timeout");
                return STS_FAIL;
            }
            return STS_RUNNING;
        case 3:
            if (g_mcan.status_resp_rx > g_mcan_test.base_status_resp && g_mcan.last_status_seq == g_mcan_test.status_seq) {
                g_mcan_test.base_ack_rx = g_mcan.ack_rx;
                g_mcan_test.ack_seq = ++g_mcan.next_seq;
                if (!st_mcan_send_simple(&g_mcan,ST_MCAN_TYPE_LED_REQ, g_mcan_test.ack_seq, 0U, 1U, 50U)) {
                    snprintf(detail, detail_len, "led req send failed");
                    return STS_FAIL;
                }
                g_mcan.tx_req++;
                g_mcan_test.deadline_ms = now_ms + 1000U;
                g_mcan_test.phase = 4;
                return STS_RUNNING;
            }
            if ((int32_t)(now_ms - g_mcan_test.deadline_ms) >= 0) {
                snprintf(detail, detail_len, "status timeout");
                return STS_FAIL;
            }
            return STS_RUNNING;
        case 4:
            if (g_mcan.ack_rx > g_mcan_test.base_ack_rx &&
                g_mcan.last_ack_seq == g_mcan_test.ack_seq &&
                g_mcan.last_ack_type == ST_MCAN_TYPE_LED_REQ) {
                snprintf(detail, detail_len, "ping/status/ack OK sw=0x%04X", g_mcan.last_status_word);
                return STS_PASS;
            }
            if ((int32_t)(now_ms - g_mcan_test.deadline_ms) >= 0) {
                snprintf(detail, detail_len, "ack timeout");
                return STS_FAIL;
            }
            return STS_RUNNING;
        default:
            return STS_FAIL;
    }
}

