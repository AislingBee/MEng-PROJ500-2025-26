static float st_raw_to_vadc(uint16_t raw, uint8_t bits) {
	return (bits == 16U) ?
			((float) raw * 3.3f / 65536.0f) : ((float) raw * 3.3f / 4096.0f);
}
static float st_adc_conv_x14(uint16_t raw, uint8_t bits) {
	return st_raw_to_vadc(raw, bits) * 14.0f;
}
static float st_adc_conv_x4(uint16_t raw, uint8_t bits) {
	return st_raw_to_vadc(raw, bits) * 4.0f;
}
static float st_adc_conv_x7p8(uint16_t raw, uint8_t bits) {
	return st_raw_to_vadc(raw, bits) * 7.8f;
}
static float st_adc_conv_x31(uint16_t raw, uint8_t bits) {
	return st_raw_to_vadc(raw, bits) * 31.0f;
}
static float st_adc_conv_x9p47(uint16_t raw, uint8_t bits) {
	return st_raw_to_vadc(raw, bits) * 9.47f;
}
static float st_adc_conv_therm(uint16_t raw, uint8_t bits) {
	float v = st_raw_to_vadc(raw, bits);
	if (v <= 0.0f || v >= 3.299f) {
		return NAN;
	}
	return (1.0f / ((1.0f / 298.15f) + (1.0f / 3435.0f) * logf(v / (3.3f - v))))
			- 273.15f;
}

