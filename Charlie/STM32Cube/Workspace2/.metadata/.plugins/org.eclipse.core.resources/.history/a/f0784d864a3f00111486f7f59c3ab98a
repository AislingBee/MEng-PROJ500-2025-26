static void st_fpga_monitor_print(void) {
	uint8_t r[ST_FPGA_REGS_BLOCK_LEN];
	if (!st_fpga_read_regs(ST_FPGA_REG_STATUS0, r, ST_FPGA_REGS_BLOCK_LEN)) {
		st_dbg_printf("[FPGA] I2C read failed\r\n");
		return;
	}
	uint8_t code = r[ST_FPGA_REG_FAULT] & 0x0FU;
	uint16_t pchg = ((uint16_t)r[ST_FPGA_REG_PCHG_HI] << 8)
	              | (uint16_t)r[ST_FPGA_REG_PCHG_LO];
	st_dbg_printf(
			"[FPGA] state=%s FAULT_LATCH=%u fault=%s ARM_PERMIT=%u ESTOP_OK=%u MCU_CMD_ARM=%u pchg=%u ms\r\n",
			st_fpga_state_str(r[ST_FPGA_REG_STATE], r[ST_FPGA_REG_STATUS0]),
			(r[ST_FPGA_REG_STATUS0] & 0x80U) ? 1U : 0U,
			(code < 8U) ? g_fpga_fault_names[code] : "?",
			(r[ST_FPGA_REG_STATUS0] & 0x01U) ? 1U : 0U,
			(r[ST_FPGA_REG_INPUTS]  & 0x20U) ? 1U : 0U,
			(r[ST_FPGA_REG_INPUTS]  & 0x10U) ? 1U : 0U,
			(unsigned)pchg);
}

