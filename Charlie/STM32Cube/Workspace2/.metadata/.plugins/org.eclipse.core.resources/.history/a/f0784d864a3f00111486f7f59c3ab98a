static float st_therm_apply_cal(float t_raw_c) {
	if (isnan(t_raw_c))
		return t_raw_c;
	return t_raw_c + g_rt.therm_offset_c;
}

static void st_therm_print_detail(void) {
	st_adc_sample_t s[8];
	if (!st_adc_read_all(s)) {
		st_dbg_printf("[THERM] adc read failed\r\n");
		return;
	}
	float t1_raw = st_adc_conv_therm(s[6].raw12, 12U);
	float t2_raw = st_adc_conv_therm(s[7].raw12, 12U);
	float t1 = st_therm_apply_cal(t1_raw);
	float t2 = st_therm_apply_cal(t2_raw);
	st_dbg_printf("[THERM] CH6 raw=%u V=%.4f Traw=%.2fC T=%.2fC  CH7 raw=%u V=%.4f Traw=%.2fC T=%.2fC offs=%.2fC\r\n",
			s[6].raw12, s[6].vadc, t1_raw, t1, s[7].raw12, s[7].vadc, t2_raw, t2,
			g_rt.therm_offset_c);
}

