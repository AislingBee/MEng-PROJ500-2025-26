static st_status_t test_gpio_poll(uint32_t now_ms, char *detail,
		size_t detail_len) {
	(void) detail;
	(void) detail_len;
	if (now_ms < g_gpio_test.next_ms)
		return STS_RUNNING;
	if (g_gpio_test.toggles >= 8U) {
		st_led_all_off();
