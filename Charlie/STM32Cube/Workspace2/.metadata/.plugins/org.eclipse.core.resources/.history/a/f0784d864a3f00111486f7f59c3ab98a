			g_stream_on = true;
			if (argc >= 3)
				g_stream_interval_ms = (uint32_t)strtoul(argv[2], NULL, 10);
			uint32_t now = HAL_GetTick();
			g_stream_next_ms     = now;
			g_stream_ssd_next_ms = now;  /* fire SSD refresh immediately */
			st_dbg_printf("[STR] on interval=%lums\r\n", (unsigned long)g_stream_interval_ms);
		} else if (strcmp(argv[1], "off") == 0) {
			g_stream_on = false;
			st_dbg_printf("[STR] off\r\n");
		} else {
			st_dbg_printf("usage: stream on|off [ms]\r\n");
		}
	} else if (strcmp(argv[0], "aux") == 0) {
		if (argc >= 3 && (argv[1][0] >= '1' && argv[1][0] <= '3') && argv[1][1] == '\0') {
			uint8_t n = (uint8_t)(argv[1][0] - '0');
			if (strcmp(argv[2], "on") == 0) {
				st_aux_sw_set(n, true);
				st_dbg_printf("[AUX] %u on\r\n", n);
			} else if (strcmp(argv[2], "off") == 0) {
				st_aux_sw_set(n, false);
				st_dbg_printf("[AUX] %u off\r\n", n);
			} else if (strcmp(argv[2], "toggle") == 0) {
				bool cur = st_aux_sw_get(n);
				st_aux_sw_set(n, !cur);
				st_dbg_printf("[AUX] %u %s\r\n", n, !cur ? "on" : "off");
			} else {
				st_dbg_printf("usage: aux 1|2|3 on|off|toggle\r\n");
			}
		} else if (argc >= 3 && strcmp(argv[1], "all") == 0) {
			bool v = (strcmp(argv[2], "on") == 0);
			st_aux_sw_set(1U, v);
			st_aux_sw_set(2U, v);
			st_aux_sw_set(3U, v);
			st_dbg_printf("[AUX] all %s\r\n", v ? "on" : "off");
		} else if (argc >= 2 && strcmp(argv[1], "status") == 0) {
			st_dbg_printf("[AUX] 1=%u 2=%u 3=%u\r\n",
				st_aux_sw_get(1U) ? 1U : 0U,
				st_aux_sw_get(2U) ? 1U : 0U,
				st_aux_sw_get(3U) ? 1U : 0U);
		} else {
			st_dbg_printf("usage: aux 1|2|3 on|off|toggle | aux all on|off | aux status\r\n");
		}
	} else {
		st_dbg_printf("unknown command\r\n");
	}
	st_prompt();
}

static void st_handle_uart_rx(void) {
	while (__HAL_UART_GET_FLAG(&ST_DBG_UART, UART_FLAG_RXNE) != RESET) {
		uint8_t ch = (uint8_t) (ST_DBG_UART.Instance->RDR & 0xFFU);
		if (ch == '\r' || ch == '\n') {
			st_dbg_printf("\r\n");
			g_cli_buf[g_cli_len] = '\0';
			st_process_line((char*) g_cli_buf);
			g_cli_len = 0U;
		} else if (ch == 0x08U || ch == 0x7FU) {
			if (g_cli_len > 0U) {
				g_cli_len--;
				st_dbg_printf("\b \b");
			}
		} else if (isprint((unsigned char )ch)
				&& g_cli_len < (ST_CLI_BUF_LEN - 1U)) {
			g_cli_buf[g_cli_len++] = ch;
			(void) HAL_UART_Transmit(&ST_DBG_UART, &ch, 1U, 10U);
		}
	}
}

void PDU_SelfTest_Init(void) {
	st_reset_all_tests();
	st_safe_outputs();
	st_restore_runtime_outputs();
	st_dbg_printf("\r\n==================================================\r\n");
	st_dbg_printf("PDU SELFTEST %s\r\n", ST_VERSION);
	st_dbg_printf("UART CLI ready on UART4 @ 115200\r\n");
	st_dbg_printf("Call this init after MX_* peripheral init.\r\n");
	st_mcan_init(&g_mcan);
	if (st_mcan_bus_config(&g_mcan, true) == HAL_OK)
		st_dbg_printf("[MCAN] bus auto-enabled\r\n");
	st_dbg_printf("Type 'help'\r\n");
	st_prompt();
}

void PDU_SelfTest_Task(void) {
	uint32_t now_ms = HAL_GetTick();
	st_handle_uart_rx();
	st_runner_poll(now_ms);
	st_monitor_poll(now_ms);
	st_stream_poll(now_ms);
	st_mcan_poll(&g_mcan, now_ms);
	/* Background FPGA cache refresh (keeps MCAN status word live) */
	if ((int32_t)(now_ms - g_fpga_bg_next_ms) >= 0) {
		st_fpga_poll();
		g_fpga_bg_next_ms = now_ms + FPGA_BG_INTERVAL_MS;
	}
}
