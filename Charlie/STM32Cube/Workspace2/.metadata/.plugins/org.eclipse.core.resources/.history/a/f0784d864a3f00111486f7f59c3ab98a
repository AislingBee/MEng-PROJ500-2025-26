static void st_handle_set(const char *what, const char *val) {
	bool on = (strcmp(val, "1") == 0 || st_str_eq_nocase(val, "on"));
	if (strcmp(what, "led0") == 0)
		st_led_set(0U, on);
	else if (strcmp(what, "led1") == 0)
		st_led_set(1U, on);
	else if (strcmp(what, "cmd_arm") == 0)
		st_cmd_arm_set(on);
	else if (strcmp(what, "cmd_fault") == 0)
		st_cmd_fault_set(on);
	else if (strcmp(what, "can_stb") == 0)
		st_can_standby_set(on);
	else if (strcmp(what, "rs485_de") == 0)
		st_rs485_de_set(on);
	else if (strcmp(what, "aux1") == 0)
		st_aux_sw_set(1U, on);
	else if (strcmp(what, "aux2") == 0)
		st_aux_sw_set(2U, on);
	else if (strcmp(what, "aux3") == 0)
		st_aux_sw_set(3U, on);
	else {
		st_dbg_printf("unknown set target\r\n");
		return;
	}
	st_dbg_printf("[SET] %s=%u\r\n", what, on ? 1U : 0U);
}

static void st_process_line(char *line) {
	char *argv[8] = { 0 };
	int argc = 0;
	while (*line != '\0' && argc < 8) {
		while (isspace((unsigned char )*line))
			++line;
		if (*line == '\0')
			break;
		argv[argc++] = line;
		while (*line != '\0' && !isspace((unsigned char )*line))
			++line;
		if (*line == '\0')
			break;
		*line++ = '\0';
	}
	if (argc == 0) {
		st_prompt();
		return;
	}

	if (strcmp(argv[0], "help") == 0) {
		st_print_help();
	} else if (strcmp(argv[0], "list") == 0) {
		st_print_tests();
	} else if (strcmp(argv[0], "status") == 0) {
		st_print_status();
	} else if (strcmp(argv[0], "summary") == 0) {
		st_print_summary();
	} else if (strcmp(argv[0], "clear") == 0) {
		st_reset_all_tests();
		memset(g_campaign_pass, 0, sizeof(g_campaign_pass));
		memset(g_campaign_fail, 0, sizeof(g_campaign_fail));
		memset(g_campaign_warn, 0, sizeof(g_campaign_warn));
		memset(g_campaign_skip, 0, sizeof(g_campaign_skip));
		g_rt.loop_completed_count = 0U;
		g_rt.run_fail_count = 0U;
		g_rt.run_warn_count = 0U;
		st_dbg_printf("[CLR] statuses cleared\r\n");
	} else if (strcmp(argv[0], "stop") == 0) {
		st_abort(true);
	} else if (strcmp(argv[0], "run") == 0 && argc >= 2) {
		bool fast = false;
		bool both = false;
		for (int i = 2; i < argc; ++i) {
			if (st_str_eq_nocase(argv[i], "fast"))
				fast = true;
			else if (st_str_eq_nocase(argv[i], "both"))
				both = true;
		}
		g_rt.loop_fast = fast;
		if (strcmp(argv[1], "all") == 0) {
			g_rt.campaign_active = false;
			st_start_all();
		} else {
			int idx = st_test_index_from_name(argv[1]);
			if (idx < 0)
				st_dbg_printf("unknown test\r\n");
