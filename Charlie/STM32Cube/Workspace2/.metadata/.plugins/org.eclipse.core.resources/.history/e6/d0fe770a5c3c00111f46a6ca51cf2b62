/*
 * st_mcan.c
 *
 * Shared management-CAN protocol layer for PDU/RCU self-test framework.
 * See st_mcan.h for board integration requirements.
 */

#include "st_mcan.h"
#include <string.h>

/* ======================================================================
 *  Init / stats
 * ====================================================================== */

void st_mcan_init(st_mcan_rt_t *m)
{
    memset(m, 0, sizeof(*m));
    m->hb_period_ms  = ST_MCAN_DEFAULT_HB_MS;
    m->ping_period_ms = ST_MCAN_DEFAULT_PING_MS;
    m->rtt_min_ms    = 0xFFFFFFFFUL;
}

void st_mcan_clear_stats(st_mcan_rt_t *m)
{
    bool mon  = m->monitor;
    bool hb   = m->hb_enabled;
    uint32_t hbms = m->hb_period_ms;
    bool on   = m->online;

    memset(m, 0, sizeof(*m));

    m->monitor       = mon;
    m->hb_enabled    = hb;
    m->hb_period_ms  = hbms ? hbms : ST_MCAN_DEFAULT_HB_MS;
    m->online        = on;
    m->ping_period_ms = ST_MCAN_DEFAULT_PING_MS;
    m->rtt_min_ms    = 0xFFFFFFFFUL;
}

/* ======================================================================
 *  Bus control
 * ====================================================================== */

bool st_mcan_bus_config(st_mcan_rt_t *m, bool enable)
{
    FDCAN_HandleTypeDef *hfdcan = st_mcan_get_fdcan();

    HAL_FDCAN_Stop(hfdcan);
    HAL_FDCAN_DeInit(hfdcan);

    if (hfdcan->Init.StdFiltersNbr < 1U)          hfdcan->Init.StdFiltersNbr = 1U;
    if (hfdcan->Init.RxFifo0ElmtsNbr < 1U)        hfdcan->Init.RxFifo0ElmtsNbr = 1U;
    if (hfdcan->Init.TxFifoQueueElmtsNbr < 1U)    hfdcan->Init.TxFifoQueueElmtsNbr = 1U;
    hfdcan->Init.FrameFormat        = FDCAN_FRAME_CLASSIC;
    hfdcan->Init.Mode               = FDCAN_MODE_NORMAL;
    hfdcan->Init.AutoRetransmission = DISABLE;
    hfdcan->Init.TransmitPause      = DISABLE;
    hfdcan->Init.ProtocolException  = DISABLE;
    hfdcan->Init.RxFifo0ElmtSize    = FDCAN_DATA_BYTES_8;
    hfdcan->Init.TxElmtSize         = FDCAN_DATA_BYTES_8;
    hfdcan->Init.TxFifoQueueMode    = FDCAN_TX_FIFO_OPERATION;

    if (HAL_FDCAN_Init(hfdcan) != HAL_OK) {
        m->online = false;
        return false;
    }

    FDCAN_FilterTypeDef filter = {0};
    filter.IdType       = FDCAN_STANDARD_ID;
    filter.FilterIndex  = 0;
    filter.FilterType   = FDCAN_FILTER_MASK;
    filter.FilterConfig = FDCAN_FILTER_TO_RXFIFO0;
    filter.FilterID1    = 0U;
    filter.FilterID2    = 0U;

    if (HAL_FDCAN_ConfigFilter(hfdcan, &filter) != HAL_OK) {
        m->online = false;
        return false;
    }
    if (HAL_FDCAN_ConfigGlobalFilter(hfdcan, FDCAN_REJECT, FDCAN_REJECT,
                                      FDCAN_FILTER_REMOTE, FDCAN_FILTER_REMOTE) != HAL_OK) {
        m->online = false;
        return false;
    }
    if (HAL_FDCAN_Start(hfdcan) != HAL_OK) {
        m->online = false;
        return false;
    }

    st_mcan_transceiver_set(enable);
    m->online = enable;
    return true;
}

void st_mcan_bus_disable(st_mcan_rt_t *m)
{
    FDCAN_HandleTypeDef *hfdcan = st_mcan_get_fdcan();
    HAL_FDCAN_Stop(hfdcan);
    st_mcan_transceiver_set(false);
    m->online = false;
}

/* ======================================================================
 *  Frame TX
 * ====================================================================== */

bool st_mcan_send_frame(st_mcan_rt_t *m, uint32_t id, const uint8_t payload[8])
{
    if (!m->online) {
        if (!st_mcan_bus_config(m, true))
            return false;
    }

    FDCAN_HandleTypeDef *hfdcan = st_mcan_get_fdcan();
    FDCAN_TxHeaderTypeDef txh = {0};
    txh.Identifier          = id;
    txh.IdType              = FDCAN_STANDARD_ID;
    txh.TxFrameType         = FDCAN_DATA_FRAME;
    txh.DataLength          = FDCAN_DLC_BYTES_8;
    txh.ErrorStateIndicator = FDCAN_ESI_ACTIVE;
    txh.BitRateSwitch       = FDCAN_BRS_OFF;
    txh.FDFormat            = FDCAN_CLASSIC_CAN;
    txh.TxEventFifoControl  = FDCAN_NO_TX_EVENTS;
    txh.MessageMarker       = 0U;

    if (HAL_FDCAN_AddMessageToTxFifoQ(hfdcan, &txh, (uint8_t *)payload) != HAL_OK)
        return false;

    m->tx_frames++;
    return true;
}

bool st_mcan_send_simple(st_mcan_rt_t *m, uint8_t type, uint8_t seq,
                          uint8_t flags, uint16_t arg0, uint16_t arg1)
{
    uint8_t p[8];
    p[0] = ST_MCAN_PROTO_VER;
    p[1] = type;
    p[2] = seq;
    p[3] = flags;
    p[4] = (uint8_t)(arg0 & 0xFFU);
    p[5] = (uint8_t)((arg0 >> 8) & 0xFFU);
    p[6] = (uint8_t)(arg1 & 0xFFU);
    p[7] = (uint8_t)((arg1 >> 8) & 0xFFU);
    return st_mcan_send_frame(m, ST_MCAN_MY_MSG_ID, p);
}

/* ======================================================================
 *  Heartbeat
 * ====================================================================== */

bool st_mcan_send_heartbeat(st_mcan_rt_t *m)
{
    uint8_t p[8];
    uint16_t up = (uint16_t)((HAL_GetTick() / 1000U) & 0xFFFFU);
    uint16_t sw = st_mcan_get_status_word();

    p[0] = ST_MCAN_PROTO_VER;
    p[1] = st_mcan_get_summary_code();
    p[2] = m->next_seq++;
    p[3] = 0U;
    p[4] = (uint8_t)(up & 0xFFU);
    p[5] = (uint8_t)((up >> 8) & 0xFFU);
    p[6] = (uint8_t)(sw & 0xFFU);
    p[7] = (uint8_t)((sw >> 8) & 0xFFU);

    if (!st_mcan_send_frame(m, ST_MCAN_MY_HB_ID, p))
        return false;

    m->tx_hb++;
    return true;
}

/* ======================================================================
 *  Status response
 * ====================================================================== */

bool st_mcan_send_status_resp(st_mcan_rt_t *m, uint8_t seq)
{
    uint8_t p[8];
    uint16_t up = (uint16_t)((HAL_GetTick() / 1000U) & 0xFFFFU);
    uint16_t sw = st_mcan_get_status_word();

    p[0] = ST_MCAN_PROTO_VER;
    p[1] = ST_MCAN_TYPE_STATUS_RESP;
    p[2] = seq;
    p[3] = st_mcan_get_summary_code();
    p[4] = (uint8_t)(up & 0xFFU);
    p[5] = (uint8_t)((up >> 8) & 0xFFU);
    p[6] = (uint8_t)(sw & 0xFFU);
    p[7] = (uint8_t)((sw >> 8) & 0xFFU);

    return st_mcan_send_frame(m, ST_MCAN_MY_MSG_ID, p);
}

/* ======================================================================
 *  Ping
 * ====================================================================== */

void st_mcan_start_ping(st_mcan_rt_t *m, uint32_t count, uint32_t period_ms,
                          bool both, bool report_each)
{
    if (period_ms == 0U) period_ms = ST_MCAN_DEFAULT_PING_MS;
    m->ping_active         = true;
    m->ping_both           = both;
    m->ping_report_each    = report_each;
    m->ping_period_ms      = period_ms;
    m->ping_target_count   = count;
    m->ping_completed_count = 0U;
    m->ping_waiting        = false;
    m->ping_last_due_ms    = 0U;
    if (!m->online) (void)st_mcan_bus_config(m, true);
}

void st_mcan_stop_ping(st_mcan_rt_t *m)
{
    m->ping_active  = false;
    m->ping_both    = false;
    m->ping_waiting = false;
}

/* ======================================================================
 *  Remote self-test
 * ====================================================================== */

bool st_mcan_send_selftest_req(st_mcan_rt_t *m, uint16_t selector, uint16_t flags)
{
    uint8_t seq = ++m->next_seq;
    if (st_mcan_send_simple(m, ST_MCAN_TYPE_SELFTEST_REQ, seq, 0U, selector, flags)) {
        m->tx_req++;
        st_dbg_printf("[MCAN] selftest req seq=%u sel=%s flags=0x%04X\r\n",
                      seq, st_mcan_selector_name(selector), flags);
        return true;
    }
    st_dbg_printf("[MCAN] selftest req failed\r\n");
    return false;
}

bool st_mcan_send_selftest_result(st_mcan_rt_t *m, uint8_t req_seq,
                                    uint16_t selector, st_status_t status)
{
    if (st_mcan_send_simple(m, ST_MCAN_TYPE_SELFTEST_RESULT, req_seq, 0U,
                             selector, (uint16_t)status)) {
        m->tx_resp++;
        return true;
    }
    return false;
}

bool st_mcan_send_selftest_done(st_mcan_rt_t *m, uint8_t req_seq,
                                  uint16_t fail_count, uint16_t warn_count)
{
    if (st_mcan_send_simple(m, ST_MCAN_TYPE_SELFTEST_DONE, req_seq, 0U,
                             fail_count, warn_count)) {
        m->tx_resp++;
        return true;
    }
    return false;
}

void st_mcan_start_remote_selftest(st_mcan_rt_t *m, uint8_t req_seq,
                                     uint16_t selector, uint16_t flags)
{
    uint32_t mask = st_mcan_local_mask_from_selector(selector);
    bool fast = (flags & 0x0001U) != 0U;

    if (mask == 0U) {
        (void)st_mcan_send_selftest_result(m, req_seq, selector, STS_SKIPPED);
        (void)st_mcan_send_selftest_done(m, req_seq, 0U, 0U);
        return;
    }

    m->remote_selftest_active    = true;
    m->remote_selftest_req_seq   = req_seq;
    m->remote_selftest_root_selector = selector;

    st_mcan_on_start_remote_selftest(mask, fast);
}

/* ======================================================================
 *  Action handler (LED blink / beep from remote request)
 * ====================================================================== */

static void st_mcan_handle_action(st_mcan_rt_t *m, uint32_t now_ms)
{
    if (m->action_type == ST_MCAN_ACT_NONE) return;
    if ((int32_t)(now_ms - m->action_next_ms) < 0) return;

    if (m->action_type == ST_MCAN_ACT_LED) {
        /* Board callback for LED — use the extern helpers */
        m->action_state = !m->action_state;
        /* LED set is board-specific but we keep it simple: the board's
         * on_start_remote_selftest and action callbacks use st_led_set
         * which is board-local.  We call through st_dbg_printf-style
         * indirection here by just managing the state and letting the
         * board's poll loop handle it... but actually both boards already
         * used identical LED action logic, so we inline it here via the
         * transceiver_set pattern won't work for LEDs.
         *
         * Resolution: we provide a second board extern for LED/buzzer
         * actions.  But to minimize the callback surface, we keep the
         * action state machine here and provide two more board externs.
         */
        st_mcan_action_led_set(m->action_state);
        if (!m->action_state) {
            if (m->action_remaining > 0U) m->action_remaining--;
            if (m->action_remaining == 0U) {
                m->action_type = ST_MCAN_ACT_NONE;
                st_mcan_action_led_set(false);
                return;
            }
        }
        m->action_next_ms = now_ms + m->action_arg1;
    } else if (m->action_type == ST_MCAN_ACT_BEEP) {
        if (!m->action_state) {
            st_mcan_action_buzzer_set(m->action_arg0);
            m->action_state = true;
            m->action_next_ms = now_ms + m->action_arg1;
        } else {
            st_mcan_action_buzzer_set(0U);
            m->action_type  = ST_MCAN_ACT_NONE;
            m->action_state = false;
        }
    }
}

/* ======================================================================
 *  RX frame dispatch
 * ====================================================================== */

static void st_mcan_handle_rx_frame(st_mcan_rt_t *m, uint32_t id,
                                      const uint8_t *d, uint32_t len,
                                      uint32_t now_ms)
{
    m->rx_frames++;
    m->last_peer_seen_ms = now_ms;

    if (!m->peer_online) {
        m->peer_online = true;
        if (m->monitor) st_dbg_printf("[MCAN] peer online\r\n");
    }

    /* Peer heartbeat */
    if (id == ST_MCAN_PEER_HB_ID) {
        m->rx_hb++;
        if (m->monitor && len >= 8U) {
            uint16_t up = (uint16_t)d[4] | ((uint16_t)d[5] << 8);
            uint16_t sw = (uint16_t)d[6] | ((uint16_t)d[7] << 8);
            st_dbg_printf("[MCAN] HB RX sum=%u up=%u sw=0x%04X\r\n", d[1], up, sw);
        }
        return;
    }

    /* Only process frames from peer's message ID */
    if (id != ST_MCAN_PEER_MSG_ID) return;
    if (len < 8U) { m->bad_dlc++; return; }
    if (d[0] != ST_MCAN_PROTO_VER) { m->bad_ver++; return; }

    uint8_t  type  = d[1];
    uint8_t  seq   = d[2];
    /* uint8_t  flags = d[3]; -- reserved */
    uint16_t arg0  = (uint16_t)d[4] | ((uint16_t)d[5] << 8);
    uint16_t arg1  = (uint16_t)d[6] | ((uint16_t)d[7] << 8);

    switch (type) {
    case ST_MCAN_TYPE_PING_REQ:
        m->ping_req_rx++;
        m->rx_req++;
        m->tx_resp++;
        (void)st_mcan_send_simple(m, ST_MCAN_TYPE_PING_RESP, seq, 0U, 0U, 0U);
        break;

    case ST_MCAN_TYPE_PING_RESP:
        m->rx_resp++;
        if (!m->ping_waiting) { m->dup_resp++; break; }
        if (seq != m->awaiting_seq) { m->bad_seq++; break; }
        m->ping_waiting = false;
        m->ping_resp++;
        m->ping_completed_count++;
        m->rtt_last_ms = now_ms - m->ping_tx_ms;
        if (m->rtt_last_ms < m->rtt_min_ms) m->rtt_min_ms = m->rtt_last_ms;
        if (m->rtt_last_ms > m->rtt_max_ms) m->rtt_max_ms = m->rtt_last_ms;
        m->rtt_sum_ms += m->rtt_last_ms;
        m->rtt_count++;
        if (m->monitor || m->ping_report_each)
            st_dbg_printf("[MCAN] ping resp seq=%u rtt=%lu ms\r\n",
                          seq, (unsigned long)m->rtt_last_ms);
        break;

    case ST_MCAN_TYPE_STATUS_REQ:
        m->rx_req++;
        m->tx_resp++;
        (void)st_mcan_send_status_resp(m, seq);
        break;

    case ST_MCAN_TYPE_STATUS_RESP:
        m->rx_resp++;
        m->status_resp_rx++;
        m->last_status_seq  = seq;
        m->last_status_word = arg1;
        st_dbg_printf("[MCAN] peer status sum=%u up=%u sw=0x%04X\r\n",
                      d[3], arg0, arg1);
        break;

    case ST_MCAN_TYPE_LED_REQ:
        m->rx_req++;
        m->action_type      = ST_MCAN_ACT_LED;
        m->action_arg1      = (arg1 == 0U) ? 100U : arg1;
        m->action_remaining = (arg0 == 0U) ? 1U : arg0;
        m->action_state     = false;
        m->action_next_ms   = now_ms;
        m->tx_resp++;
        (void)st_mcan_send_simple(m, ST_MCAN_TYPE_ACK, seq, 0U,
                                   ST_MCAN_TYPE_LED_REQ, 0U);
        break;

    case ST_MCAN_TYPE_BEEP_REQ:
        m->rx_req++;
        m->action_type    = ST_MCAN_ACT_BEEP;
        m->action_arg0    = (arg0 == 0U) ? 1500U : arg0;
        m->action_arg1    = (arg1 == 0U) ? 100U  : arg1;
        m->action_state   = false;
        m->action_next_ms = now_ms;
        m->tx_resp++;
        (void)st_mcan_send_simple(m, ST_MCAN_TYPE_ACK, seq, 0U,
                                   ST_MCAN_TYPE_BEEP_REQ, 0U);
        break;

    case ST_MCAN_TYPE_ACK:
        m->ack_rx++;
        m->last_ack_seq  = seq;
        m->last_ack_type = arg0;
        m->last_ack_ms   = now_ms;
        st_dbg_printf("[MCAN] ack seq=%u type=0x%02X\r\n", seq, (unsigned)arg0);
        break;

    case ST_MCAN_TYPE_CLEAR_STATS_REQ:
        st_mcan_clear_stats(m);
        m->tx_resp++;
        (void)st_mcan_send_simple(m, ST_MCAN_TYPE_ACK, seq, 0U,
                                   ST_MCAN_TYPE_CLEAR_STATS_REQ, 0U);
        break;

    case ST_MCAN_TYPE_SELFTEST_REQ:
        m->rx_req++;
        m->tx_resp++;
        (void)st_mcan_send_simple(m, ST_MCAN_TYPE_SELFTEST_ACK, seq, 0U,
                                   arg0, arg1);
        st_mcan_start_remote_selftest(m, seq, arg0, arg1);
        break;

    case ST_MCAN_TYPE_SELFTEST_ACK:
        m->ack_rx++;
        m->last_ack_seq  = seq;
        m->last_ack_type = ST_MCAN_TYPE_SELFTEST_REQ;
        m->last_ack_ms   = now_ms;
        st_dbg_printf("[MCAN] selftest ack seq=%u sel=%s flags=0x%04X\r\n",
                      seq, st_mcan_selector_name(arg0), arg1);
        break;

    case ST_MCAN_TYPE_SELFTEST_RESULT:
        st_dbg_printf("[MCAN] remote result %-8s %s\r\n",
                      st_mcan_selector_name(arg0),
                      st_status_str((st_status_t)arg1));
        break;

    case ST_MCAN_TYPE_SELFTEST_DONE:
        st_dbg_printf("[MCAN] remote selftest done fail=%u warn=%u\r\n",
                      arg0, arg1);
        break;

    default:
        m->bad_type++;
        break;
    }
}

/* ======================================================================
 *  Main poll
 * ====================================================================== */

void st_mcan_poll(st_mcan_rt_t *m, uint32_t now_ms)
{
    FDCAN_HandleTypeDef *hfdcan = st_mcan_get_fdcan();

    st_mcan_handle_action(m, now_ms);

    /* Peer timeout */
    if (m->peer_online) {
        uint32_t timeout = m->hb_period_ms ? (m->hb_period_ms * 3U)
                                            : (ST_MCAN_DEFAULT_HB_MS * 3U);
        if ((now_ms - m->last_peer_seen_ms) > timeout) {
            m->peer_online = false;
            if (m->monitor) st_dbg_printf("[MCAN] peer offline\r\n");
        }
    }

    /* Auto-bring-up if needed */
    if ((m->hb_enabled || m->ping_active || m->monitor) && !m->online) {
        (void)st_mcan_bus_config(m, true);
    }

    /* Drain RX FIFO */
    if (m->online) {
        while (HAL_FDCAN_GetRxFifoFillLevel(hfdcan, FDCAN_RX_FIFO0) > 0U) {
            FDCAN_RxHeaderTypeDef rxh = {0};
            uint8_t d[8] = {0};
            if (HAL_FDCAN_GetRxMessage(hfdcan, FDCAN_RX_FIFO0, &rxh, d) == HAL_OK) {
                st_mcan_handle_rx_frame(m, rxh.Identifier, d, 8U, now_ms);
            } else {
                break;
            }
        }
    }

    /* Heartbeat TX */
    if (m->hb_enabled && ((now_ms - m->last_hb_tx_ms) >= m->hb_period_ms)) {
        if (st_mcan_send_heartbeat(m))
            m->last_hb_tx_ms = now_ms;
    }

    /* Ping state machine */
    if (m->ping_active) {
        if (m->ping_waiting) {
            if ((now_ms - m->ping_tx_ms) > ST_MCAN_PING_TIMEOUT_MS) {
                m->ping_waiting = false;
                m->ping_timeout++;
                m->ping_completed_count++;
                if (m->monitor || m->ping_report_each)
                    st_dbg_printf("[MCAN] ping timeout seq=%u\r\n",
                                  m->awaiting_seq);
                m->ping_last_due_ms = now_ms + m->ping_period_ms;
            }
        } else if ((m->ping_target_count == 0U ||
                     m->ping_completed_count < m->ping_target_count) &&
                    ((m->ping_last_due_ms == 0U) ||
                     ((int32_t)(now_ms - m->ping_last_due_ms) >= 0))) {
            uint8_t seq = ++m->next_seq;
            if (st_mcan_send_simple(m, ST_MCAN_TYPE_PING_REQ, seq, 0U, 0U, 0U)) {
                m->tx_req++;
                m->ping_sent++;
                m->awaiting_seq   = seq;
                m->ping_waiting   = true;
                m->ping_tx_ms     = now_ms;
            }
        }
        if (m->ping_target_count != 0U &&
            m->ping_completed_count >= m->ping_target_count &&
            !m->ping_waiting) {
            m->ping_active = false;
            m->ping_both   = false;
            st_dbg_printf("[MCAN] ping campaign done sent=%lu resp=%lu tout=%lu\r\n",
                          (unsigned long)m->ping_sent,
                          (unsigned long)m->ping_resp,
                          (unsigned long)m->ping_timeout);
        }
    }
}

/* ======================================================================
 *  Diagnostics
 * ====================================================================== */

void st_mcan_print_stats(st_mcan_rt_t *m)
{
    uint32_t avg = (m->rtt_count > 0U)
                   ? (uint32_t)(m->rtt_sum_ms / m->rtt_count) : 0U;
    uint32_t rtt_min = (m->rtt_min_ms == 0xFFFFFFFFUL) ? 0U : m->rtt_min_ms;

    st_dbg_printf("[MCAN] online=%u peer=%u mon=%u hb=%u hb_ms=%lu "
                  "ping_active=%u both=%u sent=%lu resp=%lu tout=%lu "
                  "badseq=%lu dup=%lu "
                  "rtt(last/min/max/avg)=%lu/%lu/%lu/%lu ms\r\n",
                  m->online ? 1U : 0U,
                  m->peer_online ? 1U : 0U,
                  m->monitor ? 1U : 0U,
                  m->hb_enabled ? 1U : 0U,
                  (unsigned long)m->hb_period_ms,
                  m->ping_active ? 1U : 0U,
                  m->ping_both ? 1U : 0U,
                  (unsigned long)m->ping_sent,
                  (unsigned long)m->ping_resp,
                  (unsigned long)m->ping_timeout,
                  (unsigned long)m->bad_seq,
                  (unsigned long)m->dup_resp,
                  (unsigned long)m->rtt_last_ms,
                  (unsigned long)rtt_min,
                  (unsigned long)m->rtt_max_ms,
                  (unsigned long)avg);

    st_dbg_printf("[MCAN] tx=%lu rx=%lu txhb=%lu rxhb=%lu "
                  "txreq=%lu rxreq=%lu txresp=%lu rxresp=%lu "
                  "ack=%lu badver=%lu badtype=%lu baddlc=%lu\r\n",
                  (unsigned long)m->tx_frames,
                  (unsigned long)m->rx_frames,
                  (unsigned long)m->tx_hb,
                  (unsigned long)m->rx_hb,
                  (unsigned long)m->tx_req,
                  (unsigned long)m->rx_req,
                  (unsigned long)m->tx_resp,
                  (unsigned long)m->rx_resp,
                  (unsigned long)m->ack_rx,
                  (unsigned long)m->bad_ver,
                  (unsigned long)m->bad_type,
                  (unsigned long)m->bad_dlc);
}

void st_mcan_print_timing(st_mcan_rt_t *m)
{
    FDCAN_HandleTypeDef *hfdcan = st_mcan_get_fdcan();
    (void)m;

    st_dbg_printf("[MCAN] timing NBRP=%lu NSJW=%lu NTSEG1=%lu NTSEG2=%lu "
                  "DBRP=%lu DSJW=%lu DTSEG1=%lu DTSEG2=%lu\r\n",
                  (unsigned long)hfdcan->Init.NominalPrescaler,
                  (unsigned long)hfdcan->Init.NominalSyncJumpWidth,
                  (unsigned long)hfdcan->Init.NominalTimeSeg1,
                  (unsigned long)hfdcan->Init.NominalTimeSeg2,
                  (unsigned long)hfdcan->Init.DataPrescaler,
                  (unsigned long)hfdcan->Init.DataSyncJumpWidth,
                  (unsigned long)hfdcan->Init.DataTimeSeg1,
                  (unsigned long)hfdcan->Init.DataTimeSeg2);
}

void st_mcan_print_diag(st_mcan_rt_t *m)
{
    FDCAN_HandleTypeDef *hfdcan = st_mcan_get_fdcan();
    FDCAN_ProtocolStatusTypeDef ps = {0};
    FDCAN_ErrorCountersTypeDef  ec = {0};

    HAL_StatusTypeDef s1 = HAL_FDCAN_GetProtocolStatus(hfdcan, &ps);
    HAL_StatusTypeDef s2 = HAL_FDCAN_GetErrorCounters(hfdcan, &ec);

    st_dbg_printf("[MCAN] online=%u peer=%u hb=%u monitor=%u rx_fifo0=%lu\r\n",
                  m->online ? 1U : 0U,
                  m->peer_online ? 1U : 0U,
                  m->hb_enabled ? 1U : 0U,
                  m->monitor ? 1U : 0U,
                  (unsigned long)HAL_FDCAN_GetRxFifoFillLevel(hfdcan,
                                                               FDCAN_RX_FIFO0));

    if (s1 == HAL_OK) {
        st_dbg_printf("[MCAN] proto lec=%u dlec=%u act=%u ep=%u ew=%u bo=%u pxe=%u\r\n",
                      (unsigned)ps.LastErrorCode,
                      (unsigned)ps.DataLastErrorCode,
                      (unsigned)ps.Activity,
                      (unsigned)ps.ErrorPassive,
                      (unsigned)ps.Warning,
                      (unsigned)ps.BusOff,
                      (unsigned)ps.ProtocolException);
    } else {
        st_dbg_printf("[MCAN] proto status read failed\r\n");
    }

    if (s2 == HAL_OK) {
        st_dbg_printf("[MCAN] err tx=%lu rx=%lu rp=%lu\r\n",
                      (unsigned long)ec.TxErrorCnt,
                      (unsigned long)ec.RxErrorCnt,
                      (unsigned long)ec.RxErrorPassive);
    } else {
        st_dbg_printf("[MCAN] error counter read failed\r\n");
    }

    st_mcan_print_timing(m);
}
