static bool st_str_eq_nocase(const char *a, const char *b) {
	while (*a != '\0' && *b != '\0') {
		if (tolower((unsigned char)*a) != tolower((unsigned char )*b))
			return false;
		++a;
		++b;
	}
	return (*a == '\0' && *b == '\0');
}

