    uint32_t rtt_min = (g_mcan.rtt_min_ms == 0xFFFFFFFFUL) ? 0U : g_mcan.rtt_min_ms;
    st_dbg_printf("[MCAN] online=%u peer=%u mon=%u hb=%u hb_ms=%lu ping_active=%u both=%u sent=%lu resp=%lu tout=%lu badseq=%lu dup=%lu rtt(last/min/max/avg)=%lu/%lu/%lu/%lu ms\r\n",
                  g_mcan.online ? 1U : 0U, g_mcan.peer_online ? 1U : 0U, g_mcan.monitor ? 1U : 0U,
                  g_mcan.hb_enabled ? 1U : 0U, (unsigned long)g_mcan.hb_period_ms,
                  g_mcan.ping_active ? 1U : 0U, g_mcan.ping_both ? 1U : 0U,
                  (unsigned long)g_mcan.ping_sent, (unsigned long)g_mcan.ping_resp,
                  (unsigned long)g_mcan.ping_timeout, (unsigned long)g_mcan.bad_seq,
                  (unsigned long)g_mcan.dup_resp,
                  (unsigned long)g_mcan.rtt_last_ms, (unsigned long)rtt_min,
                  (unsigned long)g_mcan.rtt_max_ms, (unsigned long)avg);
    st_dbg_printf("[MCAN] tx=%lu rx=%lu txhb=%lu rxhb=%lu txreq=%lu rxreq=%lu txresp=%lu rxresp=%lu ack=%lu badver=%lu badtype=%lu baddlc=%lu\r\n",
                  (unsigned long)g_mcan.tx_frames, (unsigned long)g_mcan.rx_frames,
                  (unsigned long)g_mcan.tx_hb, (unsigned long)g_mcan.rx_hb,
