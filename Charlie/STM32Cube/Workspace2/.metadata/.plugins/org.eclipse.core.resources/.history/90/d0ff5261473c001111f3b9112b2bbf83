static void st_mcan_print_diag(void)
{
    FDCAN_ProtocolStatusTypeDef ps = {0};
    FDCAN_ErrorCountersTypeDef ec = {0};

    HAL_StatusTypeDef s1 = HAL_FDCAN_GetProtocolStatus(&ST_CAN_PDU, &ps);
    HAL_StatusTypeDef s2 = HAL_FDCAN_GetErrorCounters(&ST_CAN_PDU, &ec);

    st_dbg_printf("[MCAN] online=%u peer=%u hb=%u monitor=%u rx_fifo0=%lu\r\n",
                  g_mcan.online ? 1U : 0U,
                  g_mcan.peer_online ? 1U : 0U,
                  g_mcan.hb_enabled ? 1U : 0U,
                  g_mcan.monitor ? 1U : 0U,
                  (unsigned long)HAL_FDCAN_GetRxFifoFillLevel(&ST_CAN_PDU, FDCAN_RX_FIFO0));

    if (s1 == HAL_OK) {
        st_dbg_printf("[MCAN] proto lec=%u dlec=%u act=%u ep=%u ew=%u bo=%u pxe=%u\r\n",
                      (unsigned)ps.LastErrorCode,
                      (unsigned)ps.DataLastErrorCode,
                      (unsigned)ps.Activity,
                      (unsigned)ps.ErrorPassive,
                      (unsigned)ps.Warning,
                      (unsigned)ps.BusOff,
                      (unsigned)ps.ProtocolException);
    } else {
        st_dbg_printf("[MCAN] proto status read failed\r\n");
    }

    if (s2 == HAL_OK) {
        st_dbg_printf("[MCAN] err tx=%lu rx=%lu log=%lu\r\n",
                      (unsigned long)ec.TxErrorCnt,
                      (unsigned long)ec.RxErrorCnt,
                      (unsigned long)ec.RxErrorPassive);
    } else {
        st_dbg_printf("[MCAN] error counter read failed\r\n");
    }

    st_mcan_print_timing();
}

static void st_monitor_poll(uint32_t now_ms) {
	if (!g_rt.monitor_adc && !g_rt.monitor_inputs && !g_rt.monitor_ssd)
		return;
	if ((now_ms - g_rt.last_monitor_ms) < g_rt.monitor_interval_ms)
		return;
	g_rt.last_monitor_ms = now_ms;
	if (g_rt.monitor_adc)
		st_adc_monitor_print();
	if (g_rt.monitor_inputs)
		st_inputs_monitor_print();
	if (g_rt.monitor_ssd)
		st_ssd_print_readings();
}

