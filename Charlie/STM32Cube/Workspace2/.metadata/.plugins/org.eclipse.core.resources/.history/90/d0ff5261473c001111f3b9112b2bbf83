static bool st_mcan_bus_config(bool enable_transceiver) {
    HAL_FDCAN_Stop(&ST_FDCAN);
    HAL_FDCAN_DeInit(&ST_FDCAN);
    if (ST_FDCAN.Init.StdFiltersNbr < 1U) ST_FDCAN.Init.StdFiltersNbr = 1U;
    ST_FDCAN.Init.FrameFormat = FDCAN_FRAME_CLASSIC;
    ST_FDCAN.Init.Mode = FDCAN_MODE_NORMAL;
    ST_FDCAN.Init.AutoRetransmission = DISABLE;
    ST_FDCAN.Init.TransmitPause = DISABLE;
    ST_FDCAN.Init.ProtocolException = DISABLE;
    ST_FDCAN.Init.TxFifoQueueMode = FDCAN_TX_FIFO_OPERATION;
    if (HAL_FDCAN_Init(&ST_FDCAN) != HAL_OK) {
        g_mcan.online = false;
        return false;
    }
    FDCAN_FilterTypeDef filter = {0};
    filter.IdType = FDCAN_STANDARD_ID;
    filter.FilterIndex = 0;
    filter.FilterType = FDCAN_FILTER_MASK;
    filter.FilterConfig = FDCAN_FILTER_TO_RXFIFO0;
    filter.FilterID1 = 0U;
    filter.FilterID2 = 0U;
    if (HAL_FDCAN_ConfigFilter(&ST_FDCAN, &filter) != HAL_OK) { g_mcan.online = false; return false; }
    if (HAL_FDCAN_ConfigGlobalFilter(&ST_FDCAN, FDCAN_REJECT, FDCAN_REJECT, FDCAN_FILTER_REMOTE, FDCAN_FILTER_REMOTE) != HAL_OK) { g_mcan.online = false; return false; }
    if (HAL_FDCAN_Start(&ST_FDCAN) != HAL_OK) { g_mcan.online = false; return false; }
    st_can_standby_set(!enable_transceiver);
    g_mcan.online = enable_transceiver;
    return true;
}

static void st_mcan_bus_disable(void) {
    HAL_FDCAN_Stop(&ST_FDCAN);
    st_can_standby_set(true);
    g_mcan.online = false;
}

static bool st_mcan_send_frame(uint32_t id, const uint8_t payload[8]) {
    if (!g_mcan.online) {
        if (!st_mcan_bus_config(true)) return false;
    }
    FDCAN_TxHeaderTypeDef txh = {0};
    txh.Identifier = id;
    txh.IdType = FDCAN_STANDARD_ID;
    txh.TxFrameType = FDCAN_DATA_FRAME;
    txh.DataLength = FDCAN_DLC_BYTES_8;
    txh.ErrorStateIndicator = FDCAN_ESI_ACTIVE;
    txh.BitRateSwitch = FDCAN_BRS_OFF;
    txh.FDFormat = FDCAN_CLASSIC_CAN;
    txh.TxEventFifoControl = FDCAN_NO_TX_EVENTS;
    txh.MessageMarker = 0U;
    if (HAL_FDCAN_AddMessageToTxFifoQ(&ST_FDCAN, &txh, (uint8_t *)payload) != HAL_OK) return false;
    g_mcan.tx_frames++;
    return true;
}

static bool st_mcan_send_simple(uint32_t id, uint8_t type, uint8_t seq, uint8_t flags, uint16_t arg0, uint16_t arg1) {
    uint8_t p[8];
    p[0] = ST_MCAN_PROTO_VER;
    p[1] = type;
    p[2] = seq;
    p[3] = flags;
    p[4] = (uint8_t)(arg0 & 0xFFU);
    p[5] = (uint8_t)((arg0 >> 8) & 0xFFU);
    p[6] = (uint8_t)(arg1 & 0xFFU);
    p[7] = (uint8_t)((arg1 >> 8) & 0xFFU);
    return st_mcan_send_frame(id, p);
}

static bool st_mcan_send_status_resp(uint8_t seq) {
    uint8_t p[8];
    uint16_t up = (uint16_t)((HAL_GetTick() / 1000U) & 0xFFFFU);
    uint16_t sw = st_mcan_status_word();
    p[0] = ST_MCAN_PROTO_VER;
    p[1] = ST_MCAN_TYPE_STATUS_RESP;
    p[2] = seq;
    p[3] = st_mcan_summary_code();
    p[4] = (uint8_t)(up & 0xFFU);
    p[5] = (uint8_t)((up >> 8) & 0xFFU);
    p[6] = (uint8_t)(sw & 0xFFU);
    p[7] = (uint8_t)((sw >> 8) & 0xFFU);
    return st_mcan_send_frame(ST_MCAN_ID_PDU_TO_RCU, p);
}

static bool st_mcan_send_heartbeat(void) {
    uint8_t p[8];
    uint16_t up = (uint16_t)((HAL_GetTick() / 1000U) & 0xFFFFU);
    uint16_t sw = st_mcan_status_word();
    p[0] = ST_MCAN_PROTO_VER;
    p[1] = st_mcan_summary_code();
    p[2] = g_mcan.next_seq++;
    p[3] = 0U;
    p[4] = (uint8_t)(up & 0xFFU);
    p[5] = (uint8_t)((up >> 8) & 0xFFU);
    p[6] = (uint8_t)(sw & 0xFFU);
    p[7] = (uint8_t)((sw >> 8) & 0xFFU);
    if (!st_mcan_send_frame(ST_MCAN_ID_PDU_HB, p)) return false;
    g_mcan.tx_hb++;
    return true;
}

static void st_mcan_start_ping(uint32_t count, uint32_t period_ms, bool both, bool report_each) {
    if (period_ms == 0U) period_ms = ST_MCAN_DEFAULT_PING_MS;
    g_mcan.ping_active = true;
    g_mcan.ping_both = both;
    g_mcan.ping_report_each = report_each;
    g_mcan.ping_period_ms = period_ms;
    g_mcan.ping_target_count = count;
    g_mcan.ping_completed_count = 0U;
    g_mcan.ping_waiting = false;
    g_mcan.ping_last_due_ms = 0U;
    if (!g_mcan.online) (void)st_mcan_bus_config(true);
}

static void st_mcan_stop_ping(void) {
    g_mcan.ping_active = false;
    g_mcan.ping_both = false;
    g_mcan.ping_waiting = false;
}

static void st_mcan_handle_action(uint32_t now_ms) {
    if (g_mcan.action_type == ST_MCAN_ACT_NONE) return;
    if ((int32_t)(now_ms - g_mcan.action_next_ms) < 0) return;
    if (g_mcan.action_type == ST_MCAN_ACT_LED) {
        g_mcan.action_state = !g_mcan.action_state;
        st_led_set(0U, g_mcan.action_state);
        st_led_set(1U, g_mcan.action_state);
        if (!g_mcan.action_state) {
            if (g_mcan.action_remaining > 0U) g_mcan.action_remaining--;
            if (g_mcan.action_remaining == 0U) {
                g_mcan.action_type = ST_MCAN_ACT_NONE;
                st_led_all_off();
                return;
            }
        }
        g_mcan.action_next_ms = now_ms + g_mcan.action_arg1;
    } else if (g_mcan.action_type == ST_MCAN_ACT_BEEP) {
        if (!g_mcan.action_state) {
            st_buzzer_start(g_mcan.action_arg0);
            g_mcan.action_state = true;
            g_mcan.action_next_ms = now_ms + g_mcan.action_arg1;
        } else {
            st_buzzer_off();
            g_mcan.action_type = ST_MCAN_ACT_NONE;
            g_mcan.action_state = false;
        }
    }
}

static void st_mcan_handle_rx_frame(uint32_t id, const uint8_t *d, uint32_t len, uint32_t now_ms) {
    g_mcan.rx_frames++;
    g_mcan.last_peer_seen_ms = now_ms;
    if (!g_mcan.peer_online) {
        g_mcan.peer_online = true;
        if (g_mcan.monitor) st_dbg_printf("[MCAN] peer online\r\n");
    }
    if (id == ST_MCAN_ID_RCU_HB) {
        g_mcan.rx_hb++;
        if (g_mcan.monitor && len >= 8U) {
            uint16_t up = (uint16_t)d[4] | ((uint16_t)d[5] << 8);
            uint16_t sw = (uint16_t)d[6] | ((uint16_t)d[7] << 8);
            st_dbg_printf("[MCAN] HB RX sum=%u up=%u sw=0x%04X\r\n", d[1], up, sw);
        }
        return;
    }
    if (id != ST_MCAN_ID_RCU_TO_PDU) return;
    if (len < 8U) { g_mcan.bad_dlc++; return; }
    if (d[0] != ST_MCAN_PROTO_VER) { g_mcan.bad_ver++; return; }
    uint8_t type = d[1], seq = d[2], flags = d[3];
    uint16_t arg0 = (uint16_t)d[4] | ((uint16_t)d[5] << 8);
    uint16_t arg1 = (uint16_t)d[6] | ((uint16_t)d[7] << 8);
    (void)flags;
    switch (type) {
        case ST_MCAN_TYPE_PING_REQ:
            g_mcan.ping_req_rx++;
            g_mcan.rx_req++;
            g_mcan.tx_resp++;
            (void)st_mcan_send_simple(ST_MCAN_ID_PDU_TO_RCU, ST_MCAN_TYPE_PING_RESP, seq, 0U, 0U, 0U);
            break;
        case ST_MCAN_TYPE_PING_RESP:
            g_mcan.rx_resp++;
            if (!g_mcan.ping_waiting) { g_mcan.dup_resp++; break; }
            if (seq != g_mcan.awaiting_seq) { g_mcan.bad_seq++; break; }
            g_mcan.ping_waiting = false;
            g_mcan.ping_resp++;
            g_mcan.ping_completed_count++;
            g_mcan.rtt_last_ms = now_ms - g_mcan.ping_tx_ms;
            if (g_mcan.rtt_last_ms < g_mcan.rtt_min_ms) g_mcan.rtt_min_ms = g_mcan.rtt_last_ms;
            if (g_mcan.rtt_last_ms > g_mcan.rtt_max_ms) g_mcan.rtt_max_ms = g_mcan.rtt_last_ms;
            g_mcan.rtt_sum_ms += g_mcan.rtt_last_ms;
            g_mcan.rtt_count++;
            if (g_mcan.monitor || g_mcan.ping_report_each)
                st_dbg_printf("[MCAN] ping resp seq=%u rtt=%lu ms\r\n", seq, (unsigned long)g_mcan.rtt_last_ms);
            break;
        case ST_MCAN_TYPE_STATUS_REQ:
            g_mcan.rx_req++;
            g_mcan.tx_resp++;
            (void)st_mcan_send_status_resp(seq);
            break;
        case ST_MCAN_TYPE_STATUS_RESP:
            g_mcan.rx_resp++;
            st_dbg_printf("[MCAN] peer status sum=%u up=%u sw=0x%04X\r\n", d[3], arg0, arg1);
            break;
        case ST_MCAN_TYPE_LED_REQ:
            g_mcan.rx_req++;
            g_mcan.action_type = ST_MCAN_ACT_LED;
            g_mcan.action_arg1 = (arg1 == 0U) ? 100U : arg1;
            g_mcan.action_remaining = (arg0 == 0U) ? 1U : arg0;
            g_mcan.action_state = false;
            g_mcan.action_next_ms = now_ms;
            g_mcan.tx_resp++;
            (void)st_mcan_send_simple(ST_MCAN_ID_PDU_TO_RCU, ST_MCAN_TYPE_ACK, seq, 0U, ST_MCAN_TYPE_LED_REQ, 0U);
            break;
        case ST_MCAN_TYPE_BEEP_REQ:
            g_mcan.rx_req++;
            g_mcan.action_type = ST_MCAN_ACT_BEEP;
            g_mcan.action_arg0 = (arg0 == 0U) ? 1500U : arg0;
            g_mcan.action_arg1 = (arg1 == 0U) ? 100U : arg1;
            g_mcan.action_state = false;
            g_mcan.action_next_ms = now_ms;
            g_mcan.tx_resp++;
            (void)st_mcan_send_simple(ST_MCAN_ID_PDU_TO_RCU, ST_MCAN_TYPE_ACK, seq, 0U, ST_MCAN_TYPE_BEEP_REQ, 0U);
            break;
        case ST_MCAN_TYPE_ACK:
            g_mcan.ack_rx++;
            st_dbg_printf("[MCAN] ack seq=%u type=0x%02X\r\n", seq, (unsigned)arg0);
            break;
        case ST_MCAN_TYPE_CLEAR_STATS_REQ:
            st_mcan_clear_stats_local();
            g_mcan.tx_resp++;
            (void)st_mcan_send_simple(ST_MCAN_ID_PDU_TO_RCU, ST_MCAN_TYPE_ACK, seq, 0U, ST_MCAN_TYPE_CLEAR_STATS_REQ, 0U);
            break;
        default:
            g_mcan.bad_type++;
            break;
    }
}

static void st_mcan_poll(uint32_t now_ms) {
    st_mcan_handle_action(now_ms);
    if ((g_mcan.peer_online) && ((now_ms - g_mcan.last_peer_seen_ms) > (g_mcan.hb_period_ms ? (g_mcan.hb_period_ms * 3U) : (ST_MCAN_DEFAULT_HB_MS * 3U)))) {
        g_mcan.peer_online = false;
        if (g_mcan.monitor) st_dbg_printf("[MCAN] peer offline\r\n");
    }
    if ((g_mcan.hb_enabled || g_mcan.ping_active || g_mcan.monitor) && !g_mcan.online) {
        (void)st_mcan_bus_config(true);
    }
    if (g_mcan.online) {
        while (HAL_FDCAN_GetRxFifoFillLevel(&ST_FDCAN, FDCAN_RX_FIFO0) > 0U) {
            FDCAN_RxHeaderTypeDef rxh = {0};
            uint8_t d[8] = {0};
            if (HAL_FDCAN_GetRxMessage(&ST_FDCAN, FDCAN_RX_FIFO0, &rxh, d) == HAL_OK) {
                uint32_t len = 8U;
                st_mcan_handle_rx_frame(rxh.Identifier, d, len, now_ms);
            } else {
                break;
            }
        }
    }
    if (g_mcan.hb_enabled && ((now_ms - g_mcan.last_hb_tx_ms) >= g_mcan.hb_period_ms)) {
        if (st_mcan_send_heartbeat()) g_mcan.last_hb_tx_ms = now_ms;
    }
    if (g_mcan.ping_active) {
        if (g_mcan.ping_waiting) {
            if ((now_ms - g_mcan.ping_tx_ms) > ST_MCAN_PING_TIMEOUT_MS) {
                g_mcan.ping_waiting = false;
                g_mcan.ping_timeout++;
                g_mcan.ping_completed_count++;
                if (g_mcan.monitor || g_mcan.ping_report_each)
                    st_dbg_printf("[MCAN] ping timeout seq=%u\r\n", g_mcan.awaiting_seq);
                g_mcan.ping_last_due_ms = now_ms + g_mcan.ping_period_ms;
            }
        } else if ((g_mcan.ping_target_count == 0U || g_mcan.ping_completed_count < g_mcan.ping_target_count) &&
                   ((g_mcan.ping_last_due_ms == 0U) || ((int32_t)(now_ms - g_mcan.ping_last_due_ms) >= 0))) {
            uint8_t seq = ++g_mcan.next_seq;
            if (st_mcan_send_simple(ST_MCAN_ID_PDU_TO_RCU, ST_MCAN_TYPE_PING_REQ, seq, 0U, 0U, 0U)) {
                g_mcan.tx_req++;
                g_mcan.ping_sent++;
                g_mcan.awaiting_seq = seq;
                g_mcan.ping_waiting = true;
                g_mcan.ping_tx_ms = now_ms;
            }
        }
        if (g_mcan.ping_target_count != 0U && g_mcan.ping_completed_count >= g_mcan.ping_target_count && !g_mcan.ping_waiting) {
            g_mcan.ping_active = false;
            g_mcan.ping_both = false;
            st_dbg_printf("[MCAN] ping campaign done sent=%lu resp=%lu tout=%lu\r\n",
                          (unsigned long)g_mcan.ping_sent,
                          (unsigned long)g_mcan.ping_resp,
                          (unsigned long)g_mcan.ping_timeout);
        }
    }
}

