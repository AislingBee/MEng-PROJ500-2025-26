static void st_mcan_init(void) {
    memset(&g_mcan, 0, sizeof(g_mcan));
    g_mcan.hb_period_ms = ST_MCAN_DEFAULT_HB_MS;
    g_mcan.ping_period_ms = ST_MCAN_DEFAULT_PING_MS;
    g_mcan.rtt_min_ms = 0xFFFFFFFFUL;
}

static void st_mcan_clear_stats_local(void) {
    bool mon = g_mcan.monitor;
    bool hb = g_mcan.hb_enabled;
    uint32_t hbms = g_mcan.hb_period_ms;
    bool on = g_mcan.online;
    memset(&g_mcan, 0, sizeof(g_mcan));
    g_mcan.monitor = mon;
    g_mcan.hb_enabled = hb;
    g_mcan.hb_period_ms = hbms ? hbms : ST_MCAN_DEFAULT_HB_MS;
    g_mcan.online = on;
    g_mcan.ping_period_ms = ST_MCAN_DEFAULT_PING_MS;
    g_mcan.rtt_min_ms = 0xFFFFFFFFUL;
}

static uint8_t st_mcan_summary_code(void) {
    bool any_fail = false, any_warn = false;
    for (int i = 0; i < ST_NUM_TESTS; ++i) {
        if (g_tests[i].status == STS_FAIL) any_fail = true;
        else if (g_tests[i].status == STS_WARN) any_warn = true;
    }
    return any_fail ? 2U : (any_warn ? 1U : 0U);
}

static uint16_t st_mcan_status_word(void) {
    uint16_t w = 0U;
    if (HAL_GPIO_ReadPin(FAULT_LATCH_GPIO_Port, FAULT_LATCH_Pin) == GPIO_PIN_SET) w |= (1U << 0);
    if (HAL_GPIO_ReadPin(SW_FAULT_GPIO_Port, SW_FAULT_Pin) == GPIO_PIN_SET) w |= (1U << 1);
    if (HAL_GPIO_ReadPin(PGOOD_SW_GPIO_Port, PGOOD_SW_Pin) == GPIO_PIN_SET) w |= (1U << 2);
    if (HAL_GPIO_ReadPin(PGOOD_24V_GPIO_Port, PGOOD_24V_Pin) == GPIO_PIN_SET) w |= (1U << 3);
    return w;
}

static void st_mcan_print_stats(void) {
