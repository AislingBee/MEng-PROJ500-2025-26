	test_buzzer_reset();
	g_buzzer_test.next_ms = HAL_GetTick();
}
static st_status_t test_buzzer_poll(uint32_t now_ms, char *detail,
		size_t detail_len) {
	(void) detail;
	(void) detail_len;
	if (now_ms < g_buzzer_test.next_ms)
		return STS_RUNNING;
	switch (g_buzzer_test.phase) {
	case 0:
		st_buzzer_start(1200U);
		g_buzzer_test.next_ms = now_ms + (g_rt.loop_fast ? 50U : 120U);
		break;
	case 1:
		st_buzzer_off();
		g_buzzer_test.next_ms = now_ms + (g_rt.loop_fast ? 20U : 80U);
		break;
	case 2:
		st_buzzer_start(1800U);
		g_buzzer_test.next_ms = now_ms + (g_rt.loop_fast ? 50U : 120U);
		break;
	case 3:
		st_buzzer_off();
		g_buzzer_test.next_ms = now_ms + (g_rt.loop_fast ? 20U : 80U);
		break;
	case 4:
		st_buzzer_start(2400U);
		g_buzzer_test.next_ms = now_ms + (g_rt.loop_fast ? 70U : 160U);
		break;
	case 5:
		st_buzzer_off();
		return STS_PASS;
	default:
		st_buzzer_off();
		return STS_PASS;
	}
	g_buzzer_test.phase++;
	return STS_RUNNING;
}

