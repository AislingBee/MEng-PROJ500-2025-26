				samples[0].eng, samples[1].eng, samples[2].eng, samples[3].eng,
				samples[4].eng, samples[5].eng, samples[6].eng, samples[7].eng);
	}
	return st_adc_sanity(samples, detail, detail_len);
}

static st_test_t g_tests[] = { { "gpio", ST_TEST_GPIO, test_gpio_reset,
		test_gpio_start, test_gpio_poll, STS_NOT_RUN, "" }, { "buzzer",
		ST_TEST_BUZZER, test_buzzer_reset, test_buzzer_start, test_buzzer_poll,
		STS_NOT_RUN, "" }, { "can", ST_TEST_CAN, test_can_reset, test_can_start,
		test_can_poll, STS_NOT_RUN, "" }, { "ssd", ST_TEST_SSD, test_ssd_reset,
		test_ssd_start, test_ssd_poll, STS_NOT_RUN, "" }, { "fpga",
		ST_TEST_FPGA, test_fpga_reset, test_fpga_start, test_fpga_poll,
		STS_NOT_RUN, "" }, { "adc", ST_TEST_ADC, test_adc_reset, test_adc_start,
		test_adc_poll, STS_NOT_RUN, "" }, };
#define ST_NUM_TESTS ((int)(sizeof(g_tests) / sizeof(g_tests[0])))
static uint32_t g_campaign_pass[ST_NUM_TESTS];
static uint32_t g_campaign_fail[ST_NUM_TESTS];
static uint32_t g_campaign_warn[ST_NUM_TESTS];
static uint32_t g_campaign_skip[ST_NUM_TESTS];

static void st_reset_all_tests(void) {
	for (int i = 0; i < ST_NUM_TESTS; ++i) {
		g_tests[i].status = STS_NOT_RUN;
		g_tests[i].detail[0] = '\0';
		if (g_tests[i].reset)
			g_tests[i].reset();
	}
}

static int st_test_index_from_name(const char *name) {
	for (int i = 0; i < ST_NUM_TESTS; ++i)
		if (strcmp(name, g_tests[i].name) == 0)
			return i;
	return -1;
}

static void st_start_test_index(int idx) {
	if (idx < 0 || idx >= ST_NUM_TESTS)
		return;
	g_rt.current_test = idx;
	g_tests[idx].status = STS_RUNNING;
	g_tests[idx].detail[0] = '\0';
	if (g_tests[idx].start)
		g_tests[idx].start();
	st_dbg_printf("[RUN] %s\r\n", g_tests[idx].name);
}

static int st_next_enabled_test_after(int idx) {
	for (int i = idx + 1; i < ST_NUM_TESTS; ++i)
		if ((g_rt.current_mask & g_tests[i].mask) != 0U)
			return i;
	return -1;
}

static void st_abort(bool announce) {
	st_safe_outputs();
	g_rt.mode = RUN_IDLE;
	g_rt.current_test = -1;
	g_rt.current_mask = 0U;
	g_rt.campaign_active = false;
	g_rt.loop_enabled = false;
	g_rt.loop_target_count = 0U;
	if (announce)
		st_dbg_printf("[RUN] stopped\r\n");
}

static void st_start_all(void) {
	st_reset_all_tests();
	g_rt.mode = RUN_ALL;
	g_rt.current_mask = g_rt.enabled_mask;
	g_rt.current_test = -1;
	g_rt.run_fail_count = 0U;
	g_rt.run_warn_count = 0U;
	for (int i = 0; i < ST_NUM_TESTS; ++i) {
		if ((g_tests[i].mask & g_rt.enabled_mask) != 0U) {
			g_rt.current_test = i;
			g_tests[i].status = STS_RUNNING;
			if (g_tests[i].start)
				g_tests[i].start();
			if (!g_rt.loop_fast)
				st_dbg_printf("[RUN] %s\r\n", g_tests[i].name);
			return;
		} else {
			g_tests[i].status = STS_SKIPPED;
		}
	}
	g_rt.mode = RUN_IDLE;
}

static void st_start_one(uint32_t mask) {
	st_reset_all_tests();
	g_rt.mode = RUN_ONE;
	g_rt.current_mask = mask;
	g_rt.current_test = -1;
	g_rt.run_fail_count = 0U;
	g_rt.run_warn_count = 0U;
	for (int i = 0; i < ST_NUM_TESTS; ++i) {
		if ((g_tests[i].mask & mask) != 0U) {
			g_rt.current_test = i;
			g_tests[i].status = STS_RUNNING;
			g_tests[i].detail[0] = '\0';
			if (g_tests[i].start)
				g_tests[i].start();
			st_dbg_printf("[RUN] %s\r\n", g_tests[i].name);
			return;
		}
	}
	g_rt.mode = RUN_IDLE;
}

static void st_print_tests(void) {
	st_dbg_printf("Tests:\r\n");
	for (int i = 0; i < ST_NUM_TESTS; ++i) {
		st_dbg_printf("  %-8s enabled=%s\r\n", g_tests[i].name,
				(g_rt.enabled_mask & g_tests[i].mask) ? "yes" : "no");
	}
}

static void st_print_status(void) {
	st_dbg_printf("[STATUS] mode=%d loop=%u fast=%u stoponfail=%u target=%lu done=%lu delay=%lu monitor_adc=%u monitor_inputs=%u monitor_ssd=%u therm_offs=%.2f\r\n",
			(int) g_rt.mode, g_rt.loop_enabled ? 1U : 0U, g_rt.loop_fast ? 1U : 0U,
			g_rt.loop_stop_on_fail ? 1U : 0U, (unsigned long) g_rt.loop_target_count,
			(unsigned long) g_rt.loop_completed_count, (unsigned long) g_rt.loop_delay_ms,
			g_rt.monitor_adc ? 1U : 0U, g_rt.monitor_inputs ? 1U : 0U,
			g_rt.monitor_ssd ? 1U : 0U, g_rt.therm_offset_c);
	for (int i = 0; i < ST_NUM_TESTS; ++i) {
		st_dbg_printf("  %-8s %-8s %s\r\n", g_tests[i].name,
				st_status_str(g_tests[i].status), g_tests[i].detail);
