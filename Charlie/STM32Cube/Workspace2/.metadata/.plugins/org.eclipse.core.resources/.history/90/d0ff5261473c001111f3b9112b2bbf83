static void st_handle_set(const char *what, const char *val) {
	bool on = (strcmp(val, "1") == 0 || st_str_eq_nocase(val, "on"));
	if (strcmp(what, "led0") == 0)
		st_led_set(0U, on);
	else if (strcmp(what, "led1") == 0)
		st_led_set(1U, on);
	else if (strcmp(what, "cmd_arm") == 0)
		st_cmd_arm_set(on);
	else if (strcmp(what, "cmd_fault") == 0)
		st_cmd_fault_set(on);
	else if (strcmp(what, "can_stb") == 0)
		st_can_standby_set(on);
	else if (strcmp(what, "rs485_de") == 0)
		st_rs485_de_set(on);
	else {
		st_dbg_printf("unknown set target\r\n");
		return;
	}
	st_dbg_printf("[SET] %s=%u\r\n", what, on ? 1U : 0U);
}

static void st_process_line(char *line) {
	char *argv[8] = { 0 };
	int argc = 0;
	while (*line != '\0' && argc < 8) {
		while (isspace((unsigned char )*line))
			++line;
		if (*line == '\0')
			break;
		argv[argc++] = line;
		while (*line != '\0' && !isspace((unsigned char )*line))
			++line;
		if (*line == '\0')
			break;
		*line++ = '\0';
	}
	if (argc == 0) {
		st_prompt();
		return;
	}

	if (strcmp(argv[0], "help") == 0) {
		st_print_help();
	} else if (strcmp(argv[0], "list") == 0) {
		st_print_tests();
	} else if (strcmp(argv[0], "status") == 0) {
		st_print_status();
	} else if (strcmp(argv[0], "summary") == 0) {
		st_print_summary();
	} else if (strcmp(argv[0], "clear") == 0) {
		st_reset_all_tests();
		memset(g_campaign_pass, 0, sizeof(g_campaign_pass));
		memset(g_campaign_fail, 0, sizeof(g_campaign_fail));
		memset(g_campaign_warn, 0, sizeof(g_campaign_warn));
		memset(g_campaign_skip, 0, sizeof(g_campaign_skip));
		g_rt.loop_completed_count = 0U;
		g_rt.run_fail_count = 0U;
		g_rt.run_warn_count = 0U;
		st_dbg_printf("[CLR] statuses cleared\r\n");
	} else if (strcmp(argv[0], "stop") == 0) {
		st_abort(true);
	} else if (strcmp(argv[0], "run") == 0 && argc >= 2) {
		bool fast = (argc >= 3 && st_str_eq_nocase(argv[2], "fast"));
		g_rt.loop_fast = fast;
		if (strcmp(argv[1], "all") == 0) {
			g_rt.campaign_active = false;
			st_start_all();
		} else {
			int idx = st_test_index_from_name(argv[1]);
			if (idx < 0)
				st_dbg_printf("unknown test\r\n");
			else {
				g_rt.campaign_active = false;
				st_start_one(g_tests[idx].mask);
			}
		}
	} else if ((strcmp(argv[0], "enable") == 0
			|| strcmp(argv[0], "disable") == 0) && argc >= 2) {
		bool en = (strcmp(argv[0], "enable") == 0);
		if (strcmp(argv[1], "all") == 0)
			g_rt.enabled_mask = en ? ST_TEST_ALL : 0U;
		else {
			int idx = st_test_index_from_name(argv[1]);
			if (idx < 0) {
				st_dbg_printf("unknown test\r\n");
				st_prompt();
				return;
			}
			if (en)
				g_rt.enabled_mask |= g_tests[idx].mask;
			else
				g_rt.enabled_mask &= ~g_tests[idx].mask;
		}
		st_print_tests();
	} else if (strcmp(argv[0], "loop") == 0 && argc >= 2) {
		if (strcmp(argv[1], "on") == 0) {
			g_rt.loop_enabled = true;
			g_rt.campaign_active = true;
			g_rt.loop_target_count = 0U;
			g_rt.loop_completed_count = 0U;
			memset(g_campaign_pass, 0, sizeof(g_campaign_pass));
			memset(g_campaign_fail, 0, sizeof(g_campaign_fail));
			memset(g_campaign_warn, 0, sizeof(g_campaign_warn));
			memset(g_campaign_skip, 0, sizeof(g_campaign_skip));
			if (g_rt.mode == RUN_IDLE)
				st_start_all();
			st_dbg_printf("[LOOP] on\r\n");
		} else if (strcmp(argv[1], "off") == 0) {
			g_rt.loop_enabled = false;
			g_rt.campaign_active = false;
			g_rt.loop_target_count = 0U;
			st_dbg_printf("[LOOP] off\r\n");
		} else if (strcmp(argv[1], "count") == 0 && argc >= 3) {
			uint32_t count = (uint32_t) strtoul(argv[2], NULL, 0);
			bool fast = (argc >= 4 && st_str_eq_nocase(argv[3], "fast"));
			g_rt.loop_enabled = true;
			g_rt.campaign_active = true;
			g_rt.loop_target_count = count;
			g_rt.loop_completed_count = 0U;
			g_rt.loop_fast = fast;
			if (g_rt.loop_fast && g_rt.loop_delay_ms > ST_FAST_LOOP_DELAY_MS)
				g_rt.loop_delay_ms = ST_FAST_LOOP_DELAY_MS;
			memset(g_campaign_pass, 0, sizeof(g_campaign_pass));
			memset(g_campaign_fail, 0, sizeof(g_campaign_fail));
			memset(g_campaign_warn, 0, sizeof(g_campaign_warn));
			memset(g_campaign_skip, 0, sizeof(g_campaign_skip));
			if (g_rt.mode == RUN_IDLE)
				st_start_all();
			st_dbg_printf("[LOOP] count=%lu fast=%u\r\n",
					(unsigned long) count, fast ? 1U : 0U);
		} else if (strcmp(argv[1], "delay") == 0 && argc >= 3) {
			g_rt.loop_delay_ms = (uint32_t) strtoul(argv[2], NULL, 0);
			st_dbg_printf("[LOOP] delay=%lu ms\r\n",
					(unsigned long) g_rt.loop_delay_ms);
		} else if (strcmp(argv[1], "fast") == 0 && argc >= 3) {
			g_rt.loop_fast = st_str_eq_nocase(argv[2], "on");
			if (g_rt.loop_fast && g_rt.loop_delay_ms > ST_FAST_LOOP_DELAY_MS)
				g_rt.loop_delay_ms = ST_FAST_LOOP_DELAY_MS;
			st_dbg_printf("[LOOP] fast=%u\r\n", g_rt.loop_fast ? 1U : 0U);
		} else if (strcmp(argv[1], "stoponfail") == 0 && argc >= 3) {
			g_rt.loop_stop_on_fail = st_str_eq_nocase(argv[2], "on");
			st_dbg_printf("[LOOP] stoponfail=%u\r\n",
					g_rt.loop_stop_on_fail ? 1U : 0U);
		} else {
			st_dbg_printf("bad loop command\r\n");
		}
	} else if (strcmp(argv[0], "therm") == 0 && argc >= 2) {
		if (strcmp(argv[1], "raw") == 0) {
			st_therm_print_detail();
		} else if (strcmp(argv[1], "cal") == 0 && argc >= 3) {
			if (strcmp(argv[2], "show") == 0) {
				st_dbg_printf("[THERM] cal offset=%.2fC\r\n", g_rt.therm_offset_c);
			} else if (strcmp(argv[2], "clear") == 0) {
				g_rt.therm_offset_c = 0.0f;
				st_dbg_printf("[THERM] cal cleared\r\n");
			} else if (strcmp(argv[2], "offset") == 0 && argc >= 4) {
				g_rt.therm_offset_c = strtof(argv[3], NULL);
				st_dbg_printf("[THERM] cal offset=%.2fC\r\n", g_rt.therm_offset_c);
			} else {
				st_dbg_printf("bad therm cal command\r\n");
			}
		} else {
			st_dbg_printf("bad therm command\r\n");
		}
	} else if (strcmp(argv[0], "monitor") == 0 && argc >= 3) {
		if (strcmp(argv[1], "adc") == 0) {
			g_rt.monitor_adc = (strcmp(argv[2], "on") == 0);
			st_dbg_printf("[MON] adc=%s\r\n", g_rt.monitor_adc ? "on" : "off");
		} else if (strcmp(argv[1], "inputs") == 0) {
			g_rt.monitor_inputs = (strcmp(argv[2], "on") == 0);
			st_dbg_printf("[MON] inputs=%s\r\n",
					g_rt.monitor_inputs ? "on" : "off");
		} else if (strcmp(argv[1], "ssd") == 0) {
			g_rt.monitor_ssd = (strcmp(argv[2], "on") == 0);
			st_dbg_printf("[MON] ssd=%s\r\n", g_rt.monitor_ssd ? "on" : "off");
		} else if (strcmp(argv[1], "interval") == 0) {
			g_rt.monitor_interval_ms = (uint32_t) strtoul(argv[2], NULL, 0);
			st_dbg_printf("[MON] interval=%lu ms\r\n",
					(unsigned long) g_rt.monitor_interval_ms);
		} else {
			st_dbg_printf("bad monitor command\r\n");
		}
	} else if (strcmp(argv[0], "adc") == 0 && argc >= 2) {
		uint8_t sys = 0U;
		st_adc_sample_t s[8];
		if (strcmp(argv[1], "ping") == 0) {
			if (st_adc_ping(&sys))
				st_dbg_printf("[ADC] ACK, SYSTEM_STATUS=0x%02X\r\n", sys);
			else
				st_dbg_printf("[ADC] no response\r\n");
		} else if (strcmp(argv[1], "raw") == 0 || strcmp(argv[1], "scan") == 0
				|| strcmp(argv[1], "eng") == 0) {
			if (!st_adc_read_all(s))
				st_dbg_printf("[ADC] read failed\r\n");
			else if (strcmp(argv[1], "raw") == 0)
				st_adc_print_raw(s);
			else
				st_adc_print_eng(s);
		} else {
			st_dbg_printf("bad adc command\r\n");
		}
	} else if (strcmp(argv[0], "ssd") == 0 && argc >= 2) {
		if (strcmp(argv[1], "discover") == 0) {
			st_ssd_discover_ascii();
		} else if (strcmp(argv[1], "modbus-probe") == 0) {
			st_ssd_modbus_probe();
		} else {
			if (!st_ssd_uart_apply_defaults()) {
				st_dbg_printf("[SSD] UART3 init failed\r\n");
			} else if (strcmp(argv[1], "ping") == 0) {
				char fw[ST_SSD_RX_BUF_LEN] = { 0 };
				if (st_ssd_query_text(":1VE\r", fw, sizeof(fw)))
					st_dbg_printf("[SSD] response: %s\r\n", fw);
				else
					st_dbg_printf("[SSD] no response to :1VE\r\n");
			} else if (strcmp(argv[1], "fw") == 0) {
				char fw[ST_SSD_RX_BUF_LEN] = { 0 };
				if (st_ssd_query_text(":1VE\r", fw, sizeof(fw)))
					st_dbg_printf("[SSD] FW=%s\r\n", fw);
				else
					st_dbg_printf("[SSD] no response\r\n");
			} else if (strcmp(argv[1], "read") == 0) {
				st_ssd_print_readings();
			} else if (strcmp(argv[1], "errors") == 0) {
				int32_t errors = 0;
				if (st_ssd_query_i32(":1G!\r", '!', &errors))
					st_dbg_printf("[SSD] ERR=0x%04lX\r\n",
							(unsigned long) ((uint32_t) errors & 0xFFFFU));
				else
					st_dbg_printf("[SSD] no response to :1G!\r\n");
			} else if (strcmp(argv[1], "mode") == 0) {
				char buf[ST_SSD_RX_BUF_LEN] = { 0 };
				if (st_ssd_query_text(":1GM\r", buf, sizeof(buf)))
					st_dbg_printf("[SSD] MODE=%s\r\n", buf);
				else
					st_dbg_printf("[SSD] no response to :1GM\r\n");
			} else if (strcmp(argv[1], "baud") == 0) {
				char buf[ST_SSD_RX_BUF_LEN] = { 0 };
				if (st_ssd_query_text(":1GB\r", buf, sizeof(buf)))
					st_dbg_printf("[SSD] BAUD_CODE=%s\r\n", buf);
				else
					st_dbg_printf("[SSD] no response to :1GB\r\n");
			} else if (strcmp(argv[1], "delay") == 0) {
				char buf[ST_SSD_RX_BUF_LEN] = { 0 };
				if (st_ssd_query_text(":1GD\r", buf, sizeof(buf)))
					st_dbg_printf("[SSD] READ_DELAY_MS=%s\r\n", buf);
				else
					st_dbg_printf("[SSD] no response to :1GD\r\n");
			} else if (strcmp(argv[1], "raw") == 0) {
				if (argc >= 3)
					st_ssd_print_raw_cmd(argv[2]);
				else
					st_dbg_printf("usage: ssd raw :1VE\r\n");
			} else {
				st_dbg_printf("bad ssd command\r\n");
			}
		}
	} else if (st_str_eq_nocase(argv[0], "mcan") && argc >= 2) {
		if (st_str_eq_nocase(argv[1], "monitor") && argc >= 3) {
			g_mcan.monitor = st_str_eq_nocase(argv[2], "on");
			if (g_mcan.monitor && !g_mcan.online) (void)st_mcan_bus_config(true);
			st_dbg_printf("[MCAN] monitor=%u\r\n", g_mcan.monitor ? 1U : 0U);
		} else if (st_str_eq_nocase(argv[1], "hb") && argc >= 3) {
			if (st_str_eq_nocase(argv[2], "off")) {
				g_mcan.hb_enabled = false;
				st_dbg_printf("[MCAN] hb=0\r\n");
			} else if (st_str_eq_nocase(argv[2], "on")) {
				if (argc >= 4) g_mcan.hb_period_ms = (uint32_t)strtoul(argv[3], NULL, 0);
				if (g_mcan.hb_period_ms == 0U) g_mcan.hb_period_ms = ST_MCAN_DEFAULT_HB_MS;
				g_mcan.hb_enabled = true;
				if (!g_mcan.online) (void)st_mcan_bus_config(true);
				st_dbg_printf("[MCAN] hb=1 period=%lu ms\r\n", (unsigned long)g_mcan.hb_period_ms);
			} else {
				st_dbg_printf("bad mcan hb command\r\n");
			}
		} else if (st_str_eq_nocase(argv[1], "ping") && argc >= 3) {
			if (st_str_eq_nocase(argv[2], "once")) {
				st_mcan_start_ping(1U, ST_MCAN_DEFAULT_PING_MS, false, true);
				st_dbg_printf("[MCAN] ping once\r\n");
			} else if (st_str_eq_nocase(argv[2], "count") && argc >= 5) {
				uint32_t count = (uint32_t)strtoul(argv[3], NULL, 0);
				uint32_t period = (uint32_t)strtoul(argv[4], NULL, 0);
				st_mcan_start_ping(count, period, false, false);
				st_dbg_printf("[MCAN] ping count=%lu period=%lu ms\r\n", (unsigned long)count, (unsigned long)period);
			} else if (st_str_eq_nocase(argv[2], "cont") && argc >= 4) {
				uint32_t period = (uint32_t)strtoul(argv[3], NULL, 0);
				st_mcan_start_ping(0U, period, false, false);
				st_dbg_printf("[MCAN] ping cont period=%lu ms\r\n", (unsigned long)period);
			} else {
				st_dbg_printf("bad mcan ping command\r\n");
			}
		} else if (st_str_eq_nocase(argv[1], "pingboth") && argc >= 3) {
			if (st_str_eq_nocase(argv[2], "off")) {
				st_mcan_stop_ping();
				st_dbg_printf("[MCAN] pingboth off\r\n");
			} else if (st_str_eq_nocase(argv[2], "on")) {
				uint32_t period = (argc >= 4) ? (uint32_t)strtoul(argv[3], NULL, 0) : ST_MCAN_DEFAULT_PING_MS;
				st_mcan_start_ping(0U, period, true, false);
				st_dbg_printf("[MCAN] pingboth on period=%lu ms\r\n", (unsigned long)period);
			} else {
				st_dbg_printf("bad mcan pingboth command\r\n");
			}
		} else if (st_str_eq_nocase(argv[1], "status") && argc >= 3 && st_str_eq_nocase(argv[2], "req")) {
			uint8_t seq = ++g_mcan.next_seq;
			if (st_mcan_send_simple(ST_MCAN_ID_PDU_TO_RCU, ST_MCAN_TYPE_STATUS_REQ, seq, 0U, 0U, 0U)) {
				g_mcan.tx_req++;
				st_dbg_printf("[MCAN] status req seq=%u\r\n", seq);
			} else st_dbg_printf("[MCAN] status req failed\r\n");
		} else if (st_str_eq_nocase(argv[1], "led") && argc >= 4) {
			uint16_t count = (uint16_t)strtoul(argv[2], NULL, 0);
			uint16_t dwell = (uint16_t)strtoul(argv[3], NULL, 0);
			uint8_t seq = ++g_mcan.next_seq;
			if (st_mcan_send_simple(ST_MCAN_ID_PDU_TO_RCU, ST_MCAN_TYPE_LED_REQ, seq, 0U, count, dwell)) {
				g_mcan.tx_req++;
				st_dbg_printf("[MCAN] led req seq=%u count=%u dwell=%u\r\n", seq, count, dwell);
			} else st_dbg_printf("[MCAN] led req failed\r\n");
		} else if (st_str_eq_nocase(argv[1], "beep") && argc >= 4) {
			uint16_t hz = (uint16_t)strtoul(argv[2], NULL, 0);
			uint16_t ms = (uint16_t)strtoul(argv[3], NULL, 0);
			uint8_t seq = ++g_mcan.next_seq;
			if (st_mcan_send_simple(ST_MCAN_ID_PDU_TO_RCU, ST_MCAN_TYPE_BEEP_REQ, seq, 0U, hz, ms)) {
				g_mcan.tx_req++;
				st_dbg_printf("[MCAN] beep req seq=%u hz=%u ms=%u\r\n", seq, hz, ms);
			} else st_dbg_printf("[MCAN] beep req failed\r\n");
		} else if (st_str_eq_nocase(argv[1], "stats")) {
			st_mcan_print_stats();
		} else if (st_str_eq_nocase(argv[1], "clear")) {
			st_mcan_clear_stats_local();
			uint8_t seq = ++g_mcan.next_seq;
			if (st_mcan_send_simple(ST_MCAN_ID_PDU_TO_RCU, ST_MCAN_TYPE_CLEAR_STATS_REQ, seq, 0U, 0U, 0U)) {
				g_mcan.tx_req++;
				st_dbg_printf("[MCAN] local+remote clear req seq=%u\r\n", seq);
			} else {
				st_dbg_printf("[MCAN] local clear only\r\n");
			}
		} else if (st_str_eq_nocase(argv[1], "reset")) {
			g_mcan.monitor = false;
			g_mcan.hb_enabled = false;
			st_mcan_stop_ping();
			st_mcan_clear_stats_local();
			st_mcan_bus_disable();
			g_mcan.peer_online = false;
			g_mcan.last_peer_seen_ms = 0U;
			st_dbg_printf("[MCAN] reset\r\n");
		} else {
			st_dbg_printf("bad mcan command\r\n");
		}
	} else if (strcmp(argv[0], "set") == 0 && argc >= 3) {
		st_handle_set(argv[1], argv[2]);
	} else if (strcmp(argv[0], "beep") == 0 && argc >= 3) {
		uint32_t hz = (uint32_t) strtoul(argv[1], NULL, 0);
		uint32_t ms = (uint32_t) strtoul(argv[2], NULL, 0);
		st_buzzer_start(hz);
		HAL_Delay(ms);
		st_buzzer_off();
		st_dbg_printf("[BEEP] %lu Hz for %lu ms\r\n", (unsigned long) hz,
				(unsigned long) ms);
	} else {
		st_dbg_printf("unknown command\r\n");
	}
	st_prompt();
}

static void st_handle_uart_rx(void) {
	while (__HAL_UART_GET_FLAG(&ST_DBG_UART, UART_FLAG_RXNE) != RESET) {
		uint8_t ch = (uint8_t) (ST_DBG_UART.Instance->RDR & 0xFFU);
		if (ch == '\r' || ch == '\n') {
			st_dbg_printf("\r\n");
			g_cli_buf[g_cli_len] = '\0';
			st_process_line((char*) g_cli_buf);
			g_cli_len = 0U;
		} else if (ch == 0x08U || ch == 0x7FU) {
			if (g_cli_len > 0U) {
				g_cli_len--;
				st_dbg_printf("\b \b");
			}
		} else if (isprint((unsigned char )ch)
				&& g_cli_len < (ST_CLI_BUF_LEN - 1U)) {
			g_cli_buf[g_cli_len++] = ch;
			(void) HAL_UART_Transmit(&ST_DBG_UART, &ch, 1U, 10U);
		}
	}
}

void PDU_SelfTest_Init(void) {
	st_reset_all_tests();
	st_safe_outputs();
	st_dbg_printf("\r\n==================================================\r\n");
	st_dbg_printf("PDU SELFTEST %s\r\n", ST_VERSION);
	st_dbg_printf("UART CLI ready on UART4 @ 115200\r\n");
	st_dbg_printf("Call this init after MX_* peripheral init.\r\n");
	st_mcan_init();
	st_dbg_printf("Type 'help'\r\n");
	st_prompt();
}

void PDU_SelfTest_Task(void) {
	uint32_t now_ms = HAL_GetTick();
	st_handle_uart_rx();
	st_runner_poll(now_ms);
	st_monitor_poll(now_ms);
	st_mcan_poll(now_ms);
}
