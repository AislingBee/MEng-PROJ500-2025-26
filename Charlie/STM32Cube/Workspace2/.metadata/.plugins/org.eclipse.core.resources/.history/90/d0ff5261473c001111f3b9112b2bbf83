}

static void st_ssd_flush_rx(void) {
	uint32_t t0 = HAL_GetTick();

	__HAL_UART_CLEAR_OREFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_NEFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_FEFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_PEFLAG(&ST_RS485_UART);

	while ((HAL_GetTick() - t0) < 20U) {
		if (__HAL_UART_GET_FLAG(&ST_RS485_UART, UART_FLAG_RXNE) != RESET) {
			volatile uint8_t dump = (uint8_t) (ST_RS485_UART.Instance->RDR
					& 0xFFU);
			(void) dump;
			t0 = HAL_GetTick();
		}
	}

	__HAL_UART_CLEAR_OREFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_NEFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_FEFLAG(&ST_RS485_UART);
	__HAL_UART_CLEAR_PEFLAG(&ST_RS485_UART);
}

static bool st_ssd_send_cmd(const char *cmd) {
	st_ssd_flush_rx();

	HAL_StatusTypeDef st = HAL_UART_Transmit(&ST_RS485_UART, (uint8_t*) cmd,
			(uint16_t) strlen(cmd),
			ST_SSD_UART_TIMEOUT_MS);
	if (st != HAL_OK) {
		return false;
	}

	while (__HAL_UART_GET_FLAG(&ST_RS485_UART, UART_FLAG_TC) == RESET) {
	}

	return true;
}

static size_t st_ssd_read_capture(uint8_t *buf, size_t len, uint32_t timeout_ms) {
	if (buf == NULL || len == 0U)
		return 0U;

	size_t idx = 0U;
	uint8_t ch = 0U;
	uint32_t t0 = HAL_GetTick();
	bool got_any = false;

	while ((HAL_GetTick() - t0) < timeout_ms && idx < len) {
		if (HAL_UART_Receive(&ST_RS485_UART, &ch, 1U, 20U) == HAL_OK) {
			buf[idx++] = ch;
			got_any = true;
			t0 = HAL_GetTick();
		} else if (got_any) {
			if ((HAL_GetTick() - t0) > 50U) {
				break;
			}
		}
	}

	return idx;
}

static bool st_ssd_extract_last_line(const uint8_t *raw, size_t raw_len,
		char *line, size_t line_len) {
	if (line == NULL || line_len == 0U)
		return false;
	line[0] = '\0';

	size_t best_start = 0U, best_len = 0U;
	size_t cur_start = 0U, cur_len = 0U;

	for (size_t i = 0U; i < raw_len; ++i) {
		uint8_t ch = raw[i];
		if (ch == '\r' || ch == '\n') {
			if (cur_len > 0U) {
				best_start = cur_start;
				best_len = cur_len;
				cur_len = 0U;
			}
			cur_start = i + 1U;
		} else {
			if (cur_len == 0U)
				cur_start = i;
			cur_len++;
		}
	}
	if (cur_len > 0U) {
		best_start = cur_start;
		best_len = cur_len;
	}

	if (best_len == 0U)
		return false;
	if (best_len >= line_len)
		best_len = line_len - 1U;

	memcpy(line, &raw[best_start], best_len);
	line[best_len] = '\0';
	return true;
}

static bool st_ssd_read_line(char *buf, size_t len, uint32_t timeout_ms) {
	if (len == 0U)
		return false;

	size_t idx = 0U;
	uint8_t ch = 0U;
	uint32_t t0 = HAL_GetTick();
	bool got_any = false;

	while ((HAL_GetTick() - t0) < timeout_ms) {
		if (HAL_UART_Receive(&ST_RS485_UART, &ch, 1U, 20U) == HAL_OK) {
			got_any = true;

			if (ch == '\r' || ch == '\n') {
				if (idx == 0U) {
					continue;
				}
				break;
			}

			if (idx < (len - 1U)) {
				buf[idx++] = (char) ch;
			}

			t0 = HAL_GetTick();
		}
	}

	buf[idx] = '\0';
	return got_any && (idx > 0U);
}

static bool st_ssd_query_text(const char *cmd, char *buf, size_t len) {
	uint8_t raw[ST_SSD_RX_BUF_LEN];

	if (buf == NULL || len == 0U)
		return false;
	buf[0] = '\0';

	if (!st_ssd_send_cmd(cmd))
		return false;

	size_t n = st_ssd_read_capture(raw, sizeof(raw), ST_SSD_RAW_TIMEOUT_MS);
	if (n == 0U)
		return false;

	return st_ssd_extract_last_line(raw, n, buf, len);
}

static bool st_ssd_query_i32(const char *cmd, char expected_prefix,
		int32_t *value) {
	char buf[ST_SSD_RX_BUF_LEN];
	char num[24];
	size_t ni = 0U;
	bool started = false;

	if (!st_ssd_query_text(cmd, buf, sizeof(buf)))
		return false;
	if (buf[0] != expected_prefix)
		return false;

	for (size_t i = 1U; buf[i] != '\0' && ni < (sizeof(num) - 1U); ++i) {
		char c = buf[i];
		if (!started) {
			if (c == '-' || c == '+' || isdigit((unsigned char )c)) {
				num[ni++] = c;
				started = true;
			}
		} else {
			if (isdigit((unsigned char )c)) {
				num[ni++] = c;
			} else {
				break;
			}
		}
	}
	num[ni] = '\0';
	if (ni == 0U)
		return false;
	*value = (int32_t) strtol(num, NULL, 10);
	return true;
}

static void st_ssd_print_readings(void) {
	int32_t current_ma = 0;
	int32_t vbus_mv = 0;
	int32_t temp_dC = 0;
	int32_t power_dW = 0;
	int32_t errors = 0;

	bool ok_i = st_ssd_query_i32(":1GA\r", 'A', &current_ma);
	HAL_Delay(20U);
	bool ok_v = st_ssd_query_i32(":1GV\r", 'V', &vbus_mv);
	HAL_Delay(20U);
	bool ok_t = st_ssd_query_i32(":1GT\r", 'T', &temp_dC);
	HAL_Delay(20U);
	bool ok_p = st_ssd_query_i32(":1GP\r", 'P', &power_dW);
	HAL_Delay(20U);
	bool ok_e = st_ssd_query_i32(":1G!\r", '!', &errors);

	if (!(ok_i && ok_v && ok_t && ok_p && ok_e)) {
		st_dbg_printf("[SSD] read failed (I=%u V=%u T=%u P=%u E=%u)\r\n",
				ok_i ? 1U : 0U, ok_v ? 1U : 0U, ok_t ? 1U : 0U, ok_p ? 1U : 0U,
				ok_e ? 1U : 0U);
		return;
	}

	st_dbg_printf(
			"[SSD] I=%.3f A  V=%.3f V  T=%.1f C  P=%.1f W  ERR=0x%04lX\r\n",
			current_ma / 1000.0f, vbus_mv / 1000.0f, temp_dC / 10.0f,
			power_dW / 10.0f, (unsigned long) ((uint32_t) errors & 0xFFFFU));
}

static void st_ssd_print_raw_cmd(const char *cmd_in) {
	char cmd[32];
	uint8_t raw[ST_SSD_RX_BUF_LEN];
	size_t n;

	if (cmd_in == NULL || cmd_in[0] == '\0') {
		st_dbg_printf("[SSD] raw requires command text, e.g. ssd raw :1VE\r\n");
		return;
	}

	if (strchr(cmd_in, '\r') || strchr(cmd_in, '\n')) {
		snprintf(cmd, sizeof(cmd), "%s", cmd_in);
	} else {
		snprintf(cmd, sizeof(cmd), "%s\r", cmd_in);
	}

	if (!st_ssd_send_cmd(cmd)) {
		st_dbg_printf("[SSD] TX failed\r\n");
		return;
	}

	n = st_ssd_read_capture(raw, sizeof(raw), ST_SSD_RAW_TIMEOUT_MS);
	st_dbg_printf("[SSD] TX=\"%s\" RX_LEN=%lu\r\n", cmd, (unsigned long) n);
	st_dbg_printf("[SSD] RX_HEX:");
	for (size_t i = 0U; i < n; ++i)
		st_dbg_printf(" %02X", raw[i]);
	st_dbg_printf("\r\n");
	st_dbg_printf("[SSD] RX_ASCII=\"");
	for (size_t i = 0U; i < n; ++i) {
		uint8_t ch = raw[i];
		if (ch == '\r')
			st_dbg_printf("<CR>");
		else if (ch == '\n')
			st_dbg_printf("<LF>");
		else if (isprint((unsigned char )ch))
			st_dbg_printf("%c", ch);
		else
			st_dbg_printf(".");
	}
	st_dbg_printf("\"\r\n");
}

static void st_ssd_discover_ascii(void) {
	static const uint32_t baud_list[ST_SSD_DISCOVER_BAUD_COUNT] = { 9600U,
			14400U, 19200U, 38400U, 57600U, 115200U };
	char cmd[16];
	char resp[ST_SSD_RX_BUF_LEN];
	bool found = false;

	st_dbg_printf("[SSD] ASCII discover start\r\n");

	for (size_t bi = 0U; bi < ST_SSD_DISCOVER_BAUD_COUNT; ++bi) {
		uint32_t baud = baud_list[bi];
		if (!st_ssd_uart_apply(baud, UART_STOPBITS_1)) {
			st_dbg_printf("[SSD] baud %lu init failed\r\n",
					(unsigned long) baud);
			continue;
		}

		for (uint32_t addr = 1U; addr <= ST_SSD_SCAN_ADDR_MAX; ++addr) {
			snprintf(cmd, sizeof(cmd), ":%luVE\r", (unsigned long) addr);
			if (st_ssd_query_text(cmd, resp, sizeof(resp))) {
				found = true;
				st_dbg_printf("[SSD] ASCII hit: baud=%lu addr=%lu VE=%s\r\n",
						(unsigned long) baud, (unsigned long) addr, resp);

				snprintf(cmd, sizeof(cmd), ":%luGM\r", (unsigned long) addr);
				if (st_ssd_query_text(cmd, resp, sizeof(resp)))
					st_dbg_printf("[SSD]   GM=%s\r\n", resp);

				snprintf(cmd, sizeof(cmd), ":%luGB\r", (unsigned long) addr);
				if (st_ssd_query_text(cmd, resp, sizeof(resp)))
					st_dbg_printf("[SSD]   GB=%s\r\n", resp);
			}
		}
	}

	if (!found)
		st_dbg_printf("[SSD] ASCII discover found nothing\r\n");

	(void) st_ssd_uart_apply_defaults();
}

static uint16_t st_modbus_crc16(const uint8_t *data, size_t len) {
	uint16_t crc = 0xFFFFU;
	for (size_t i = 0U; i < len; ++i) {
		crc ^= data[i];
		for (uint8_t b = 0U; b < 8U; ++b) {
			if (crc & 1U)
				crc = (uint16_t) ((crc >> 1) ^ 0xA001U);
			else
				crc >>= 1;
		}
	}
	return crc;
}

static bool st_ssd_modbus_probe_once(uint8_t addr, uint32_t baud,
		uint16_t *fw_reg, uint16_t *mode_reg, uint16_t *baud_reg) {
	uint8_t req[8];
	uint8_t rx[32];
	size_t n;
	uint16_t crc;

	if (!st_ssd_uart_apply(baud, UART_STOPBITS_2))
		return false;

	req[0] = addr;
	req[1] = 0x04U;
	req[2] = 0x00U;
	req[3] = 17U;
	req[4] = 0x00U;
	req[5] = 0x01U;
	crc = st_modbus_crc16(req, 6U);
	req[6] = (uint8_t) (crc & 0xFFU);
	req[7] = (uint8_t) (crc >> 8);

	st_ssd_flush_rx();
	st_rs485_de_set(true);
	HAL_Delay(2U);
	if (HAL_UART_Transmit(&ST_RS485_UART, req, sizeof(req),
			ST_SSD_UART_TIMEOUT_MS) != HAL_OK) {
		st_rs485_de_set(false);
		return false;
	}
	HAL_Delay(5U);
	st_rs485_de_set(false);
	HAL_Delay(10U);

	n = st_ssd_read_capture(rx, sizeof(rx), ST_SSD_RAW_TIMEOUT_MS);
	if (n < 7U)
		return false;
	if (rx[0] != addr || rx[1] != 0x04U || rx[2] != 0x02U)
		return false;
	crc = st_modbus_crc16(rx, n - 2U);
	if (rx[n - 2U] != (uint8_t) (crc & 0xFFU)
			|| rx[n - 1U] != (uint8_t) (crc >> 8))
		return false;
	if (fw_reg)
		*fw_reg = (uint16_t) (((uint16_t) rx[3] << 8) | rx[4]);

	req[0] = addr;
	req[1] = 0x03U;
	req[2] = 0x00U;
	req[3] = 2U;
	req[4] = 0x00U;
	req[5] = 0x01U;
	crc = st_modbus_crc16(req, 6U);
	req[6] = (uint8_t) (crc & 0xFFU);
	req[7] = (uint8_t) (crc >> 8);
	st_ssd_flush_rx();
	st_rs485_de_set(true);
	HAL_Delay(2U);
	if (HAL_UART_Transmit(&ST_RS485_UART, req, sizeof(req),
			ST_SSD_UART_TIMEOUT_MS) != HAL_OK) {
		st_rs485_de_set(false);
		return false;
	}
	HAL_Delay(5U);
	st_rs485_de_set(false);
	HAL_Delay(10U);
	n = st_ssd_read_capture(rx, sizeof(rx), ST_SSD_RAW_TIMEOUT_MS);
	if (n >= 7U && rx[0] == addr && rx[1] == 0x03U && rx[2] == 0x02U) {
		crc = st_modbus_crc16(rx, n - 2U);
		if (rx[n - 2U] == (uint8_t) (crc & 0xFFU)
				&& rx[n - 1U] == (uint8_t) (crc >> 8) && mode_reg)
			*mode_reg = (uint16_t) (((uint16_t) rx[3] << 8) | rx[4]);
	}

	req[0] = addr;
	req[1] = 0x03U;
	req[2] = 0x00U;
	req[3] = 4U;
	req[4] = 0x00U;
	req[5] = 0x01U;
	crc = st_modbus_crc16(req, 6U);
	req[6] = (uint8_t) (crc & 0xFFU);
	req[7] = (uint8_t) (crc >> 8);
	st_ssd_flush_rx();
	st_rs485_de_set(true);
	HAL_Delay(2U);
	if (HAL_UART_Transmit(&ST_RS485_UART, req, sizeof(req),
			ST_SSD_UART_TIMEOUT_MS) != HAL_OK) {
		st_rs485_de_set(false);
		return true;
	}
	HAL_Delay(5U);
	st_rs485_de_set(false);
	HAL_Delay(10U);
	n = st_ssd_read_capture(rx, sizeof(rx), ST_SSD_RAW_TIMEOUT_MS);
	if (n >= 7U && rx[0] == addr && rx[1] == 0x03U && rx[2] == 0x02U) {
		crc = st_modbus_crc16(rx, n - 2U);
		if (rx[n - 2U] == (uint8_t) (crc & 0xFFU)
				&& rx[n - 1U] == (uint8_t) (crc >> 8) && baud_reg)
			*baud_reg = (uint16_t) (((uint16_t) rx[3] << 8) | rx[4]);
	}

	return true;
}

static void st_ssd_modbus_probe(void) {
	static const uint32_t baud_list[ST_SSD_DISCOVER_BAUD_COUNT] = { 9600U,
			14400U, 19200U, 38400U, 57600U, 115200U };
	bool found = false;

	st_dbg_printf("[SSD] MODBUS probe start\r\n");

	for (size_t bi = 0U; bi < ST_SSD_DISCOVER_BAUD_COUNT; ++bi) {
		uint32_t baud = baud_list[bi];
		for (uint32_t addr = 1U; addr <= ST_SSD_SCAN_ADDR_MAX; ++addr) {
			uint16_t fw = 0U, mode = 0xFFFFU, br = 0xFFFFU;
			if (st_ssd_modbus_probe_once((uint8_t) addr, baud, &fw, &mode,
					&br)) {
				found = true;
				st_dbg_printf(
						"[SSD] MODBUS hit: baud=%lu addr=%lu FW=0x%04X MODE=0x%04X BAUD=%u\r\n",
						(unsigned long) baud, (unsigned long) addr, fw, mode,
						br);
			}
		}
	}

	if (!found)
		st_dbg_printf("[SSD] MODBUS probe found nothing\r\n");

	(void) st_ssd_uart_apply_defaults();
}

static bool st_adc_write_reg(uint8_t reg, uint8_t value) {
	uint8_t tx[3] = { ST_TLA_OP_SINGLE_WRITE, reg, value };
	return HAL_I2C_Master_Transmit(&ST_I2C, ST_ADC_ADDR_8BIT, tx, sizeof(tx),
			ST_I2C_TIMEOUT_MS) == HAL_OK;
}

static bool st_adc_read_reg(uint8_t reg, uint8_t *value) {
	uint8_t tx[2] = { ST_TLA_OP_SINGLE_READ, reg };
	if (HAL_I2C_Master_Transmit(&ST_I2C, ST_ADC_ADDR_8BIT, tx, sizeof(tx),
			ST_I2C_TIMEOUT_MS) != HAL_OK)
		return false;
	return HAL_I2C_Master_Receive(&ST_I2C, ST_ADC_ADDR_8BIT, value, 1U,
			ST_I2C_TIMEOUT_MS) == HAL_OK;
}

static bool st_adc_ping(uint8_t *sys_status) {
	return st_adc_read_reg(ST_TLA_REG_SYSTEM_STATUS, sys_status);
}

static bool st_adc_init_analog_defaults(void) {
	if (!st_adc_write_reg(ST_TLA_REG_PIN_CFG, 0x00U))
		return false;
	if (!st_adc_write_reg(ST_TLA_REG_DATA_CFG, 0x00U))
		return false;
	if (!st_adc_write_reg(ST_TLA_REG_OSR_CFG, 0x00U))
		return false;
	if (!st_adc_write_reg(ST_TLA_REG_OPMODE_CFG, 0x00U))
		return false;
	return true;
}

static bool st_adc_read_channel12(uint8_t ch, uint16_t *raw12) {
	uint8_t rx[2] = { 0, 0 };
	if (ch > 7U)
		return false;
	if (!st_adc_write_reg(ST_TLA_REG_CHANNEL_SEL, ch & 0x0FU))
		return false;
	if (HAL_I2C_Master_Receive(&ST_I2C, ST_ADC_ADDR_8BIT, rx, sizeof(rx),
			ST_I2C_TIMEOUT_MS) != HAL_OK)
		return false;
	*raw12 = (uint16_t) (((uint16_t) rx[0] << 4) | ((uint16_t) rx[1] >> 4));
	return true;
}

static bool st_adc_read_all(st_adc_sample_t samples[8]) {
	if (!st_adc_init_analog_defaults())
		return false;
	for (uint8_t i = 0U; i < 8U; ++i) {
		if (!st_adc_read_channel12(i, &samples[i].raw12))
			return false;
		samples[i].vadc = st_raw_to_vadc(samples[i].raw12, 12U);
		samples[i].eng = g_adc_info[i].convert(samples[i].raw12, 12U);
		if ((i == 6U || i == 7U) && !isnan(samples[i].eng)) {
			samples[i].eng = st_therm_apply_cal(samples[i].eng);
		}
	}
	return true;
}

