static st_status_t test_gpio_poll(uint32_t now_ms, char *detail,
		size_t detail_len) {
	(void) detail;
	(void) detail_len;
	if (now_ms < g_gpio_test.next_ms)
		return STS_RUNNING;
	if (g_gpio_test.toggles >= 8U) {
		st_led_all_off();
		return STS_PASS;
	}
	if ((g_gpio_test.toggles & 1U) == 0U) {
		st_led_set(0U, true);
		st_led_set(1U, false);
	} else {
		st_led_set(0U, false);
		st_led_set(1U, true);
	}
	g_gpio_test.toggles++;
	g_gpio_test.next_ms = now_ms + (g_rt.loop_fast ? 40U : ST_GPIO_DWELL_MS);
	return STS_RUNNING;
}

static void test_buzzer_reset(void) {
	memset(&g_buzzer_test, 0, sizeof(g_buzzer_test));
	st_buzzer_off();
}
