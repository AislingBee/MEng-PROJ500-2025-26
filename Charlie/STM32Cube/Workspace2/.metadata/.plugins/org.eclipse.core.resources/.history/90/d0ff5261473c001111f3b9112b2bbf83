static void st_dbg_printf(const char *fmt, ...) {
	char buf[256];
	va_list ap;
	va_start(ap, fmt);
	int n = vsnprintf(buf, sizeof(buf), fmt, ap);
	va_end(ap);
	if (n > 0) {
		if (n > (int) sizeof(buf))
			n = (int) sizeof(buf);
		(void) HAL_UART_Transmit(&ST_DBG_UART, (uint8_t*) buf, (uint16_t) n,
				200U);
	}
}

