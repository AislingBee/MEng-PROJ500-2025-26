#!/usr/bin/env python3
"""
rcu_bench_gui.py — RCU bench monitoring GUI
Requires: pip install customtkinter matplotlib

Usage:
  python rcu_bench_gui.py [--rcu-ip 192.168.100.10]

Tabs: Overview | PDU | IMU | Motors | Log
"""

import argparse
import collections
import math
import socket
import struct
import threading
import time
import tkinter as tk
from tkinter import ttk

import customtkinter as ctk
import matplotlib
matplotlib.use("TkAgg")
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg
from matplotlib.figure import Figure

# ---------------------------------------------------------------------------
# One Dark palette
# ---------------------------------------------------------------------------
BG      = "#1e2229"
PANEL   = "#282c34"
ACCENT  = "#61afef"
OK      = "#98c379"
WARN    = "#e5c07b"
ERROR   = "#e06c75"
TEXT    = "#abb2bf"
DIM     = "#5c6370"
WHITE   = "#ffffff"

ctk.set_appearance_mode("dark")
ctk.set_default_color_theme("blue")

# ---------------------------------------------------------------------------
# Protocol (must match rcu_pkt.h)
# ---------------------------------------------------------------------------
PKT_MAGIC       = 0x5243
HDR_FMT         = "<HBBH"
HDR_SIZE        = struct.calcsize(HDR_FMT)

PKT_TELEM       = 0x01
PKT_MOTOR_FB    = 0x02
PKT_DEBUG_CMD   = 0x20
PKT_DEBUG_REPLY = 0x21
PKT_MOTOR_CMD   = 0x10

TELEM_FMT  = "<6BH8h4h6h7h7h"
TELEM_SIZE = struct.calcsize(TELEM_FMT)

FB_HEADER_SIZE = 1
FB_SLOT_FMT    = "<BBHHHBx"
FB_SLOT_SIZE   = struct.calcsize(FB_SLOT_FMT)
FB_SLOTS       = 16

DBGCMD_PING         = 0x01
DBGCMD_BUZZ         = 0x02
DBGCMD_LED_BLINK    = 0x03
DBGCMD_CAN_LOOPBACK = 0x04
DBGCMD_FORCE_TELEM  = 0x05

PORT_TELEM  = 7700
PORT_CMD    = 7701

RCU_IP_DEFAULT = "192.168.100.10"

# IMU scale factors (LSM6DSOX, ±4g / ±500dps)
IMU_ACCEL_G_PER_LSB  = 0.000122
IMU_GYRO_DPS_PER_LSB = 0.0175
IMU_TEMP_SCALE       = 1.0 / 256.0
IMU_TEMP_OFFSET_C    = 25.0

RS04_POS_MAX = 12.57
RS04_VEL_MAX = 15.0
RS04_TRQ_MAX = 120.0
RS04_KP_MAX  = 5000.0
RS04_KD_MAX  = 100.0

HISTORY_LEN  = 300   # ~30 s at 10 Hz

FPGA_STATES  = {0: "IDLE", 1: "PRECHARGE", 2: "ARMED", 3: "COMPUTE"}
S0_BITS      = [(0,"FAULT_LATCH"),(1,"PCHG_LATCH"),(2,"MOTOR_EN"),
                (3,"COMPUTE_EN"),(6,"OVUV_OK"),(7,"ARM_PERMIT")]
IN_BITS      = [(1,"REMOTE_ARM"),(2,"ESTOP_OK"),(3,"MCU_ARM_SEEN")]

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
def u16_to_f(v, lo, hi):
    return lo + (v / 65535.0) * (hi - lo)

def f_to_u16(v, lo, hi):
    v = max(lo, min(hi, v))
    return int((v - lo) / (hi - lo) * 65535 + 0.5)

def decode_bits(val, bit_defs):
    active = [name for (bit, name) in bit_defs if (val >> bit) & 1]
    return " | ".join(active) if active else "none"


# ---------------------------------------------------------------------------
# Thread-safe state
# ---------------------------------------------------------------------------
class RcuState:
    def __init__(self):
        self._lock = threading.Lock()

        # Connection
        self.connected     = False
        self.rcu_ip        = RCU_IP_DEFAULT
        self.pkt_count     = 0
        self.telem_count   = 0
        self.seq_gaps      = 0
        self._last_seq     = -1
        self._t0           = time.monotonic()
        self._pkt_ts_deque = collections.deque(maxlen=50)  # for pkt/s calc

        # Telem
        self.telem_age_ms  = 9999
        self._last_telem_t = 0.0
        self.t             = {}   # raw decoded telem dict

        # Motor FB
        self.motor_slots   = []   # list of slot dicts

        # Debug reply (last ping)
        self.last_ping     = {}

        # Plot history deques (filled with 0.0 on creation)
        def _dq():
            return collections.deque([0.0]*HISTORY_LEN, maxlen=HISTORY_LEN)

        self.h_vraw        = _dq()
        self.h_v12         = _dq()
        self.h_v24         = _dq()
        self.h_imu0_mag    = _dq()
        self.h_imu1_mag    = _dq()

    # ------------------------------------------------------------------
    def update_telem(self, t):
        with self._lock:
            now = time.monotonic()
            self._last_telem_t = now
            self.telem_count  += 1
            self.t = dict(t)

            self.h_vraw.append(t.get("v_vraw_v",    0.0))
            self.h_v12.append( t.get("v_12v_mv", 0) / 1000.0)
            self.h_v24.append( t.get("v_24v_mv", 0) / 1000.0)

            a0 = math.sqrt(t.get("imu0_ax_g",0)**2 +
                           t.get("imu0_ay_g",0)**2 +
                           t.get("imu0_az_g",0)**2)
            a1 = math.sqrt(t.get("imu1_ax_g",0)**2 +
                           t.get("imu1_ay_g",0)**2 +
                           t.get("imu1_az_g",0)**2)
            self.h_imu0_mag.append(a0)
            self.h_imu1_mag.append(a1)

    def bump_pkt(self, seq):
        with self._lock:
            self.pkt_count += 1
            self._pkt_ts_deque.append(time.monotonic())
            if self._last_seq >= 0:
                gap = (seq - self._last_seq - 1) & 0xFF
                self.seq_gaps += gap
            self._last_seq = seq

    def pkts_per_sec(self):
        with self._lock:
            now = time.monotonic()
            recent = [t for t in self._pkt_ts_deque if now - t <= 1.0]
            return len(recent)

    def telem_age(self):
        with self._lock:
            if self._last_telem_t == 0.0:
                return 9999
            return int((time.monotonic() - self._last_telem_t) * 1000)

    def get_telem(self):
        with self._lock:
            return dict(self.t)

    def get_motor_slots(self):
        with self._lock:
            return list(self.motor_slots)

    def update_motor_fb(self, slots):
        with self._lock:
            self.motor_slots = slots

    def update_ping(self, reply):
        with self._lock:
            self.last_ping = dict(reply)

    def set_connected(self, v):
        with self._lock:
            self.connected = v

    def is_connected(self):
        with self._lock:
            return self.connected

    def get_history(self, name):
        with self._lock:
            d = getattr(self, name, None)
            if d is None:
                return []
            return list(d)


# ---------------------------------------------------------------------------
# UDP receiver thread
# ---------------------------------------------------------------------------
class RcuReceiver(threading.Thread):
    def __init__(self, state: RcuState):
        super().__init__(daemon=True)
        self.rcu     = state
        self._stop   = threading.Event()
        self._sock   = None

    def stop(self):
        self._stop.set()
        if self._sock:
            try:
                self._sock.close()
            except Exception:
                pass

    def run(self):
        while not self._stop.is_set():
            try:
                self._sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                self._sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                self._sock.bind(("0.0.0.0", PORT_TELEM))
                self._sock.settimeout(1.0)
                self.rcu.set_connected(True)

                while not self._stop.is_set():
                    try:
                        data, _ = self._sock.recvfrom(4096)
                    except socket.timeout:
                        continue
                    except OSError:
                        break
                    self._process(data)

            except Exception:
                pass
            finally:
                self.rcu.set_connected(False)
                try:
                    self._sock.close()
                except Exception:
                    pass
            if not self._stop.is_set():
                time.sleep(1.0)

    def _process(self, data):
        if len(data) < HDR_SIZE:
            return
        magic, pkt_type, seq, plen = struct.unpack_from(HDR_FMT, data, 0)
        if magic != PKT_MAGIC:
            return
        payload = data[HDR_SIZE: HDR_SIZE + plen]
        self.rcu.bump_pkt(seq)

        if pkt_type == PKT_TELEM:
            t = _decode_telem(payload)
            if t:
                self.rcu.update_telem(t)

        elif pkt_type == PKT_MOTOR_FB:
            slots = _decode_motor_fb(payload)
            self.rcu.update_motor_fb(slots)

        elif pkt_type == PKT_DEBUG_REPLY:
            r = _decode_debug_reply(payload)
            if r:
                self.rcu.update_ping(r)


# ---------------------------------------------------------------------------
# Packet decoders
# ---------------------------------------------------------------------------
def _decode_telem(payload):
    if len(payload) < TELEM_SIZE:
        return None
    f = struct.unpack_from(TELEM_FMT, payload)
    (s0, fc, sc, act, inp, ver, pchg_ms,
     v_vraw_dv, v_12v, v_24v, i_vraw_sw, i_12v, i_24v, th1, th2,
     em_i, em_v, em_p, em_t,
     lt0, lt1, lt2, lvsrc, lvbus, licoil,
     a0x, a0y, a0z, g0x, g0y, g0z, t0,
     a1x, a1y, a1z, g1x, g1y, g1z, t1) = f

    return dict(
        fpga_sts0=s0, fpga_fc=fc, fpga_sc=sc, fpga_act=act,
        fpga_inputs=inp, fpga_version=ver, fpga_pchg_ms=pchg_ms,
        v_vraw_v=v_vraw_dv / 100.0,
        v_12v_mv=v_12v, v_24v_mv=v_24v,
        i_vraw_sw_ma=i_vraw_sw, i_12v_ma=i_12v, i_24v_ma=i_24v,
        therm1_c=th1 * 0.1, therm2_c=th2 * 0.1,
        em_i_ma=em_i, em_v_mv=em_v, em_p_w=em_p * 0.1, em_t_c=em_t * 0.1,
        ladc_therm0_c=lt0 * 0.1, ladc_therm1_c=lt1 * 0.1, ladc_therm2_c=lt2 * 0.1,
        ladc_vsource_v=lvsrc / 1000.0, ladc_vbus_v=lvbus / 1000.0,
        ladc_icoil_ma=licoil,
        imu0_ax_g=a0x * IMU_ACCEL_G_PER_LSB, imu0_ay_g=a0y * IMU_ACCEL_G_PER_LSB,
        imu0_az_g=a0z * IMU_ACCEL_G_PER_LSB,
        imu0_gx_dps=g0x * IMU_GYRO_DPS_PER_LSB, imu0_gy_dps=g0y * IMU_GYRO_DPS_PER_LSB,
        imu0_gz_dps=g0z * IMU_GYRO_DPS_PER_LSB,
        imu0_temp_c=t0 * IMU_TEMP_SCALE + IMU_TEMP_OFFSET_C,
        imu1_ax_g=a1x * IMU_ACCEL_G_PER_LSB, imu1_ay_g=a1y * IMU_ACCEL_G_PER_LSB,
        imu1_az_g=a1z * IMU_ACCEL_G_PER_LSB,
        imu1_gx_dps=g1x * IMU_GYRO_DPS_PER_LSB, imu1_gy_dps=g1y * IMU_GYRO_DPS_PER_LSB,
        imu1_gz_dps=g1z * IMU_GYRO_DPS_PER_LSB,
        imu1_temp_c=t1 * IMU_TEMP_SCALE + IMU_TEMP_OFFSET_C,
    )


def _decode_motor_fb(payload):
    if len(payload) < FB_HEADER_SIZE:
        return []
    (count,) = struct.unpack_from("<B", payload, 0)
    slots = []
    off   = FB_HEADER_SIZE
    for _ in range(min(count, FB_SLOTS)):
        if off + FB_SLOT_SIZE > len(payload):
            break
        bus, mid, pos_u16, vel_u16, trq_u16, err = struct.unpack_from(FB_SLOT_FMT, payload, off)
        off += FB_SLOT_SIZE
        slots.append(dict(
            bus=bus, motor_id=mid,
            pos_rad=u16_to_f(pos_u16, -RS04_POS_MAX, RS04_POS_MAX),
            vel_rads=u16_to_f(vel_u16, -RS04_VEL_MAX, RS04_VEL_MAX),
            torque_nm=u16_to_f(trq_u16, -RS04_TRQ_MAX, RS04_TRQ_MAX),
            error=err,
        ))
    return slots


DBG_REPLY_FMT  = "<II6Bxx I"
DBG_REPLY_SIZE = struct.calcsize(DBG_REPLY_FMT)

def _decode_debug_reply(payload):
    if len(payload) < DBG_REPLY_SIZE:
        return None
    (uptime, boot_rsr,
     imu0_v, imu1_v, fpga_v, rails_v, ssd_v, can_lb,
     hb_age) = struct.unpack_from(DBG_REPLY_FMT, payload)
    return dict(
        uptime_ms=uptime, boot_rsr=boot_rsr,
        imu0_ok=bool(imu0_v), imu1_ok=bool(imu1_v),
        fpga_ok=bool(fpga_v), rails_ok=bool(rails_v), em_ok=bool(ssd_v),
        can_lb=can_lb,
        hb_age_ms=hb_age,
    )


# ---------------------------------------------------------------------------
# Command sender (fire-and-forget from any thread)
# ---------------------------------------------------------------------------
_seq_lock = threading.Lock()
_seq_val  = 0

def _next_seq():
    global _seq_val
    with _seq_lock:
        v = _seq_val
        _seq_val = (_seq_val + 1) & 0xFF
        return v

def send_debug_cmd(rcu_ip, subcmd):
    seq = _next_seq()
    hdr = struct.pack(HDR_FMT, PKT_MAGIC, PKT_DEBUG_CMD, seq, 1)
    data = hdr + bytes([subcmd])
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        sock.sendto(data, (rcu_ip, PORT_CMD))
    finally:
        sock.close()

def send_motor_cmd(rcu_ip, bus, motor_id, pos, vel, trq, kp, kd):
    pos_u16 = f_to_u16(pos, -RS04_POS_MAX, RS04_POS_MAX)
    vel_u16 = f_to_u16(vel, -RS04_VEL_MAX, RS04_VEL_MAX)
    trq_u16 = f_to_u16(trq, -RS04_TRQ_MAX, RS04_TRQ_MAX)
    kp_u8   = int(max(0, min(255, (kp / RS04_KP_MAX) * 255)))
    kd_u8   = int(max(0, min(255, (kd / RS04_KD_MAX) * 255)))
    entry = struct.pack("<BBHHHBBxx", bus, motor_id, pos_u16, vel_u16, trq_u16, kp_u8, kd_u8)
    seq   = _next_seq()
    hdr   = struct.pack(HDR_FMT, PKT_MAGIC, PKT_MOTOR_CMD, seq, len(entry))
    data  = hdr + entry
    sock  = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        sock.sendto(data, (rcu_ip, PORT_CMD))
    finally:
        sock.close()


# ---------------------------------------------------------------------------
# Matplotlib helpers
# ---------------------------------------------------------------------------
def _make_fig(nrows=1, ncols=1, figsize=(7, 2.5)):
    fig = Figure(figsize=figsize, facecolor=BG)
    axs = []
    for i in range(nrows * ncols):
        ax = fig.add_subplot(nrows, ncols, i + 1)
        ax.set_facecolor(PANEL)
        ax.tick_params(colors=TEXT, labelsize=8)
        ax.xaxis.label.set_color(TEXT)
        ax.yaxis.label.set_color(TEXT)
        for spine in ax.spines.values():
            spine.set_edgecolor(DIM)
        ax.grid(True, color="#3d3f43", linewidth=0.5)
        axs.append(ax)
    fig.tight_layout(pad=1.0)
    return fig, axs


def _embed_fig(fig, parent):
    canvas = FigureCanvasTkAgg(fig, master=parent)
    canvas.draw()
    canvas.get_tk_widget().pack(fill="both", expand=True)
    return canvas


def _color_label(val, lo_warn, hi_warn, lo_err=None, hi_err=None):
    """Return foreground colour based on value thresholds."""
    if lo_err is not None and val <= lo_err:
        return ERROR
    if hi_err is not None and val >= hi_err:
        return ERROR
    if val <= lo_warn or val >= hi_warn:
        return WARN
    return OK


# ---------------------------------------------------------------------------
# GUI helper: labeled value row
# ---------------------------------------------------------------------------
def _lv_row(parent, label, row, col=0, colspan=1, width=120):
    """Return a CTkLabel for 'label' and a CTkLabel for the value."""
    lbl = ctk.CTkLabel(parent, text=label, anchor="w",
                       text_color=DIM, font=("Consolas", 11))
    lbl.grid(row=row, column=col, sticky="w", padx=(8,2), pady=1)
    val = ctk.CTkLabel(parent, text="---", anchor="w",
                       text_color=TEXT, font=("Consolas", 11), width=width)
    val.grid(row=row, column=col+1, columnspan=colspan,
             sticky="w", padx=(0,8), pady=1)
    return val


def _status_dot(parent, row, col=0):
    """Return a label used as a coloured status indicator."""
    dot = ctk.CTkLabel(parent, text="\u25cf", font=("Consolas", 14),
                       text_color=DIM)
    dot.grid(row=row, column=col, padx=(8,2), pady=1, sticky="w")
    return dot


# ---------------------------------------------------------------------------
# Main Application
# ---------------------------------------------------------------------------
class App(ctk.CTk):
    def __init__(self, rcu_ip: str):
        super().__init__()
        self.title("RCU Bench Monitor")
        self.geometry("1200x780")
        self.configure(fg_color=BG)

        self.rcu_ip  = rcu_ip
        self.rcu   = RcuState()
        self.rcu.rcu_ip = rcu_ip
        self._recv   = None
        self._log_lines = collections.deque(maxlen=500)

        self._build_topbar()
        self._build_tabs()
        self._start_receiver()
        self.after(100, self._update_loop)

    # ------------------------------------------------------------------
    # Top bar
    # ------------------------------------------------------------------
    def _build_topbar(self):
        bar = ctk.CTkFrame(self, fg_color=PANEL, height=44, corner_radius=0)
        bar.pack(fill="x", side="top")
        bar.pack_propagate(False)

        ctk.CTkLabel(bar, text="RCU IP:", text_color=DIM,
                     font=("Consolas", 11)).pack(side="left", padx=(12,2))
        self._ip_var = ctk.StringVar(value=self.rcu_ip)
        self._ip_entry = ctk.CTkEntry(bar, textvariable=self._ip_var,
                                      width=140, font=("Consolas", 12))
        self._ip_entry.pack(side="left", padx=(0,8))

        self._conn_btn = ctk.CTkButton(bar, text="Reconnect", width=100,
                                       command=self._reconnect,
                                       fg_color=ACCENT, hover_color="#4d9bd4",
                                       font=("Consolas", 11))
        self._conn_btn.pack(side="left", padx=(0,12))

        self._conn_lbl = ctk.CTkLabel(bar, text="\u25cf  Connecting…",
                                      text_color=WARN, font=("Consolas", 12))
        self._conn_lbl.pack(side="left", padx=(0,20))

        self._pps_lbl = ctk.CTkLabel(bar, text="0 pkt/s", text_color=DIM,
                                     font=("Consolas", 11))
        self._pps_lbl.pack(side="left", padx=(0,12))

        self._gap_lbl = ctk.CTkLabel(bar, text="0 gaps", text_color=DIM,
                                     font=("Consolas", 11))
        self._gap_lbl.pack(side="left")

        self._age_lbl = ctk.CTkLabel(bar, text="telem: ---ms", text_color=DIM,
                                     font=("Consolas", 11))
        self._age_lbl.pack(side="right", padx=12)

    # ------------------------------------------------------------------
    # Tabs
    # ------------------------------------------------------------------
    def _build_tabs(self):
        self._nb = ctk.CTkTabview(self, fg_color=BG,
                                  segmented_button_fg_color=PANEL,
                                  segmented_button_selected_color=ACCENT,
                                  segmented_button_unselected_color=PANEL,
                                  text_color=TEXT)
        self._nb.pack(fill="both", expand=True, padx=6, pady=4)

        for name in ("Overview", "PDU", "IMU", "Motors", "Log"):
            self._nb.add(name)

        self._build_overview(self._nb.tab("Overview"))
        self._build_pdu(self._nb.tab("PDU"))
        self._build_imu(self._nb.tab("IMU"))
        self._build_motors(self._nb.tab("Motors"))
        self._build_log(self._nb.tab("Log"))

    # ------------------------------------------------------------------
    # Overview tab
    # ------------------------------------------------------------------
    def _build_overview(self, tab):
        tab.configure(fg_color=BG)

        # Health panel (left)
        health = ctk.CTkFrame(tab, fg_color=PANEL, corner_radius=8)
        health.pack(side="left", fill="y", padx=(6,4), pady=6)

        ctk.CTkLabel(health, text="SUBSYSTEM HEALTH",
                     text_color=ACCENT, font=("Consolas", 12, "bold")
                     ).grid(row=0, column=0, columnspan=3, pady=(8,4), padx=8, sticky="w")

        self._ov_dots = {}
        self._ov_vals = {}
        items = [
            ("IMU0",      "imu0"),
            ("IMU1",      "imu1"),
            ("PDU FPGA",  "fpga"),
            ("PDU Rails", "rails"),
            ("Energy Mtr","em"),
            ("PDU HB",    "pdu_hb"),
            ("CAN Loop",  "can_lb"),
        ]
        for i, (label, key) in enumerate(items, start=1):
            dot = _status_dot(health, row=i)
            ctk.CTkLabel(health, text=label, anchor="w",
                         text_color=TEXT, font=("Consolas", 11), width=90
                         ).grid(row=i, column=1, sticky="w", padx=(0,4), pady=1)
            val = ctk.CTkLabel(health, text="---", anchor="w",
                               text_color=DIM, font=("Consolas", 10), width=100)
            val.grid(row=i, column=2, sticky="w", padx=(0,8), pady=1)
            self._ov_dots[key] = dot
            self._ov_vals[key] = val

        # Quick stats
        stats = ctk.CTkFrame(health, fg_color=BG, corner_radius=6)
        stats.grid(row=len(items)+1, column=0, columnspan=3, padx=8, pady=8, sticky="ew")
        self._ov_uptime = _lv_row(stats, "Uptime",    0)
        self._ov_pkts   = _lv_row(stats, "Packets",   1)
        self._ov_vraws  = _lv_row(stats, "V_RAW_SW",  2)

        # Command buttons (right of health)
        cmds = ctk.CTkFrame(tab, fg_color=PANEL, corner_radius=8)
        cmds.pack(side="left", fill="none", padx=4, pady=6)

        ctk.CTkLabel(cmds, text="QUICK COMMANDS",
                     text_color=ACCENT, font=("Consolas", 12, "bold")
                     ).pack(pady=(8,4), padx=12, anchor="w")

        btn_defs = [
            ("Ping",       lambda: self._send_dbg(DBGCMD_PING)),
            ("Buzz",       lambda: self._send_dbg(DBGCMD_BUZZ)),
            ("LED Blink",  lambda: self._send_dbg(DBGCMD_LED_BLINK)),
            ("CAN Loopback", lambda: self._send_dbg(DBGCMD_CAN_LOOPBACK)),
            ("Force Telem",  lambda: self._send_dbg(DBGCMD_FORCE_TELEM)),
        ]
        for label, cmd in btn_defs:
            ctk.CTkButton(cmds, text=label, command=cmd, width=140,
                          fg_color=ACCENT, hover_color="#4d9bd4",
                          font=("Consolas", 11)
                          ).pack(pady=4, padx=12)

        # Ping result
        self._ping_frame = ctk.CTkFrame(cmds, fg_color=BG, corner_radius=6)
        self._ping_frame.pack(fill="x", padx=8, pady=8)
        ctk.CTkLabel(self._ping_frame, text="Last ping reply:",
                     text_color=DIM, font=("Consolas", 10)
                     ).pack(anchor="w", padx=6)
        self._ping_lbl = ctk.CTkLabel(self._ping_frame, text="(none)",
                                      text_color=TEXT, font=("Consolas", 10),
                                      justify="left", anchor="w", wraplength=200)
        self._ping_lbl.pack(anchor="w", padx=6, pady=(0,6))

    # ------------------------------------------------------------------
    # PDU tab
    # ------------------------------------------------------------------
    def _build_pdu(self, tab):
        tab.configure(fg_color=BG)

        # Left column: FPGA + rails
        left = ctk.CTkScrollableFrame(tab, fg_color=BG, width=380)
        left.pack(side="left", fill="y", padx=(6,2), pady=6)

        # FPGA section
        fpga_f = ctk.CTkFrame(left, fg_color=PANEL, corner_radius=8)
        fpga_f.pack(fill="x", pady=(0,6))
        ctk.CTkLabel(fpga_f, text="FPGA STATUS",
                     text_color=ACCENT, font=("Consolas", 12, "bold")
                     ).grid(row=0, column=0, columnspan=2, padx=8, pady=(6,2), sticky="w")
        self._pdu = {}
        rows = [
            ("State",       "fpga_state"),
            ("STATUS0",     "fpga_sts0_str"),
            ("INPUTS",      "fpga_inp_str"),
            ("Fault",       "fpga_fault"),
            ("Actions",     "fpga_act"),
            ("Version",     "fpga_ver"),
            ("Pchg timer",  "fpga_pchg"),
        ]
        for i, (lbl, key) in enumerate(rows, start=1):
            self._pdu[key] = _lv_row(fpga_f, lbl, i, width=180)

        # Power rails section
        rail_f = ctk.CTkFrame(left, fg_color=PANEL, corner_radius=8)
        rail_f.pack(fill="x", pady=(0,6))
        ctk.CTkLabel(rail_f, text="POWER RAILS",
                     text_color=ACCENT, font=("Consolas", 12, "bold")
                     ).grid(row=0, column=0, columnspan=2, padx=8, pady=(6,2), sticky="w")
        rail_rows = [
            ("V_RAW_SW",  "v_vraw"),
            ("V_12V",     "v_12v"),
            ("V_24V",     "v_24v"),
            ("I_RAW_SW",  "i_vraw_sw"),
            ("I_12V",     "i_12v"),
            ("I_24V",     "i_24v"),
            ("ExtTherm1", "th1"),
            ("ExtTherm2", "th2"),
        ]
        for i, (lbl, key) in enumerate(rail_rows, start=1):
            self._pdu[key] = _lv_row(rail_f, lbl, i, width=120)

        # Energy Meter section
        em_f = ctk.CTkFrame(left, fg_color=PANEL, corner_radius=8)
        em_f.pack(fill="x", pady=(0,6))
        ctk.CTkLabel(em_f, text="ENERGY METER (RS485)",
                     text_color=ACCENT, font=("Consolas", 12, "bold")
                     ).grid(row=0, column=0, columnspan=2, padx=8, pady=(6,2), sticky="w")
        for i, (lbl, key) in enumerate([
            ("Current",  "em_i"),
            ("Voltage",  "em_v"),
            ("Power",    "em_p"),
            ("Temp",     "em_t"),
        ], start=1):
            self._pdu[key] = _lv_row(em_f, lbl, i, width=120)

        # Board ADC section
        ladc_f = ctk.CTkFrame(left, fg_color=PANEL, corner_radius=8)
        ladc_f.pack(fill="x", pady=(0,6))
        ctk.CTkLabel(ladc_f, text="BOARD ADC (STM32 LOCAL)",
                     text_color=ACCENT, font=("Consolas", 12, "bold")
                     ).grid(row=0, column=0, columnspan=2, padx=8, pady=(6,2), sticky="w")
        for i, (lbl, key) in enumerate([
            ("Therm0",  "lt0"),
            ("Therm1",  "lt1"),
            ("Therm2",  "lt2"),
            ("V_source","lvsrc"),
            ("V_bus",   "lvbus"),
            ("I_coil",  "licoil"),
        ], start=1):
            self._pdu[key] = _lv_row(ladc_f, lbl, i, width=120)

        # Right column: voltage history plot
        right = ctk.CTkFrame(tab, fg_color=BG)
        right.pack(side="left", fill="both", expand=True, padx=(2,6), pady=6)
        ctk.CTkLabel(right, text="Rail voltage history (30 s)",
                     text_color=DIM, font=("Consolas", 10)).pack(anchor="w", padx=6)
        self._pdu_fig, pdu_axs = _make_fig(figsize=(6, 4))
        self._pdu_ax = pdu_axs[0]
        self._pdu_ax.set_ylabel("V", color=TEXT, fontsize=9)
        xs = list(range(HISTORY_LEN))
        self._pdu_line_vraw, = self._pdu_ax.plot(xs, [0]*HISTORY_LEN,
                                                   color=WARN, lw=1.2, label="V_RAW_SW")
        self._pdu_line_v12,  = self._pdu_ax.plot(xs, [0]*HISTORY_LEN,
                                                   color=OK,   lw=1.2, label="12V")
        self._pdu_line_v24,  = self._pdu_ax.plot(xs, [0]*HISTORY_LEN,
                                                   color=ACCENT, lw=1.2, label="24V")
        self._pdu_ax.legend(loc="upper left", fontsize=8,
                            facecolor=PANEL, edgecolor=DIM, labelcolor=TEXT)
        self._pdu_canvas = _embed_fig(self._pdu_fig, right)

    # ------------------------------------------------------------------
    # IMU tab
    # ------------------------------------------------------------------
    def _build_imu(self, tab):
        tab.configure(fg_color=BG)
        self._imu = {}

        for col_idx, (imu_name, prefix) in enumerate([("IMU0 (SPI4, CS=PC13)", "imu0"),
                                                       ("IMU1 (SPI3, CS=PA15)", "imu1")]):
            frame = ctk.CTkFrame(tab, fg_color=PANEL, corner_radius=8)
            frame.pack(side="left", fill="both", expand=True,
                       padx=(6 if col_idx == 0 else 2, 6 if col_idx == 1 else 2),
                       pady=6)
            ctk.CTkLabel(frame, text=imu_name,
                         text_color=ACCENT, font=("Consolas", 12, "bold")
                         ).grid(row=0, column=0, columnspan=2, padx=8, pady=(6,2), sticky="w")

            fields = [
                ("Ax", f"{prefix}_ax"), ("Ay", f"{prefix}_ay"), ("Az", f"{prefix}_az"),
                ("|a|", f"{prefix}_mag"),
                ("Gx", f"{prefix}_gx"), ("Gy", f"{prefix}_gy"), ("Gz", f"{prefix}_gz"),
                ("Temp", f"{prefix}_temp"),
            ]
            for i, (lbl, key) in enumerate(fields, start=1):
                self._imu[key] = _lv_row(frame, lbl, i, width=110)

            # |a| history plot
            plot_frame = ctk.CTkFrame(frame, fg_color=BG)
            plot_frame.grid(row=len(fields)+1, column=0, columnspan=2,
                            padx=4, pady=4, sticky="ew")
            fig, axs = _make_fig(figsize=(4.5, 2.2))
            ax = axs[0]
            ax.set_ylabel("|a| (g)", color=TEXT, fontsize=8)
            line, = ax.plot(list(range(HISTORY_LEN)), [0]*HISTORY_LEN,
                            color=ACCENT if prefix == "imu0" else WARN, lw=1.2)
            ax.set_ylim(0, 2)
            canvas = _embed_fig(fig, plot_frame)
            self._imu[f"{prefix}_fig"]    = fig
            self._imu[f"{prefix}_mpl_ax"] = ax
            self._imu[f"{prefix}_line"]   = line
            self._imu[f"{prefix}_canvas"] = canvas

    # ------------------------------------------------------------------
    # Motors tab
    # ------------------------------------------------------------------
    def _build_motors(self, tab):
        tab.configure(fg_color=BG)

        # FB table
        table_f = ctk.CTkFrame(tab, fg_color=PANEL, corner_radius=8)
        table_f.pack(fill="both", expand=True, padx=6, pady=6, side="top")
        ctk.CTkLabel(table_f, text="MOTOR FEEDBACK",
                     text_color=ACCENT, font=("Consolas", 12, "bold")
                     ).pack(anchor="w", padx=8, pady=(6,2))

        cols = ("Bus", "ID", "Pos (rad)", "Vel (rad/s)", "Torque (Nm)", "Error")
        self._motor_tree = ttk.Treeview(table_f, columns=cols,
                                        show="headings", height=12)
        style = ttk.Style()
        style.theme_use("clam")
        style.configure("Treeview",
                        background=PANEL, foreground=TEXT,
                        fieldbackground=PANEL, rowheight=22,
                        font=("Consolas", 10))
        style.configure("Treeview.Heading",
                        background=BG, foreground=ACCENT,
                        font=("Consolas", 10, "bold"))
        for col in cols:
            self._motor_tree.heading(col, text=col)
            self._motor_tree.column(col, width=110, anchor="center")
        self._motor_tree.pack(fill="both", expand=True, padx=6, pady=4)

        # Command entry
        cmd_f = ctk.CTkFrame(tab, fg_color=PANEL, corner_radius=8)
        cmd_f.pack(fill="x", padx=6, pady=(0,6), side="bottom")
        ctk.CTkLabel(cmd_f, text="MOTOR COMMAND",
                     text_color=ACCENT, font=("Consolas", 12, "bold")
                     ).grid(row=0, column=0, columnspan=8, padx=8, pady=(6,2), sticky="w")

        fields = [
            ("Bus (0=R,1=L)", "_mc_bus",  "0"),
            ("Motor ID",      "_mc_id",   "1"),
            ("Pos (rad)",     "_mc_pos",  "0.0"),
            ("Vel (rad/s)",   "_mc_vel",  "0.0"),
            ("Trq (Nm)",      "_mc_trq",  "0.0"),
            ("Kp",            "_mc_kp",   "10.0"),
            ("Kd",            "_mc_kd",   "1.0"),
        ]
        self._mc_vars = {}
        for col_i, (lbl, attr, default) in enumerate(fields):
            ctk.CTkLabel(cmd_f, text=lbl, text_color=DIM,
                         font=("Consolas", 10)
                         ).grid(row=1, column=col_i, padx=4, pady=2)
            var = ctk.StringVar(value=default)
            entry = ctk.CTkEntry(cmd_f, textvariable=var, width=78,
                                 font=("Consolas", 11))
            entry.grid(row=2, column=col_i, padx=4, pady=2)
            setattr(self, attr, var)
            self._mc_vars[attr] = var

        ctk.CTkButton(cmd_f, text="Send", width=80, command=self._send_motor,
                      fg_color=OK, hover_color="#7aad5c", text_color=BG,
                      font=("Consolas", 11, "bold")
                      ).grid(row=2, column=len(fields), padx=8, pady=2)

        self._mc_status = ctk.CTkLabel(cmd_f, text="", text_color=DIM,
                                       font=("Consolas", 10))
        self._mc_status.grid(row=3, column=0, columnspan=8, padx=8, pady=(0,6), sticky="w")

    # ------------------------------------------------------------------
    # Log tab
    # ------------------------------------------------------------------
    def _build_log(self, tab):
        tab.configure(fg_color=BG)
        self._log_text = ctk.CTkTextbox(tab, fg_color=PANEL,
                                        text_color=TEXT,
                                        font=("Consolas", 10),
                                        wrap="none", state="disabled")
        self._log_text.pack(fill="both", expand=True, padx=6, pady=6)

    # ------------------------------------------------------------------
    # Receiver lifecycle
    # ------------------------------------------------------------------
    def _start_receiver(self):
        self.rcu_ip = self._ip_var.get().strip() or RCU_IP_DEFAULT
        self.rcu.rcu_ip = self.rcu_ip
        if self._recv and self._recv.is_alive():
            self._recv.stop()
        self._recv = RcuReceiver(self.rcu)
        self._recv.start()

    def _reconnect(self):
        self._start_receiver()

    # ------------------------------------------------------------------
    # Debug commands
    # ------------------------------------------------------------------
    def _send_dbg(self, subcmd):
        ip = self._ip_var.get().strip() or RCU_IP_DEFAULT
        threading.Thread(target=send_debug_cmd, args=(ip, subcmd),
                         daemon=True).start()

    def _send_motor(self):
        try:
            bus = int(self._mc_bus.get())
            mid = int(self._mc_id.get())
            pos = float(self._mc_pos.get())
            vel = float(self._mc_vel.get())
            trq = float(self._mc_trq.get())
            kp  = float(self._mc_kp.get())
            kd  = float(self._mc_kd.get())
        except ValueError as e:
            self._mc_status.configure(text=f"Parse error: {e}", text_color=ERROR)
            return
        ip = self._ip_var.get().strip() or RCU_IP_DEFAULT
        threading.Thread(target=send_motor_cmd,
                         args=(ip, bus, mid, pos, vel, trq, kp, kd),
                         daemon=True).start()
        self._mc_status.configure(
            text=f"Sent: bus={bus} id={mid} pos={pos:.3f} kp={kp:.1f} kd={kd:.2f}",
            text_color=OK)

    # ------------------------------------------------------------------
    # Main update loop (runs every 100 ms on UI thread)
    # ------------------------------------------------------------------
    def _update_loop(self):
        try:
            self._update_topbar()
            t = self.rcu.get_telem()
            if t:
                self._update_overview(t)
                self._update_pdu(t)
                self._update_imu(t)
            self._update_motors()
        except Exception:
            pass
        self.after(100, self._update_loop)

    def _update_topbar(self):
        connected = self.rcu.is_connected()
        age_ms    = self.rcu.telem_age()
        pps       = self.rcu.pkts_per_sec()
        gaps      = self.rcu.seq_gaps

        if connected:
            if age_ms < 500:
                self._conn_lbl.configure(text="\u25cf  Live", text_color=OK)
            else:
                self._conn_lbl.configure(text="\u25cf  Stale", text_color=WARN)
        else:
            self._conn_lbl.configure(text="\u25cf  Disconnected", text_color=ERROR)

        self._pps_lbl.configure(text=f"{pps} pkt/s")
        self._gap_lbl.configure(text=f"{gaps} gaps")
        age_str = f"{age_ms}ms" if age_ms < 9999 else "---"
        self._age_lbl.configure(text=f"telem: {age_str}")

    def _update_overview(self, t):
        ping = self.rcu.last_ping

        def _set(key, ok, txt=""):
            dot = self._ov_dots.get(key)
            val = self._ov_vals.get(key)
            if dot:
                dot.configure(text_color=OK if ok else ERROR)
            if val:
                val.configure(text=txt, text_color=TEXT if ok else ERROR)

        imu0_mag = math.sqrt(t.get("imu0_ax_g",0)**2 +
                             t.get("imu0_ay_g",0)**2 +
                             t.get("imu0_az_g",0)**2)
        imu1_mag = math.sqrt(t.get("imu1_ax_g",0)**2 +
                             t.get("imu1_ay_g",0)**2 +
                             t.get("imu1_az_g",0)**2)

        _set("imu0",   imu0_mag > 0.1, f"|a|={imu0_mag:.3f}g")
        _set("imu1",   imu1_mag > 0.1, f"|a|={imu1_mag:.3f}g")
        _set("fpga",   ping.get("fpga_ok", False), "OK" if ping.get("fpga_ok") else "not rx")
        _set("rails",  ping.get("rails_ok", False), "OK" if ping.get("rails_ok") else "not rx")
        _set("em",     ping.get("em_ok", False), "OK" if ping.get("em_ok") else "not rx")
        pdu_hb_ok = ping.get("hb_age_ms", 0xFFFFFFFF) < 2000
        hb_txt = f"{ping['hb_age_ms']}ms" if "hb_age_ms" in ping else "---"
        _set("pdu_hb", pdu_hb_ok, hb_txt)
        can_lb = ping.get("can_lb", 0)
        can_str = {0:"untested",1:"right only",2:"left only",3:"BOTH OK",0xFF:"FAIL"}.get(can_lb, f"0x{can_lb:02X}")
        _set("can_lb", can_lb == 3, can_str)

        uptime = ping.get("uptime_ms", 0)
        self._ov_uptime.configure(text=f"{uptime//1000}s" if uptime else "---")
        self._ov_pkts.configure(text=str(self.rcu.pkt_count))
        self._ov_vraws.configure(text=f"{t.get('v_vraw_v',0):.2f} V")

        # Ping reply text
        if ping:
            rsr = ping.get("boot_rsr", 0)
            rst = "clean" if rsr == 0 else f"RSR=0x{rsr:08X}"
            txt = (f"up={ping.get('uptime_ms',0)//1000}s  reset={rst}\n"
                   f"IMU0={'OK' if ping.get('imu0_ok') else 'FAIL'}  "
                   f"IMU1={'OK' if ping.get('imu1_ok') else 'FAIL'}")
            self._ping_lbl.configure(text=txt)

    def _update_pdu(self, t):
        pdu = self._pdu

        state_str = FPGA_STATES.get(t.get("fpga_sc", 0), "?")
        pdu["fpga_state"].configure(text=state_str,
            text_color=OK if state_str in ("ARMED","COMPUTE") else WARN)
        pdu["fpga_sts0_str"].configure(text=decode_bits(t.get("fpga_sts0",0), S0_BITS))
        pdu["fpga_inp_str"].configure(text=decode_bits(t.get("fpga_inputs",0), IN_BITS))
        fc = t.get("fpga_fc", 0)
        pdu["fpga_fault"].configure(text=f"0x{fc:02X}" if fc else "none",
                                    text_color=ERROR if fc else OK)
        pdu["fpga_act"].configure(text=f"0x{t.get('fpga_act',0):02X}")
        pdu["fpga_ver"].configure(text=f"0x{t.get('fpga_version',0):02X}")
        pdu["fpga_pchg"].configure(text=f"{t.get('fpga_pchg_ms',0)} ms")

        v_raw = t.get("v_vraw_v", 0.0)
        pdu["v_vraw"].configure(
            text=f"{v_raw:.2f} V",
            text_color=_color_label(v_raw, 40.0, 62.0, lo_err=20.0, hi_err=65.0))
        pdu["v_12v"].configure(text=f"{t.get('v_12v_mv',0)/1000:.3f} V")
        pdu["v_24v"].configure(text=f"{t.get('v_24v_mv',0)/1000:.3f} V")
        pdu["i_vraw_sw"].configure(text=f"{t.get('i_vraw_sw_ma',0)} mA")
        pdu["i_12v"].configure(text=f"{t.get('i_12v_ma',0)} mA")
        pdu["i_24v"].configure(text=f"{t.get('i_24v_ma',0)} mA")
        pdu["th1"].configure(text=f"{t.get('therm1_c',0):.1f} °C")
        pdu["th2"].configure(text=f"{t.get('therm2_c',0):.1f} °C")

        pdu["em_i"].configure(text=f"{t.get('em_i_ma',0)} mA")
        pdu["em_v"].configure(text=f"{t.get('em_v_mv',0)} mV")
        pdu["em_p"].configure(text=f"{t.get('em_p_w',0):.1f} W")
        pdu["em_t"].configure(text=f"{t.get('em_t_c',0):.1f} °C")

        pdu["lt0"].configure(text=f"{t.get('ladc_therm0_c',0):.1f} °C")
        pdu["lt1"].configure(text=f"{t.get('ladc_therm1_c',0):.1f} °C")
        pdu["lt2"].configure(text=f"{t.get('ladc_therm2_c',0):.1f} °C")
        pdu["lvsrc"].configure(text=f"{t.get('ladc_vsource_v',0):.3f} V")
        pdu["lvbus"].configure(text=f"{t.get('ladc_vbus_v',0):.3f} V")
        pdu["licoil"].configure(text=f"{t.get('ladc_icoil_ma',0)} mA")

        # Update rail voltage plot
        h_vraw = self.rcu.get_history("h_vraw")
        h_v12  = self.rcu.get_history("h_v12")
        h_v24  = self.rcu.get_history("h_v24")
        xs = list(range(HISTORY_LEN))
        self._pdu_line_vraw.set_data(xs, h_vraw)
        self._pdu_line_v12.set_data(xs, h_v12)
        self._pdu_line_v24.set_data(xs, h_v24)
        self._pdu_ax.relim()
        self._pdu_ax.autoscale_view()
        self._pdu_canvas.draw_idle()

        # Log entry
        self._log(f"PDU  V_RAW={v_raw:.2f}V  FPGA={state_str}  "
                  f"EM={t.get('em_p_w',0):.1f}W")

    def _update_imu(self, t):
        for prefix in ("imu0", "imu1"):
            ax_g = t.get(f"{prefix}_ax_g", 0.0)
            ay_g = t.get(f"{prefix}_ay_g", 0.0)
            az_g = t.get(f"{prefix}_az_g", 0.0)
            mag  = math.sqrt(ax_g**2 + ay_g**2 + az_g**2)
            ok   = mag > 0.05

            self._imu[f"{prefix}_ax"].configure(
                text=f"{ax_g:+.4f} g", text_color=TEXT if ok else ERROR)
            self._imu[f"{prefix}_ay"].configure(text=f"{ay_g:+.4f} g")
            self._imu[f"{prefix}_az"].configure(text=f"{az_g:+.4f} g")
            self._imu[f"{prefix}_mag"].configure(
                text=f"{mag:.4f} g",
                text_color=OK if 0.95 < mag < 1.05 else (WARN if ok else ERROR))
            self._imu[f"{prefix}_gx"].configure(
                text=f"{t.get(f'{prefix}_gx_dps',0):+.1f} dps")
            self._imu[f"{prefix}_gy"].configure(
                text=f"{t.get(f'{prefix}_gy_dps',0):+.1f} dps")
            self._imu[f"{prefix}_gz"].configure(
                text=f"{t.get(f'{prefix}_gz_dps',0):+.1f} dps")
            self._imu[f"{prefix}_temp"].configure(
                text=f"{t.get(f'{prefix}_temp_c',0):.1f} °C")

            hist = self.rcu.get_history(f"h_{prefix}_mag")
            xs   = list(range(HISTORY_LEN))
            line = self._imu[f"{prefix}_line"]
            line.set_data(xs, hist)
            self._imu[f"{prefix}_mpl_ax"].relim()
            self._imu[f"{prefix}_mpl_ax"].autoscale_view()
            self._imu[f"{prefix}_fig"].canvas.draw_idle()

    def _update_motors(self):
        slots = self.rcu.get_motor_slots()
        tree  = self._motor_tree
        for row in tree.get_children():
            tree.delete(row)
        bus_names = {0: "R", 1: "L"}
        for s in slots:
            tree.insert("", "end", values=(
                bus_names.get(s["bus"], s["bus"]),
                s["motor_id"],
                f"{s['pos_rad']:+.4f}",
                f"{s['vel_rads']:+.3f}",
                f"{s['torque_nm']:+.2f}",
                f"0x{s['error']:02X}" if s["error"] else "OK",
            ))

    def _log(self, msg):
        ts  = time.strftime("%H:%M:%S")
        line = f"[{ts}] {msg}\n"
        self._log_lines.append(line)
        try:
            self._log_text.configure(state="normal")
            self._log_text.insert("end", line)
            self._log_text.see("end")
            # Trim to maxlen
            if len(self._log_lines) >= 500:
                self._log_text.delete("1.0", "2.0")
            self._log_text.configure(state="disabled")
        except Exception:
            pass

    def on_close(self):
        if self._recv:
            self._recv.stop()
        self.destroy()


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
def main():
    ap = argparse.ArgumentParser(description="RCU bench GUI")
    ap.add_argument("--rcu-ip", default=RCU_IP_DEFAULT,
                    help=f"RCU board IP (default {RCU_IP_DEFAULT})")
    args = ap.parse_args()

    app = App(rcu_ip=args.rcu_ip)
    app.protocol("WM_DELETE_WINDOW", app.on_close)
    app.mainloop()


if __name__ == "__main__":
    main()


