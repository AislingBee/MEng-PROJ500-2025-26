  library IEEE, vital2000, MACHXO2;
  use IEEE.STD_LOGIC_1164.all;
  use vital2000.vital_timing.all;
  use MACHXO2.COMPONENTS.ALL;

  entity i2c1_sdaB is
    -- miscellaneous vital GENERICs
    GENERIC (
      TimingChecksOn	: boolean := TRUE;
      XOn           	: boolean := FALSE;
      MsgOn         	: boolean := TRUE;
      InstancePath  	: string := "i2c1_sdaB";

      tipd_PADDT  	: VitalDelayType01 := (0 ns, 0 ns);
      tipd_PADDO  	: VitalDelayType01 := (0 ns, 0 ns);
      tipd_i2c1sda  	: VitalDelayType01 := (0 ns, 0 ns);

        tpd_PADDT_i2c1sda	 : VitalDelayType01Z := (0 ns, 0 ns, 0 ns , 0 ns, 0 ns, 0 ns)
        ;

        tpd_PADDO_i2c1sda	 : VitalDelayType01Z := (0 ns, 0 ns, 0 ns , 0 ns, 0 ns, 0 ns)
        ;
      tpd_i2c1sda_PADDI	 : VitalDelayType01 := (0 ns, 0 ns);
      tperiod_i2c1sda 	: VitalDelayType := 0 ns;
      tpw_i2c1sda_posedge	: VitalDelayType := 0 ns;
      tpw_i2c1sda_negedge	: VitalDelayType := 0 ns;

        tpd_i2c1sda_i2c1sda	 : VitalDelayType01Z := (0 ns, 0 ns, 0 ns , 0 ns, 0 ns, 0 ns)
        );

    port (PADDI: out Std_logic; PADDT: in Std_logic; PADDO: in Std_logic; 
          i2c1sda: inout Std_logic);

    ATTRIBUTE Vital_Level0 OF i2c1_sdaB : ENTITY IS TRUE;

  end i2c1_sdaB;

  architecture Structure of i2c1_sdaB is
    ATTRIBUTE Vital_Level0 OF Structure : ARCHITECTURE IS TRUE;

    signal PADDI_out 	: std_logic := 'X';
    signal PADDT_ipd 	: std_logic := 'X';
    signal PADDO_ipd 	: std_logic := 'X';
    signal i2c1sda_ipd 	: std_logic := 'X';
    signal i2c1sda_out 	: std_logic := 'Z';

    component xo2iobuf0114
      port (I: in Std_logic; T: in Std_logic; Z: out Std_logic; 
            PAD: out Std_logic; PADI: in Std_logic);
    end component;
  begin
    u_efb_i2c_BB1_sda: xo2iobuf0114
      port map (I=>PADDO_ipd, T=>PADDT_ipd, Z=>PADDI_out, PAD=>i2c1sda_out, 
                PADI=>i2c1sda_ipd);

    --  INPUT PATH DELAYs
    WireDelay : BLOCK
    BEGIN
      VitalWireDelay(PADDT_ipd, PADDT, tipd_PADDT);
      VitalWireDelay(PADDO_ipd, PADDO, tipd_PADDO);
      VitalWireDelay(i2c1sda_ipd, i2c1sda, tipd_i2c1sda);
    END BLOCK;

    VitalBehavior : PROCESS (PADDI_out, PADDT_ipd, PADDO_ipd, i2c1sda_ipd, 
      i2c1sda_out)
    VARIABLE PADDI_zd         	: std_logic := 'X';
    VARIABLE PADDI_GlitchData 	: VitalGlitchDataType;
    VARIABLE i2c1sda_zd         	: std_logic := 'X';
    VARIABLE i2c1sda_GlitchData 	: VitalGlitchDataType;

    VARIABLE tviol_i2c1sda_i2c1sda          	: x01 := '0';
    VARIABLE periodcheckinfo_i2c1sda	: VitalPeriodDataType;

    BEGIN

    IF (TimingChecksOn) THEN
      VitalPeriodPulseCheck (
        TestSignal => i2c1sda_ipd,
        TestSignalName => "i2c1sda",
        Period => tperiod_i2c1sda,
        PulseWidthHigh => tpw_i2c1sda_posedge,
        PulseWidthLow => tpw_i2c1sda_negedge,
        PeriodData => periodcheckinfo_i2c1sda,
        Violation => tviol_i2c1sda_i2c1sda,
        MsgOn => MsgOn, XOn => XOn,
        HeaderMsg => InstancePath,
        CheckEnabled => TRUE,
        MsgSeverity => warning);

    END IF;

    PADDI_zd 	:= PADDI_out;
    i2c1sda_zd 	:= i2c1sda_out;

    VitalPathDelay01 (
      OutSignal => PADDI, OutSignalName => "PADDI", OutTemp => PADDI_zd,
      Paths      => (0 => (InputChangeTime => i2c1sda_ipd'last_event,
                           PathDelay => tpd_i2c1sda_PADDI,
                           PathCondition => TRUE)),
      GlitchData => PADDI_GlitchData,
      Mode       => vitaltransport, XOn => XOn, MsgOn => MsgOn);
    VitalPathDelay01Z (
      OutSignal => i2c1sda, OutSignalName => "i2c1sda", OutTemp => i2c1sda_zd,
      Paths      => (0 => (InputChangeTime => PADDT_ipd'last_event,
                           PathDelay => tpd_PADDT_i2c1sda,
                           PathCondition => TRUE),
                     1 => (InputChangeTime => PADDO_ipd'last_event,
                           PathDelay => tpd_PADDO_i2c1sda,
                           PathCondition => TRUE)),
      GlitchData => i2c1sda_GlitchData,
      Mode       => vitaltransport, XOn => XOn, MsgOn => MsgOn);

    END PROCESS;

  end Structure;

