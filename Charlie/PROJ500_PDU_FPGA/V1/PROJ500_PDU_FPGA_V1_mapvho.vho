      OutSignal => PADDI, OutSignalName => "PADDI", OutTemp => PADDI_zd,
      Paths      => (0 => (InputChangeTime => SWCOMPUTE_ipd'last_event,
                           PathDelay => tpd_SWCOMPUTE_PADDI,
                           PathCondition => TRUE)),
