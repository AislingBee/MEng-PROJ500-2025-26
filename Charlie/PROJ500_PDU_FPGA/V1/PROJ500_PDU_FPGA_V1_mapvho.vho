    PADDI_zd 	:= PADDI_out;
    i2c1scl_zd 	:= i2c1scl_out;

    VitalPathDelay01 (
      OutSignal => PADDI, OutSignalName => "PADDI", OutTemp => PADDI_zd,
      Paths      => (0 => (InputChangeTime => i2c1scl_ipd'last_event,
