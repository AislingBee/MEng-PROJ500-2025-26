        PulseWidthLow => tpw_SWCOMPUTE_negedge,
        PeriodData => periodcheckinfo_SWCOMPUTE,
        Violation => tviol_SWCOMPUTE_SWCOMPUTE,
        MsgOn => MsgOn, XOn => XOn,
        HeaderMsg => InstancePath,
        CheckEnabled => TRUE,
        MsgSeverity => warning);

    END IF;

    PADDI_zd 	:= PADDI_out;

